#   servicio app → postgresql://USER:PASS@postgres:5432/DB
# Host (migraciones/seed): pasarla inline al comando →
#   postgresql://USER:PASS@localhost:5433/DB
# DATABASE_URL=postgresql://esoft:cambia_esto_en_produccion@localhost:5433/esoft_db

SESSION_SECRET=cambia_esto_en_produccion
