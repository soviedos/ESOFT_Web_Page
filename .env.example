POSTGRES_USER=esoft
POSTGRES_PASSWORD=cambia_esto_en_produccion
POSTGRES_DB=esoft_db

# DATABASE_URL la consume astro:env/server (requerida; lanza error al inicio si falta).
# Este valor es para comandos desde el HOST (migraciones, seed, db:reset, db:studio):
#   el contenedor esoft_postgres expone el puerto 5432 interno como 5433 en el host.
# Dentro de Docker NO se usa este valor: Compose arma e inyecta al servicio app
#   DATABASE_URL=postgresql://USER:PASS@postgres:5432/DB (host postgres, puerto 5432 interno).
DATABASE_URL=postgresql://esoft:cambia_esto_en_produccion@localhost:5433/esoft_db

SESSION_SECRET=cambia_esto_en_produccion
PUBLIC_SITE_URL=https://esoft.ucenfotec.ac.cr
AI_API_KEY=
PGADMIN_EMAIL=admin@esoft.local
PGADMIN_PASSWORD=admin
