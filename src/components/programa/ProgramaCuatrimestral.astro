---
import type { ProgramaDetalle, EstadisticaDato } from '../../lib/types'
import { nivelLabel } from '../../lib/labels'
import Base from '../../layouts/Base.astro'
import ProgramaHero from '../sections/ProgramaHero.astro'
import CurriculumTabla from './CurriculumTabla.astro'
import TechGrid from '../sections/TechGrid.astro'
import InfoCTA from '../sections/InfoCTA.astro'

interface Props { programa: ProgramaDetalle }
const { programa } = Astro.props

const cursos = programa.cursos ?? []

const badge = [
  programa.nivel ? nivelLabel[programa.nivel] ?? programa.nivel : 'Programa cuatrimestral',
  programa.duracionCuatrimestres != null ? `${programa.duracionCuatrimestres} cuatrimestres` : '',
].filter(Boolean).join(' · ')

const totalCreditos = cursos.reduce((s, c) => s + (c.creditos ?? 0), 0)
const totalHoras = cursos.reduce(
  (s, c) => s + (c.horasLectivas ?? 0) + (c.horasPracticas ?? 0) + (c.horasEstudio ?? 0), 0,
)

const estadisticas: EstadisticaDato[] = [
  programa.duracionCuatrimestres != null && { valor: String(programa.duracionCuatrimestres), label: 'Cuatrimestres', colorValor: 'brand', size: 'lg' },
  cursos.length > 0 && { valor: String(cursos.length), label: 'Cursos', colorValor: 'content', size: 'lg' },
  totalCreditos > 0 && { valor: String(totalCreditos), label: 'Créditos', colorValor: 'accent2', size: 'lg' },
  totalHoras > 0 && { valor: String(totalHoras), label: 'Horas totales', colorValor: 'content', size: 'lg' },
].filter(Boolean) as EstadisticaDato[]

const tieneEncabezadoExtra = Boolean(programa.objetivo || programa.perfilEgresado)
---

<Base title={programa.titulo} description={programa.descripcion}>
  <ProgramaHero
    titulo={programa.titulo}
    descripcion={programa.descripcion}
    badge={badge}
    breadcrumbItems={[
      { label: 'Programas', href: '/programas' },
      { label: 'Cuatrimestrales', href: '/programas/cuatrimestrales' },
      { label: programa.titulo },
    ]}
    estadisticas={estadisticas}
  />

  {tieneEncabezadoExtra && (
    <section class="py-12 md:py-16 px-6" style="background: var(--color-bg-secondary);">
      <div class="max-w-[1060px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-10">
        {programa.objetivo && (
          <div>
            <h2 class="text-[13px] font-bold text-brand-label tracking-widest uppercase mb-3">Objetivo</h2>
            <p class="text-content-secondary text-[15px] leading-[1.85]">{programa.objetivo}</p>
          </div>
        )}
        {programa.perfilEgresado && (
          <div>
            <h2 class="text-[13px] font-bold text-brand-label tracking-widest uppercase mb-3">Perfil de egreso</h2>
            <p class="text-content-secondary text-[15px] leading-[1.85]">{programa.perfilEgresado}</p>
          </div>
        )}
      </div>
    </section>
  )}

  {cursos.length > 0 && <CurriculumTabla cursos={cursos} />}

  {(programa.tecnologias?.length ?? 0) > 0 && (
    <section class="py-12 md:py-16 px-6" style="background: var(--color-bg-secondary);">
      <div class="max-w-[1060px] mx-auto">
        <TechGrid tecnologias={programa.tecnologias!} />
      </div>
    </section>
  )}

  <InfoCTA
    titulo={programa.titulo}
    descripcion={programa.objetivo ?? programa.descripcion}
  />
</Base>
