---
import type { ProgramaData } from '../../lib/types'
import ProgramaLayout from './ProgramaLayout.astro'

interface Props { programa: ProgramaData }
const { programa } = Astro.props
---
<ProgramaLayout programa={programa} heroGradient="rgba(0,106,234,0.06)">
  <slot name="before-curriculum" slot="before-curriculum" />
  <slot name="curriculum-extra" slot="curriculum-extra" />
  <slot name="after-curriculum" slot="after-curriculum" />
</ProgramaLayout>
