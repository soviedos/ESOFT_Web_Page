---
import type { ProgramaData } from '../../lib/types'
import Base from '../../layouts/Base.astro'
import ProgramaHero from '../sections/ProgramaHero.astro'
import CurriculumSection from '../sections/CurriculumSection.astro'
import TechGrid from '../sections/TechGrid.astro'
import InfoCTA from '../sections/InfoCTA.astro'

interface Props {
  programa: ProgramaData
  heroGradient?: string
}

const { programa, heroGradient } = Astro.props

const ROMANS = ['I','II','III','IV','V','VI','VII','VIII','IX','X','XI','XII']

const tipoLabel: Record<string, string> = {
  bachillerato:     'Bachillerato',
  maestria:         'Maestría',
  tecnico:          'Técnico',
  ruta_corporativa: 'Ruta Corporativa',
}

const badge = programa.badgeOverride ?? `${tipoLabel[programa.tipo] ?? programa.tipo} · ${programa.duracionCuatrimestres} cuatrimestres`

const estadisticas = (programa.estadisticas ?? []).map(e => ({
  valor:      e.valor,
  label:      e.label,
  colorValor: e.colorValor ?? ('content' as const),
  size:       e.size       ?? ('lg'      as const),
}))

const cursosFlat = (programa.cursos ?? []).slice().sort((a, b) =>
  a.cuatrimestre !== b.cuatrimestre ? a.cuatrimestre - b.cuatrimestre : a.orden - b.orden
)

const quarterMap = new Map<number, typeof cursosFlat>()
for (const c of cursosFlat) {
  if (!quarterMap.has(c.cuatrimestre)) quarterMap.set(c.cuatrimestre, [])
  quarterMap.get(c.cuatrimestre)!.push(c)
}

const cuatrimestres = [...quarterMap.entries()].map(([num, lista]) => ({
  num:      ROMANS[num - 1] ?? String(num),
  creditos: lista.reduce((s, c) => s + (c.creditos ?? 0), 0),
  cursos:   lista.map(c => ({ code: c.code ?? '', name: c.nombre, cr: c.creditos ?? 0 })),
}))

const subtitulo = cuatrimestres.length > 0
  ? `${cursosFlat.length} cursos · ${cuatrimestres.reduce((s, q) => s + q.creditos, 0)} créditos · ${cuatrimestres.length} cuatrimestres`
  : undefined

const tecnologias = programa.tecnologias ?? []
---

<Base title={programa.titulo} description={programa.descripcion}>
  <ProgramaHero
    titulo={programa.titulo}
    tituloAcento={programa.tituloAcento}
    descripcion={programa.descripcion}
    badge={badge}
    breadcrumbItems={[
      { label: 'Programas', href: '/programas' },
      { label: programa.titulo },
    ]}
    estadisticas={estadisticas}
    heroGradient={heroGradient}
  />

  <slot name="before-curriculum" />

  {cuatrimestres.length > 0 && (
    <CurriculumSection cuatrimestres={cuatrimestres} subtitulo={subtitulo}>
      <slot name="curriculum-extra" />
    </CurriculumSection>
  )}

  {tecnologias.length > 0 && (
    <section class="py-12 md:py-16 px-6" style="background: var(--color-bg-secondary);">
      <div class="max-w-[1060px] mx-auto">
        <TechGrid tecnologias={tecnologias} />
      </div>
    </section>
  )}

  <slot name="after-curriculum" />

  <InfoCTA
    titulo={programa.ctaTitulo ?? programa.titulo}
    tituloAcento={programa.ctaTituloAcento}
    descripcion={programa.ctaDescripcion ?? programa.objetivo ?? programa.descripcion}
  />
</Base>
