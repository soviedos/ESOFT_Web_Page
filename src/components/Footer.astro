---
const year = new Date().getFullYear();

const footerSections = [
  {
    title: 'Programas',
    links: [
      { href: '/programas/bachillerato-ingenieria-software', label: 'Bachillerato' },
      { href: '/programas/tecnico-ingenieria-software', label: 'Técnico en Software' },
      { href: '/programas/maestria-ingenieria-software-ia', label: 'Maestría en IA' },
      { href: '/programas', label: 'Ver todos' },
    ],
  },
  {
    title: 'ESOFT',
    links: [
      { href: '/escuela', label: 'La Escuela' },
      { href: '/calidad-academica', label: 'Calidad académica' },
      { href: '/industria-empleabilidad', label: 'Industria' },
      { href: '/historias', label: 'Testimonios' },
    ],
  },
  {
    title: 'Admisión',
    links: [
      { href: '/admision', label: 'Cómo aplicar' },
      { href: '/admision/requisitos', label: 'Requisitos' },
      { href: '/admision/financiamiento', label: 'Financiamiento' },
      { href: '/contacto', label: 'Contacto' },
    ],
  },
];
---

<footer class="bg-bg-primary border-t border-border-subtle text-content-muted">
  <div class="max-w-6xl mx-auto px-6 py-12 md:py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="text-lg font-bold text-content tracking-tight">ESOFT</a>
        <p class="mt-3 text-sm leading-relaxed">
          Escuela de Software, IA, Testing, UX y Arquitectura.
        </p>
      </div>

      {footerSections.map((section) => (
        <div>
          <h4 class="text-xs font-medium text-content-disabled uppercase tracking-wider mb-4">{section.title}</h4>
          <ul class="space-y-2.5">
            {section.links.map(({ href, label }) => (
              <li>
                <a href={href} class="text-sm hover:text-content transition-colors">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-border-subtle text-sm text-content-disabled">
      &copy; {year} ESOFT. Todos los derechos reservados.
    </div>
  </div>
</footer>
