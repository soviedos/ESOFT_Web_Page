---
const year = new Date().getFullYear();

const footerSections = [
  {
    title: 'Programas',
    links: [
      { href: '/programas/bachillerato-ingenieria-software', label: 'Bachillerato' },
      { href: '/programas/tecnico-ingenieria-software', label: 'Técnico en Software' },
      { href: '/programas/maestria-ingenieria-software-ia', label: 'Maestría en IA' },
      { href: '/programas', label: 'Ver todos' },
    ],
  },
  {
    title: 'ESOFT',
    links: [
      { href: '/escuela', label: 'La Escuela' },
      { href: '/calidad-academica', label: 'Calidad académica' },
      { href: '/industria-empleabilidad', label: 'Industria' },
      { href: '/historias', label: 'Testimonios' },
    ],
  },
  {
    title: 'Admisión',
    links: [
      { href: '/admision', label: 'Cómo aplicar' },
      { href: '/admision/requisitos', label: 'Requisitos' },
      { href: '/admision/financiamiento', label: 'Financiamiento' },
      { href: '/contacto', label: 'Contacto' },
    ],
  },
];
---

<footer class="relative bg-bg-primary border-t border-border-subtle text-content-muted overflow-hidden">
  <!-- Subtle gradient top line -->
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-white/[0.06] to-transparent"></div>

  <div class="max-w-[1100px] mx-auto px-6 py-16 md:py-20">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-16">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="text-[17px] font-bold text-content tracking-[-0.02em]">ESOFT</a>
        <p class="mt-4 text-[13px] leading-relaxed max-w-xs">
          Formamos a los ingenieros de software que la industria necesita.
        </p>
      </div>

      {footerSections.map((section) => (
        <div>
          <h4 class="text-[11px] font-semibold text-content-secondary uppercase tracking-[0.12em] mb-5">{section.title}</h4>
          <ul class="space-y-3">
            {section.links.map(({ href, label }) => (
              <li>
                <a href={href} class="text-[13px] hover:text-content transition-colors duration-300">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-16 pt-8 border-t border-border-subtle flex flex-col sm:flex-row justify-between items-center gap-4 text-[11px] text-content-disabled">
      <span>&copy; {year} ESOFT &middot; Universidad CENFOTEC</span>
      <span class="text-content-disabled/60">Hecho con la tecnologia que ensenamos.</span>
    </div>
  </div>
</footer>
