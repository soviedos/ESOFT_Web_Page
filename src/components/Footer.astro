---
const year = new Date().getFullYear();

const footerSections = [
  {
    title: 'Programas',
    links: [
      { href: '/programas/bachillerato-ingenieria-software', label: 'Bachillerato' },
      { href: '/programas/tecnico-ingenieria-software', label: 'Técnico en Software' },
      { href: '/programas/maestria-ingenieria-software-ia', label: 'Maestría en IA' },
      { href: '/programas', label: 'Ver todos' },
    ],
  },
  {
    title: 'ESOFT',
    links: [
      { href: '/escuela', label: 'La Escuela' },
      { href: '/calidad-academica', label: 'Calidad académica' },
      { href: '/industria-empleabilidad', label: 'Industria' },
      { href: '/historias', label: 'Testimonios' },
    ],
  },
  {
    title: 'Admisión',
    links: [
      { href: '/admision', label: 'Cómo aplicar' },
      { href: '/admision/requisitos', label: 'Requisitos' },
      { href: '/admision/financiamiento', label: 'Financiamiento' },
      { href: '/contacto', label: 'Contacto' },
    ],
  },
];
---

<footer class="relative bg-bg-primary border-t border-border-subtle text-content-muted overflow-hidden">
  <!-- Ambient top glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[1px] bg-gradient-to-r from-transparent via-brand/20 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6 py-16 md:py-20">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-16">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="text-xl font-bold text-content tracking-tight">ESOFT</a>
        <p class="mt-4 text-sm leading-relaxed max-w-xs">
          Formamos a los ingenieros de software que la industria necesita. IA, Cloud, Testing, UX y Arquitectura.
        </p>
      </div>

      {footerSections.map((section) => (
        <div>
          <h4 class="text-xs font-semibold text-content-secondary uppercase tracking-wider mb-5">{section.title}</h4>
          <ul class="space-y-3">
            {section.links.map(({ href, label }) => (
              <li>
                <a href={href} class="text-sm hover:text-content transition-colors duration-200">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-16 pt-8 border-t border-border-subtle flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-content-disabled">
      <span>&copy; {year} ESOFT · Universidad CENFOTEC</span>
      <span>Hecho con tecnología que enseñamos.</span>
    </div>
  </div>
</footer>
