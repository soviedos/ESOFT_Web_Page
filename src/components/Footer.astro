---
const year = new Date().getFullYear();

const footerSections = [
  {
    title: 'Programas',
    links: [
      { href: '/programas/bachillerato-ingenieria-software', label: 'Bachillerato' },
      { href: '/programas/tecnico-ingenieria-software', label: 'Técnico en Software' },
      { href: '/programas/maestria-ingenieria-software-ia', label: 'Maestría en IA' },
      { href: '/programas', label: 'Ver todos' },
    ],
  },
  {
    title: 'ESOFT',
    links: [
      { href: '/escuela', label: 'La Escuela' },
      { href: '/calidad-academica', label: 'Calidad académica' },
      { href: '/industria-empleabilidad', label: 'Industria' },
      { href: '/historias', label: 'Testimonios' },
    ],
  },
  {
    title: 'Admisión',
    links: [
      { href: '/admision', label: 'Cómo aplicar' },
      { href: '/admision/requisitos', label: 'Requisitos' },
      { href: '/admision/financiamiento', label: 'Financiamiento' },
      { href: '/contacto', label: 'Contacto' },
    ],
  },
];
---

<footer class="relative bg-bg-primary text-content-muted">
  <div class="section-divider"></div>

  <!-- Final CTA -->
  <div class="relative max-w-[600px] mx-auto px-6 md:px-8 lg:px-12 pt-20 md:pt-28 pb-16 md:pb-24 text-center">
    <div class="ambient-glow w-[300px] md:w-[500px] h-[180px] md:h-[300px] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" style="background: radial-gradient(ellipse at center, rgba(0,212,240,0.04) 0%, transparent 70%);"></div>
    <h2 class="relative headline-display text-[clamp(1.5rem,3.5vw,2.5rem)] mb-5">
      Tu carrera en software <span class="text-gradient-hero">empieza hoy.</span>
    </h2>
    <p class="relative text-content-secondary text-[15px] leading-[1.8] mb-9 max-w-[420px] mx-auto">
      Unite a la comunidad de ingenieros que ya estan transformando la industria tech en Costa Rica y el mundo.
    </p>
    <a href="/admision/solicitar-informacion" class="relative btn-primary inline-flex items-center bg-brand text-bg-primary font-semibold px-8 py-3.5 rounded-full text-[15px]">
      Solicitar informacion
    </a>
  </div>

  <div class="max-w-[1060px] mx-auto px-6 md:px-8 lg:px-12 py-12 md:py-16 lg:py-20">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-12">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="inline-block">
          <img src="/ESOFT_Software-Engineering-Negro.png" alt="ESOFT" class="w-[120px] h-auto invert" />
        </a>
        <p class="mt-4 text-[13px] leading-[1.7] max-w-[220px] text-content-secondary">
          Donde se forma el talento que construye el software del futuro.
        </p>
        <img src="/UCENFOTEC_LogoHorizontal-Negro.png" alt="Universidad CENFOTEC" class="mt-5 w-[90px] h-auto invert opacity-50" />
      </div>

      {footerSections.map((section) => (
        <div>
          <h4 class="text-[12px] font-bold text-content tracking-tight uppercase mb-5">{section.title}</h4>
          <ul class="space-y-3">
            {section.links.map(({ href, label }) => (
              <li>
                <a href={href} class="text-[13px] text-content-secondary hover:text-content transition-colors duration-300">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-14 pt-7 border-t border-border-subtle flex flex-col sm:flex-row justify-between items-center gap-4 text-[12px] text-content-disabled">
      <span>&copy; {year} ESOFT &middot; Universidad CENFOTEC</span>
    </div>
  </div>
</footer>
