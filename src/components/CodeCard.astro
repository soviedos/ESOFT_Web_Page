---
---
<div class="code-card" aria-hidden="true">
  <div class="code-card__bar">
    <span class="code-card__dot" style="background:#FF5F57"></span>
    <span class="code-card__dot" style="background:#FFBD2E"></span>
    <span class="code-card__dot" style="background:#28C840"></span>
    <span class="code-card__filename">model.ts</span>
  </div>
  <pre class="code-card__body"><code
><span class="t-comment">// ESOFT · IA en producción</span>
<span class="t-kw">import</span> <span class="t-brace">{</span> Pipeline <span class="t-brace">}</span> <span class="t-kw">from</span> <span class="t-str">'@esoft/ml'</span><span class="t-punct">;</span>

<span class="t-kw">const</span> <span class="t-var">model</span> <span class="t-op">=</span> <span class="t-kw">await</span> Pipeline<span class="t-punct">.</span><span class="t-fn">load</span><span class="t-brace">(</span><span class="t-brace">)</span><span class="t-punct">;</span>

<span class="t-kw">const</span> <span class="t-var">result</span> <span class="t-op">=</span> <span class="t-kw">await</span> <span class="t-var">model</span><span class="t-punct">.</span><span class="t-fn">predict</span><span class="t-brace">({</span>
  <span class="t-prop">input</span><span class="t-punct">:</span> userData<span class="t-punct">,</span>
  <span class="t-prop">threshold</span><span class="t-punct">:</span> <span class="t-num">0.82</span><span class="t-punct">,</span>
<span class="t-brace">})</span><span class="t-punct">;</span>

<span class="t-fn">console</span><span class="t-punct">.</span><span class="t-fn">log</span><span class="t-brace">(</span><span class="t-var">result</span><span class="t-punct">.</span><span class="t-prop">confidence</span><span class="t-brace">)</span><span class="t-punct">;</span>
<span class="t-comment">// → 0.94 ✓</span></code></pre>
</div>

<style>
.code-card {
  position: absolute;
  right: -20px;
  bottom: 8%;
  width: 290px;
  background: #ffffff;
  border: 1px solid rgba(27,58,140,0.12);
  border-radius: 14px;
  box-shadow:
    0 8px 32px rgba(15,23,42,0.10),
    0 2px 8px rgba(15,23,42,0.06);
  overflow: hidden;
  animation: card-float 6s ease-in-out infinite;
  font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', ui-monospace, monospace;
  z-index: 10;
}

@keyframes card-float {
  0%, 100% { transform: translateY(0px) rotate(-1deg); }
  50%       { transform: translateY(-10px) rotate(-1deg); }
}

.code-card__bar {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 14px 8px;
  background: #F1F5F9;
  border-bottom: 1px solid rgba(15,23,42,0.07);
}

.code-card__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  display: inline-block;
}

.code-card__filename {
  margin-left: 6px;
  font-size: 11px;
  color: #64748B;
  font-family: inherit;
}

.code-card__body {
  margin: 0;
  padding: 14px 16px;
  font-size: 11.5px;
  line-height: 1.75;
  overflow: hidden;
  background: #FAFBFF;
}

.code-card__body code { display: block; }

/* Syntax tokens */
.t-comment { color: #94A3B8; font-style: italic; }
.t-kw      { color: #164a98; font-weight: 600; }
.t-str     { color: #16A34A; }
.t-fn      { color: #c81f66; }
.t-var     { color: #0F172A; }
.t-prop    { color: #7C3AED; }
.t-num     { color: #0EA5E9; }
.t-op      { color: #64748B; }
.t-punct   { color: #94A3B8; }
.t-brace   { color: #475569; }

@media (max-width: 767px) {
  .code-card { display: none; }
}

@media (prefers-reduced-motion: reduce) {
  .code-card { animation: none; }
}
</style>
