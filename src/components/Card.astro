---
interface Props {
  title: string;
  description: string;
  href?: string;
  icon?: string;
}

const { title, description, href, icon } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'group block rounded-2xl border border-border-subtle bg-bg-secondary/50 p-6 transition-all duration-300 card-shine',
    href && 'hover:border-border-strong hover:bg-bg-secondary hover:shadow-lg hover:-translate-y-1 cursor-pointer',
  ]}
>
  {icon && <span class="text-2xl mb-3 block">{icon}</span>}
  <h3 class="text-[15px] font-semibold text-content mb-2 group-hover:text-brand transition-colors duration-300">{title}</h3>
  <p class="text-sm text-content-muted leading-relaxed">{description}</p>
  {href && (
    <span class="inline-flex items-center gap-1 text-xs text-content-disabled group-hover:text-brand mt-4 transition-colors duration-300">
      Explorar
      <svg class="w-3 h-3 transform group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </span>
  )}
</Tag>
