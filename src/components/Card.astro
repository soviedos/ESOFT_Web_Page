const svgPath = icon ? iconMap[icon] : null;
---

<Tag
  href={href}
  class:list={[
    'group block card-premium rounded-[20px] p-8 md:p-9',
    href && 'cursor-pointer',
  ]}
>
  {svgPath && (
    <div class="w-12 h-12 rounded-xl bg-brand-soft border border-border-brand flex items-center justify-center mb-6 group-hover:border-brand/30 transition-colors duration-500">
      <svg class="w-5 h-5 text-brand" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d={svgPath} />
      </svg>
    </div>
  )}
  {!svgPath && icon && <span class="text-2xl mb-5 block">{icon}</span>}
  <h3 class="text-[16px] font-bold text-content mb-2.5 tracking-tight">{title}</h3>
  <p class="text-[15px] text-content-secondary leading-[1.8]">{description}</p>
  {href && (
    <span class="inline-flex items-center gap-1.5 text-[14px] text-content-secondary group-hover:text-brand mt-6 transition-colors duration-500 font-medium">
      Explorar
      <svg class="w-3.5 h-3.5 transform group-hover:translate-x-1 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </span>
  )}
</Tag>
