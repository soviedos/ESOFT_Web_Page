---
import { requireAuth } from '../lib/auth'

const currentPath = Astro.url.pathname;
const sessionUser = await requireAuth(Astro.request)

// Menú "Programas" — dos grupos por modalidad
const programasGroups = [
  {
    label: 'Cuatrimestrales',
    href: '/programas/cuatrimestrales',
    items: [
      { href: '/programas/cuatrimestrales?nivel=tecnico',      label: 'Técnicos' },
      { href: '/programas/cuatrimestrales?nivel=bachillerato', label: 'Bachillerato' },
      { href: '/programas/cuatrimestrales?nivel=maestria',     label: 'Maestrías' },
    ],
  },
  {
    label: 'Microciclos',
    href: '/programas/microciclos',
    items: [
      { href: '/programas/microciclos/rutas',            label: 'Rutas de conocimiento' },
      { href: '/programas/microciclos/cursos-360',       label: 'Cursos 360' },
      { href: '/programas/microciclos/cursos-continuos', label: 'Cursos de aprendizaje continuo' },
    ],
  },
];

const escuelaItems = [
  { href: '/escuela',             label: 'La Escuela' },
  { href: '/escuela/director',    label: 'Dirección' },
  { href: '/escuela/docentes',    label: 'Docentes' },
  { href: '/escuela/metodologia', label: 'Metodología' },
];

const simpleLinks = [
  { href: '/admision',  label: 'Admisión' },
  { href: '/historias', label: 'Historias' },
];

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);

const triggerBase =
  'text-[14px] font-medium tracking-[0.01em] transition-colors duration-300';
---

<header id="site-header" class="fixed top-0 inset-x-0 z-50 transition-all duration-500 ease-out" role="banner">
  <nav class="max-w-[1200px] mx-auto px-5 md:px-12 flex items-center justify-between h-[var(--nav-height)]" aria-label="Navegación principal">
    <!-- Logo: dominant brand anchor -->
    <a href="/" class="flex items-center shrink-0 hover:opacity-85 transition-opacity duration-300 mr-10" aria-label="ESOFT - Ir al inicio">
      <img id="nav-logo" src="/ESOFT_Software-Engineering-Azul.png" alt="Logo de ESOFT, Escuela de Ingeniería de Software" class="w-[100px] md:w-[150px] h-auto transition-all duration-500" />
    </a>

    <button id="menu-toggle" class="md:hidden p-2 -mr-2 text-content-muted" aria-label="Abrir menú de navegación" aria-expanded="false" aria-controls="mobile-menu">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <ul class="hidden md:flex items-center gap-8">
      <!-- Programas ▾ (mega-menú: dos grupos) -->
      <li class="relative group">
        <button
          type="button"
          class:list={[
            triggerBase, 'inline-flex items-center gap-1',
            isActive('/programas') ? 'text-content' : 'text-content-secondary group-hover:text-content',
          ]}
          aria-haspopup="true"
          aria-expanded="false"
        >
          Programas
          <svg class="w-3 h-3 transition-transform duration-300 group-hover:rotate-180 group-focus-within:rotate-180" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="dropdown-panel left-0 w-[440px] grid grid-cols-2 gap-2 p-3">
          {programasGroups.map((group) => (
            <div class="p-2">
              <a href={group.href} class="block px-2 pb-2 text-[11px] font-bold uppercase tracking-widest text-brand hover:text-brand-hover transition-colors">
                {group.label}
              </a>
              <ul class="space-y-0.5">
                {group.items.map(({ href, label }) => (
                  <li>
                    <a href={href} class="block rounded-lg px-2 py-2 text-[13.5px] text-content-secondary hover:bg-brand-soft/40 hover:text-content transition-colors">
                      {label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </li>

      <!-- Escuela ▾ -->
      <li class="relative group">
        <button
          type="button"
          class:list={[
            triggerBase, 'inline-flex items-center gap-1',
            isActive('/escuela') ? 'text-content' : 'text-content-secondary group-hover:text-content',
          ]}
          aria-haspopup="true"
          aria-expanded="false"
        >
          Escuela
          <svg class="w-3 h-3 transition-transform duration-300 group-hover:rotate-180 group-focus-within:rotate-180" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="dropdown-panel left-0 w-[230px] p-3">
          <ul class="space-y-0.5">
            {escuelaItems.map(({ href, label }) => (
              <li>
                <a href={href} class="block rounded-lg px-2 py-2 text-[13.5px] text-content-secondary hover:bg-brand-soft/40 hover:text-content transition-colors">
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </li>

      {simpleLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              triggerBase,
              isActive(href) ? 'text-content' : 'text-content-secondary hover:text-content',
            ]}
          >
            {label}
          </a>
        </li>
      ))}

      {sessionUser ? (
        <li>
          <a
            href={sessionUser.rol === 'admin' ? '/admin' : '/docentes/perfil'}
            class="flex items-center gap-2 text-[13px] font-medium text-content-secondary hover:text-brand transition-colors duration-300"
            title={sessionUser.rol === 'admin' ? 'Panel admin' : 'Mi perfil'}
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="6" r="3" stroke="currentColor" stroke-width="1.3"/>
              <path d="M2 14c0-3.31 2.69-6 6-6s6 2.69 6 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
            {sessionUser.rol === 'admin' ? 'Admin' : 'Mi perfil'}
          </a>
        </li>
      ) : (
        <li>
          <a
            href="/login"
            class="flex items-center gap-1.5 text-[13px] font-medium text-content-secondary hover:text-brand transition-colors duration-300"
            aria-label="Acceso institucional"
          >
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
              <path d="M6 2H3a1 1 0 0 0-1 1v9a1 1 0 0 0 1 1h3M10 10l3-2.5L10 5M13 7.5H6"
                    stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Acceso
          </a>
        </li>
      )}
      <li class="ml-1">
        <a
          href="/admision/solicitar-informacion"
          class="btn-primary inline-flex items-center rounded-full bg-accent2 px-5 py-2 text-[14px] font-semibold text-white"
        >
          Solicitar información
        </a>
      </li>
    </ul>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-border-subtle px-5 pb-8 pt-3" style="background: rgba(248,249,252,0.97); backdrop-filter: blur(20px) saturate(1.4); -webkit-backdrop-filter: blur(20px) saturate(1.4);">
    <ul class="flex flex-col gap-0">
      <!-- Programas (acordeón nativo) -->
      <li>
        <details class="group border-b border-border-subtle">
          <summary class="flex items-center justify-between py-3.5 text-[16px] text-content-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
            Programas
            <svg class="w-4 h-4 transition-transform duration-300 group-open:rotate-180" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </summary>
          <div class="pb-3 pl-3">
            {programasGroups.map((group) => (
              <div class="mb-2">
                <a href={group.href} class="block py-2 text-[12px] font-bold uppercase tracking-widest text-brand">{group.label}</a>
                <ul>
                  {group.items.map(({ href, label }) => (
                    <li>
                      <a href={href} class="block py-2 pl-2 text-[15px] text-content-secondary">{label}</a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </details>
      </li>

      <!-- Escuela (acordeón nativo) -->
      <li>
        <details class="group border-b border-border-subtle">
          <summary class="flex items-center justify-between py-3.5 text-[16px] text-content-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
            Escuela
            <svg class="w-4 h-4 transition-transform duration-300 group-open:rotate-180" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </summary>
          <ul class="pb-3 pl-3">
            {escuelaItems.map(({ href, label }) => (
              <li>
                <a href={href} class="block py-2 pl-2 text-[15px] text-content-secondary">{label}</a>
              </li>
            ))}
          </ul>
        </details>
      </li>

      {simpleLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block py-3.5 text-[16px] border-b border-border-subtle transition-colors',
              isActive(href) ? 'text-content font-medium' : 'text-content-secondary',
            ]}
          >
            {label}
          </a>
        </li>
      ))}

      {sessionUser ? (
        <li>
          <a
            href={sessionUser.rol === 'admin' ? '/admin' : '/docentes/perfil'}
            class="block py-3.5 text-[16px] border-b border-border-subtle text-content-secondary transition-colors"
          >
            {sessionUser.rol === 'admin' ? '⊞ Panel admin' : '◎ Mi perfil'}
          </a>
        </li>
      ) : (
        <li>
          <a href="/login"
             class="block py-3.5 text-[16px] border-b border-border-subtle text-content-secondary transition-colors">
            → Acceso institucional
          </a>
        </li>
      )}
      <li class="pt-6">
        <a
          href="/admision/solicitar-informacion"
          class="block text-center rounded-full bg-accent2 px-5 py-3 text-[15px] font-semibold text-white"
        >
          Solicitar información
        </a>
      </li>
    </ul>
  </div>
</header>

<style>
  /* Panel de dropdown desktop — visible en hover y al enfocar con teclado (focus-within) */
  .dropdown-panel {
    position: absolute;
    top: calc(100% + 6px);
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    background: rgba(248, 249, 252, 0.98);
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    border: 1px solid var(--color-border-subtle, rgba(15, 23, 42, 0.08));
    border-radius: 16px;
    box-shadow: 0 18px 50px -12px rgba(22, 74, 152, 0.18);
    z-index: 60;
  }
  /* Puente invisible para que el cursor no pierda el hover entre el botón y el panel */
  .dropdown-panel::before {
    content: '';
    position: absolute;
    top: -8px;
    left: 0;
    right: 0;
    height: 8px;
  }
  .group:hover > .dropdown-panel,
  .group:focus-within > .dropdown-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
</style>

<script>
  (() => {
    const header = document.getElementById('site-header');
    if (!header) return;

    let ticking = false;

    const update = () => {
      const s = window.scrollY > 10;
      header.style.background = s ? 'rgba(248,249,252,0.88)' : 'transparent';
      header.style.backdropFilter = s ? 'blur(20px) saturate(1.4)' : 'none';
      header.style.setProperty('-webkit-backdrop-filter', header.style.backdropFilter);
      header.style.borderBottom = s ? '1px solid rgba(15,23,42,0.08)' : '1px solid transparent';
      ticking = false;
    };

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
    update();

    document.getElementById('menu-toggle')?.addEventListener('click', () => {
      const menu = document.getElementById('mobile-menu');
      const toggle = document.getElementById('menu-toggle');
      if (menu && toggle) {
        const isOpen = !menu.classList.contains('hidden');
        menu.classList.toggle('hidden');
        toggle.setAttribute('aria-expanded', String(!isOpen));
        toggle.setAttribute('aria-label', !isOpen ? 'Cerrar menú de navegación' : 'Abrir menú de navegación');
      }
    });

    // Close mobile menu on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const menu = document.getElementById('mobile-menu');
        const toggle = document.getElementById('menu-toggle');
        if (menu && toggle && !menu.classList.contains('hidden')) {
          menu.classList.add('hidden');
          toggle.setAttribute('aria-expanded', 'false');
          toggle.setAttribute('aria-label', 'Abrir menú de navegación');
          toggle.focus();
        }
      }
    });
  })();
</script>
