---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Inicio' },
  { href: '/programas', label: 'Carreras' },
  { href: '/rutas', label: 'Maestrías' },
  { href: '/escuela', label: 'Educación Continua' },
  { href: '/contacto', label: 'Contacto' },
];

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="fixed top-0 w-full z-50 bg-bg-primary/90 backdrop-blur-md border-b border-border-subtle">
  <nav class="max-w-6xl mx-auto px-6 flex items-center justify-between h-16">
    <a href="/" class="text-lg font-bold tracking-tight text-content">ESOFT</a>

    <!-- Mobile toggle -->
    <button id="menu-toggle" class="md:hidden p-2 -mr-2 text-content-muted touch-manipulation" aria-label="Menú">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-7">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm transition-colors',
              isActive(href) ? 'text-content font-medium' : 'text-content-muted hover:text-content',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border-subtle bg-bg-primary px-6 pb-6">
    <ul class="flex flex-col gap-1 pt-3">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block py-2.5 text-sm transition-colors touch-manipulation',
              isActive(href) ? 'text-content font-medium' : 'text-content-muted hover:text-content',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
