---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/programas', label: 'Programas' },
  { href: '/rutas', label: 'Rutas' },
  { href: '/escuela', label: 'Escuela' },
  { href: '/calidad-academica', label: 'Calidad' },
  { href: '/contacto', label: 'Contacto' },
];

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header id="site-header" class="fixed top-0 w-full z-50 transition-all duration-500">
  <nav class="max-w-6xl mx-auto px-6 flex items-center justify-between h-16">
    <a href="/" class="text-xl font-bold tracking-tight text-content">
      ESOFT
    </a>

    <!-- Mobile toggle -->
    <button id="menu-toggle" class="md:hidden p-2 -mr-2 text-content-muted touch-manipulation" aria-label="Menú">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-[13px] tracking-wide transition-colors duration-200',
              isActive(href) ? 'text-content font-medium' : 'text-content-muted hover:text-content',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/admision/solicitar-informacion"
          class="btn-primary inline-flex items-center rounded-full bg-brand px-5 py-2 text-[13px] font-medium text-white hover:bg-brand-hover transition-all duration-300"
        >
          Aplicar
        </a>
      </li>
    </ul>
  </nav>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden md:hidden bg-bg-primary/95 backdrop-blur-xl border-t border-border-subtle px-6 pb-6">
    <ul class="flex flex-col gap-1 pt-3">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block py-2.5 text-sm transition-colors touch-manipulation',
              isActive(href) ? 'text-content font-medium' : 'text-content-muted hover:text-content',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
      <li class="pt-3">
        <a
          href="/admision/solicitar-informacion"
          class="block text-center rounded-full bg-brand px-4 py-2.5 text-sm font-medium text-white hover:bg-brand-hover transition-colors touch-manipulation"
        >
          Aplicar
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  let lastScroll = 0;

  const updateHeader = () => {
    const scrollY = window.scrollY;
    if (scrollY > 40) {
      header?.classList.add('bg-bg-primary/80', 'backdrop-blur-xl', 'border-b', 'border-border-subtle');
    } else {
      header?.classList.remove('bg-bg-primary/80', 'backdrop-blur-xl', 'border-b', 'border-border-subtle');
    }
    lastScroll = scrollY;
  };

  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
