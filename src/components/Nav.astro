---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/programas', label: 'Programas' },
  { href: '/rutas', label: 'Rutas' },
  { href: '/escuela', label: 'Escuela' },
  { href: '/calidad-academica', label: 'Calidad' },
  { href: '/contacto', label: 'Contacto' },
];

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header id="site-header" class="fixed top-0 inset-x-0 z-50 transition-all duration-500 ease-out">
  <nav class="max-w-[980px] mx-auto px-6 lg:px-4 flex items-center justify-between h-11">
    <a href="/" class="text-[15px] font-semibold text-content/90 hover:text-content transition-colors duration-300">
      ESOFT
    </a>

    <button id="menu-toggle" class="md:hidden p-2 -mr-2 text-content-muted" aria-label="Menu">
      <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <ul class="hidden md:flex items-center gap-6">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-[12px] transition-colors duration-300',
              isActive(href)
                ? 'text-content/90'
                : 'text-content-muted hover:text-content/90',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/admision/solicitar-informacion"
          class="btn-primary inline-flex items-center rounded-full bg-brand px-4 py-[5px] text-[12px] font-medium text-white"
        >
          Aplicar
        </a>
      </li>
    </ul>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-border-subtle px-6 pb-8 pt-4" style="background: rgba(0,0,0,0.96); backdrop-filter: blur(40px) saturate(1.4); -webkit-backdrop-filter: blur(40px) saturate(1.4);">
    <ul class="flex flex-col gap-0">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block py-3 text-[15px] border-b border-border-subtle transition-colors',
              isActive(href) ? 'text-content' : 'text-content-muted',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
      <li class="pt-5">
        <a
          href="/admision/solicitar-informacion"
          class="block text-center rounded-full bg-brand px-4 py-2.5 text-sm font-medium text-white"
        >
          Aplicar
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;

  const update = () => {
    const s = window.scrollY > 10;
    header.style.background = s ? 'rgba(0,0,0,0.72)' : 'rgba(0,0,0,0.5)';
    header.style.backdropFilter = s ? 'blur(40px) saturate(1.8)' : 'blur(20px) saturate(1.2)';
    (header.style as any).webkitBackdropFilter = header.style.backdropFilter;
  };

  window.addEventListener('scroll', update, { passive: true });
  update();

  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
