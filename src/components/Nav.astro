---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/programas', label: 'Programas' },
  { href: '/rutas', label: 'Rutas' },
  { href: '/escuela', label: 'Escuela' },
  { href: '/calidad-academica', label: 'Calidad' },
  { href: '/contacto', label: 'Contacto' },
];

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header id="site-header" class="fixed top-0 inset-x-0 z-50 transition-all duration-500 ease-out">
  <nav class="max-w-[1200px] mx-auto px-5 md:px-12 flex items-center justify-between h-[72px]">
    <!-- Logo: dominant brand anchor -->
    <a href="/" class="flex items-center shrink-0 hover:opacity-85 transition-opacity duration-300 mr-10">
      <img id="nav-logo" src="/ESOFT_Software-Engineering-Negro.png" alt="ESOFT" class="w-[100px] md:w-[150px] h-auto invert transition-all duration-500" />
    </a>

    <button id="menu-toggle" class="md:hidden p-2 -mr-2 text-content-muted" aria-label="Menu">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <ul class="hidden md:flex items-center gap-9">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-[13px] font-normal tracking-[0.01em] transition-colors duration-300',
              isActive(href)
                ? 'text-content'
                : 'text-content-secondary hover:text-content',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
      <li class="ml-2">
        <a
          href="/admision/solicitar-informacion"
          class="btn-primary inline-flex items-center rounded-full bg-brand px-5 py-2 text-[13px] font-semibold text-bg-primary"
        >
          Matricular ahora
        </a>
      </li>
    </ul>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-border-subtle px-5 pb-8 pt-5" style="background: rgba(7,7,10,0.97); backdrop-filter: blur(40px) saturate(1.6); -webkit-backdrop-filter: blur(40px) saturate(1.6);">
    <ul class="flex flex-col gap-0">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block py-3.5 text-[16px] border-b border-border-subtle transition-colors',
              isActive(href) ? 'text-content font-medium' : 'text-content-secondary',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
      <li class="pt-6">
        <a
          href="/admision/solicitar-informacion"
          class="block text-center rounded-full bg-brand px-5 py-3 text-[15px] font-semibold text-bg-primary"
        >
          Matricular ahora
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;

  const update = () => {
    const s = window.scrollY > 10;
    header.style.background = s ? 'rgba(7,7,10,0.85)' : 'transparent';
    header.style.backdropFilter = s ? 'blur(40px) saturate(1.6)' : 'none';
    (header.style as any).webkitBackdropFilter = header.style.backdropFilter;
    header.style.borderBottom = s ? '1px solid rgba(255,255,255,0.04)' : '1px solid transparent';
  };

  window.addEventListener('scroll', update, { passive: true });
  update();

  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
