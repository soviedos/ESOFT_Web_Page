---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/programas', label: 'Programas' },
  { href: '/rutas', label: 'Rutas' },
  { href: '/escuela', label: 'Escuela' },
  { href: '/calidad-academica', label: 'Calidad' },
  { href: '/contacto', label: 'Contacto' },
];

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header id="site-header" class="fixed top-0 inset-x-0 z-50 transition-all duration-500 ease-out" role="banner">
  <nav class="max-w-[1200px] mx-auto px-5 md:px-12 flex items-center justify-between h-[72px]" aria-label="Navegación principal">
    <!-- Logo: dominant brand anchor -->
    <a href="/" class="flex items-center shrink-0 hover:opacity-85 transition-opacity duration-300 mr-10" aria-label="ESOFT - Ir al inicio">
      <img id="nav-logo" src="/ESOFT_Software-Engineering-Negro.png" alt="Logo de ESOFT, Escuela de Ingeniería de Software" class="w-[100px] md:w-[150px] h-auto transition-all duration-500" />
    </a>

    <button id="menu-toggle" class="md:hidden p-2 -mr-2 text-content-muted" aria-label="Abrir menú de navegación" aria-expanded="false" aria-controls="mobile-menu">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <ul class="hidden md:flex items-center gap-9">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-[14px] font-medium tracking-[0.01em] transition-colors duration-300',
              isActive(href)
                ? 'text-content'
                : 'text-content-secondary hover:text-content',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
      <li class="ml-2">
        <a
          href="/admision/solicitar-informacion"
          class="btn-primary inline-flex items-center rounded-full bg-brand px-5 py-2 text-[14px] font-semibold text-bg-primary"
        >
          Matricular ahora
        </a>
      </li>
    </ul>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-border-subtle px-5 pb-8 pt-5" style="background: rgba(248,249,252,0.97); backdrop-filter: blur(20px) saturate(1.4); -webkit-backdrop-filter: blur(20px) saturate(1.4);">
    <ul class="flex flex-col gap-0">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block py-3.5 text-[16px] border-b border-border-subtle transition-colors',
              isActive(href) ? 'text-content font-medium' : 'text-content-secondary',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
      <li class="pt-6">
        <a
          href="/admision/solicitar-informacion"
          class="block text-center rounded-full bg-brand px-5 py-3 text-[15px] font-semibold text-bg-primary"
        >
          Matricular ahora
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;
  let ticking = false;

  const update = () => {
    const s = window.scrollY > 10;
    header.style.background = s ? 'rgba(248,249,252,0.88)' : 'transparent';
    header.style.backdropFilter = s ? 'blur(20px) saturate(1.4)' : 'none';
    (header.style as any).webkitBackdropFilter = header.style.backdropFilter;
    header.style.borderBottom = s ? '1px solid rgba(15,23,42,0.08)' : '1px solid transparent';
    ticking = false;
  };

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(update);
      ticking = true;
    }
  }, { passive: true });
  update();

  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    const menu = document.getElementById('mobile-menu');
    const toggle = document.getElementById('menu-toggle');
    if (menu && toggle) {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', String(!isOpen));
      toggle.setAttribute('aria-label', !isOpen ? 'Cerrar menú de navegación' : 'Abrir menú de navegación');
    }
  });

  // Close mobile menu on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const menu = document.getElementById('mobile-menu');
      const toggle = document.getElementById('menu-toggle');
      if (menu && toggle && !menu.classList.contains('hidden')) {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Abrir menú de navegación');
        toggle.focus();
      }
    }
  });
</script>
