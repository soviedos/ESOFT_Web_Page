---
interface Props {
  items: { label: string; href?: string }[]
}
const { items } = Astro.props
---

<nav class="text-[13px] text-content-muted mb-8" aria-label="Ruta de navegación">
  {items.map((item, i) => (
    <>
      {i > 0 && <span class="mx-2">·</span>}
      {item.href
        ? <a href={item.href} class="hover:text-content transition-colors">{item.label}</a>
        : <span class="text-content">{item.label}</span>
      }
    </>
  ))}
</nav>
