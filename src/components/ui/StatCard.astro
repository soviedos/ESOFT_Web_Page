---
interface Props {
  valor: string
  label: string
  colorValor?: 'content' | 'brand' | 'accent2'
  size?: 'lg' | 'xl'
}
const { valor, label, colorValor = 'content', size = 'xl' } = Astro.props

const colorClass = {
  content: 'text-content',
  brand:   'text-brand',
  accent2: 'text-accent2',
}[colorValor]

const sizeClass = size === 'xl' ? 'text-[2.5rem]' : 'text-[2.25rem]'
---

<div class="card-stat p-6 text-center">
  <p class:list={['font-extrabold leading-tight', colorClass, sizeClass]}>{valor}</p>
  <p class="text-[14px] text-content-secondary mt-1">{label}</p>
</div>
