---
---
<div class="terminal" role="img" aria-label="Terminal mostrando flujo de trabajo de un ingeniero de software">
  <div class="terminal__bar">
    <span class="terminal__dot" style="background:#164A98"></span>
    <span class="terminal__dot" style="background:#006AEA"></span>
    <span class="terminal__dot" style="background:#9CC8FF"></span>
    <span class="terminal__title">bash — esoft-project</span>
  </div>
  <div class="terminal__body" id="terminal-body">
    <div class="terminal__line">
      <span class="terminal__prompt">~/esoft-project</span>
      <span class="terminal__cmd" id="t-line-0"></span>
      <span class="terminal__cursor" id="t-cursor-0">▋</span>
    </div>
  </div>
</div>

<script>
(function () {
  const body = document.getElementById('terminal-body');
  if (!body) return;

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    body.innerHTML = `
      <div class="terminal__line"><span class="terminal__prompt">~/esoft-project</span><span class="terminal__out terminal__cmd">git pull origin main</span></div>
      <div class="terminal__line terminal__out t-muted">Already up to date.</div>
      <div class="terminal__line"><span class="terminal__prompt">~/esoft-project</span><span class="terminal__out terminal__cmd">npm test</span></div>
      <div class="terminal__line terminal__out t-green">✓ 312 tests passed in 1.4s</div>
      <div class="terminal__line"><span class="terminal__prompt">~/esoft-project</span><span class="terminal__out terminal__cmd">kubectl rollout status deploy/api</span></div>
      <div class="terminal__line terminal__out t-green">✓ 3/3 pods ready — deploy successful</div>
    `;
    return;
  }

  const steps = [
    { cmd: 'git pull origin main',             output: 'Already up to date.',                         cls: 't-muted'  },
    { cmd: 'git checkout -b feat/ai-endpoint', output: 'Switched to branch "feat/ai-endpoint"',       cls: 't-muted'  },
    { cmd: 'npm install',                       output: '✓ 847 packages — 0 vulnerabilities',          cls: 't-green'  },
    { cmd: 'npm run lint',                      output: '✓ ESLint: 0 errors, 0 warnings',              cls: 't-green'  },
    { cmd: 'npm test',                          output: '✓ 312 tests passed in 1.4s',                  cls: 't-green'  },
    { cmd: 'git add -p',                        output: '✓ Staged 6 files',                            cls: 't-muted'  },
    { cmd: 'git commit -m "feat: AI endpoint"', output: '[feat/ai-endpoint c9f2a11] feat: AI endpoint',cls: 't-muted'  },
    { cmd: 'git push origin feat/ai-endpoint',  output: '✓ PR #84 opened → review requested',         cls: 't-cyan'   },
    { cmd: 'docker build -t app:2.5.0 .',       output: '✓ Image built → registry.esoft.dev',         cls: 't-cyan'   },
    { cmd: 'kubectl rollout status deploy/api', output: '✓ 3/3 pods ready — deploy successful',       cls: 't-green'  },
    { cmd: 'curl /api/health | jq .status',     output: '"ok"  ← live in production ✓',               cls: 't-live'   },
  ];

  let stepIdx = 0;

  const typeCmd = (cmdEl: HTMLElement, text: string, done: () => void) => {
    let i = 0;
    const iv = setInterval(() => {
      cmdEl.textContent += text[i++];
      if (i >= text.length) { clearInterval(iv); done(); }
    }, 38);
  };

  const addOutput = (text: string, cls: string) => {
    const line = document.createElement('div');
    line.className = 'terminal__line terminal__out' + (cls ? ` ${cls}` : '');
    line.textContent = text;
    body.appendChild(line);
    body.scrollTop = body.scrollHeight;
  };

  const addPromptLine = (): { cmdEl: HTMLElement; cursorEl: HTMLElement } => {
    const line = document.createElement('div');
    line.className = 'terminal__line';
    const prompt = document.createElement('span');
    prompt.className = 'terminal__prompt';
    prompt.textContent = '~/esoft-project';
    const cmd = document.createElement('span');
    cmd.className = 'terminal__cmd';
    const cursor = document.createElement('span');
    cursor.className = 'terminal__cursor';
    cursor.textContent = '▋';
    line.appendChild(prompt);
    line.appendChild(cmd);
    line.appendChild(cursor);
    body.appendChild(line);
    body.scrollTop = body.scrollHeight;
    return { cmdEl: cmd, cursorEl: cursor };
  };

  const runStep = () => {
    const s = steps[stepIdx];
    const existingCmd    = document.getElementById('t-line-0') as HTMLElement | null;
    const existingCursor = document.getElementById('t-cursor-0') as HTMLElement | null;

    const { cmdEl, cursorEl } = (stepIdx === 0 && existingCmd && existingCursor)
      ? { cmdEl: existingCmd, cursorEl: existingCursor }
      : addPromptLine();

    typeCmd(cmdEl, s.cmd, () => {
      cursorEl.remove();
      setTimeout(() => {
        addOutput(s.output, s.cls ?? '');
        stepIdx++;
        if (stepIdx >= steps.length) {
          setTimeout(reset, 3000);
        } else {
          setTimeout(runStep, 600);
        }
      }, 300);
    });
  };

  const reset = () => {
    body.style.transition = 'opacity 0.5s ease';
    body.style.opacity = '0';
    setTimeout(() => {
      body.innerHTML = '<div class="terminal__line"><span class="terminal__prompt">~/esoft-project</span><span class="terminal__cmd" id="t-line-0"></span><span class="terminal__cursor" id="t-cursor-0">▋</span></div>';
      stepIdx = 0;
      body.style.transition = 'none';
      body.style.opacity = '0';
      void body.offsetHeight; // force reflow so fade-in works
      body.style.transition = 'opacity 0.5s ease';
      body.style.opacity = '1';
      setTimeout(runStep, 600);
    }, 550);
  };

  const observer = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting) {
      observer.disconnect();
      setTimeout(runStep, 600);
    }
  }, { threshold: 0.3 });

  const terminal = document.querySelector('.terminal');
  if (!terminal) return;
  observer.observe(terminal);
})();
</script>

<style is:global>
.terminal {
  background: #0F172A;
  border-radius: 14px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow:
    0 20px 48px rgba(15,23,42,0.18),
    0 4px 12px rgba(15,23,42,0.10);
  font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', ui-monospace, monospace;
  max-width: 480px;
  width: 100%;
}

.terminal__bar {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 11px 14px;
  background: #1E293B;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.terminal__dot {
  width: 11px;
  height: 11px;
  border-radius: 50%;
}

.terminal__title {
  margin-left: 8px;
  font-size: 11px;
  color: #64748B;
  font-family: inherit;
}

.terminal__body {
  padding: 16px 18px 18px;
  min-height: 200px;
  max-height: 260px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 4px;
  opacity: 1;
}

.terminal__line {
  display: flex;
  align-items: baseline;
  gap: 8px;
  font-size: 12.5px;
  line-height: 1.6;
  white-space: nowrap;
}

.terminal__prompt {
  color: #9CC8FF;
  font-weight: 600;
  flex-shrink: 0;
}

.terminal__prompt::after {
  content: ' $';
  color: #9CC8FF;
  font-weight: 400;
}

.terminal__cmd {
  color: #E2E8F0;
}

.terminal__cursor {
  color: #9CC8FF;
  animation: blink 1s step-end infinite;
  margin-left: 1px;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0; }
}

.terminal__out {
  color: #64748B;
  padding-left: 4px;
}

/* Salidas de éxito/info — azul claro de marca (sin verde neón ni cian) */
.t-green { color: #9CC8FF; }
.t-cyan  { color: #9CC8FF; }
.t-muted { color: #475569; }
/* Remate final — único uso de magenta en la terminal */
.t-live  { color: #C81F66; font-weight: 600; }
</style>
