---
import Base from '../../layouts/Base.astro'
import Breadcrumb from '../ui/Breadcrumb.astro'
import CTAButton from '../ui/CTAButton.astro'
import TechGrid from './TechGrid.astro'

interface ProgresionItem {
  label: string
  href: string
  descripcion: string
}

interface Props {
  ruta: {
    titulo: string
    descripcion: string
    objetivoProfesional: string
    nivelEntrada: string
    progresion: ProgresionItem[]
    tecnologias: string[]
  }
}

const { ruta } = Astro.props
---

<Base title={ruta.titulo} description={ruta.descripcion}>
  <section class="max-w-6xl mx-auto px-6 py-12 md:py-20">
    <Breadcrumb items={[
      { label: 'Rutas', href: '/rutas' },
      { label: ruta.titulo.replace('Ruta: ', '') },
    ]} />

    <div class="max-w-3xl">
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-6">{ruta.titulo}</h1>
      <p class="text-content-muted mb-6 md:mb-8 text-base md:text-lg">{ruta.descripcion}</p>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Objetivo profesional</h2>
      <p class="text-content-muted mb-8">{ruta.objetivoProfesional}</p>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Nivel de entrada</h2>
      <p class="text-content-muted mb-8">{ruta.nivelEntrada}</p>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Progresión</h2>
      <ol class="space-y-4 mb-8">
        {ruta.progresion.map((item, i) => (
          <li class="flex gap-4 items-start">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-bg-elevated text-brand font-bold flex items-center justify-center text-sm">
              {i + 1}
            </span>
            <div>
              <a href={item.href} class="font-semibold text-brand hover:underline">{item.label}</a>
              <p class="text-sm text-content-muted">{item.descripcion}</p>
            </div>
          </li>
        ))}
      </ol>

      <TechGrid tecnologias={ruta.tecnologias} />

      <CTAButton
        href="/admision/solicitar-informacion"
        texto="Empezar esta ruta"
        clase="inline-block px-6 py-3 text-sm"
      />
    </div>
  </section>
</Base>
