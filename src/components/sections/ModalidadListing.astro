---
// Landing reutilizable para las sub-modalidades de microciclos.
// El texto explicativo (`intro`) llega desde bloques_contenido (con fallback).
import RichText from '../RichText.astro'

interface Item {
  slug: string
  titulo: string
  descripcion: string | null
  meta?: string | null
}
interface Props {
  breadcrumbLabel: string
  eyebrow: string
  titulo: string
  intro: string
  items: Item[]
  vacioTexto?: string
}
const {
  breadcrumbLabel, eyebrow, titulo, intro, items,
  vacioTexto = 'No hay programas disponibles en esta modalidad por ahora.',
} = Astro.props as Props
---

<section class="relative py-12 md:py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <nav class="text-[13px] text-content-muted mb-5" aria-label="Ruta de navegación">
      <a href="/programas" class="hover:text-content transition-colors">Programas</a>
      <span class="mx-2">/</span>
      <a href="/programas/microciclos" class="hover:text-content transition-colors">Microciclos</a>
      <span class="mx-2">/</span>
      <span class="text-content-secondary">{breadcrumbLabel}</span>
    </nav>
    <span class="text-[11px] font-bold uppercase tracking-widest text-brand">{eyebrow}</span>
    <h1 class="text-3xl md:text-5xl font-bold tracking-tight mt-2 mb-4">{titulo}</h1>
    <RichText texto={intro} class="max-w-3xl text-content-secondary text-base md:text-lg leading-[1.8]" />
  </div>
</section>

<section class="max-w-6xl mx-auto px-6 pb-20 md:pb-28">
  {items.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {items.map(p => (
        <a href={`/programas/${p.slug}`} class="card-premium rounded-[20px] p-6 flex flex-col gap-3 no-underline">
          {p.meta && <span class="text-[11px] font-bold uppercase tracking-widest text-accent2">{p.meta}</span>}
          <h3 class="text-[15.5px] font-bold text-content leading-snug">{p.titulo}</h3>
          <p class="text-[13.5px] text-content-secondary leading-[1.75] flex-1">{p.descripcion}</p>
          <span class="link-arrow mt-1 text-[13.5px]">Ver programa <svg viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        </a>
      ))}
    </div>
  ) : (
    <p class="text-content-muted text-[15px] py-12 text-center">{vacioTexto}</p>
  )}
</section>
