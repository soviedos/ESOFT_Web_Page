---
// Chat del asesor de admisiones. Consume POST /api/asesor con JS vanilla.
const SALUDO = 'Hola, contame qué te interesa aprender y te ayudo a encontrar tu ruta de conocimiento.'
---

<div class="flex flex-col h-[calc(100vh-var(--nav-height)-2px)] max-w-[760px] mx-auto w-full px-4 md:px-6">

  <!-- Encabezado -->
  <header class="pt-8 pb-5 text-center shrink-0">
    <span class="inline-flex items-center gap-2 text-[11px] font-bold uppercase tracking-widest text-brand">
      <span class="w-1.5 h-1.5 rounded-full bg-accent2" aria-hidden="true"></span>
      Asesor IA · ESOFT
    </span>
    <h1 class="headline-display text-[clamp(1.5rem,3vw,2.25rem)] mt-2">Encontrá tu ruta de conocimiento</h1>
    <p class="text-content-secondary text-[14px] mt-2 max-w-[460px] mx-auto">
      Te oriento sobre los programas de ESOFT. Las recomendaciones son una guía: la decisión es tuya.
    </p>
  </header>

  <!-- Lista de mensajes -->
  <div id="chat-mensajes"
       class="flex-1 overflow-y-auto py-4 space-y-4"
       role="log" aria-live="polite" aria-label="Conversación con el asesor">
    <!-- Mensaje inicial del asesor -->
    <div class="flex justify-start">
      <div class="msg-asesor max-w-[85%] rounded-2xl rounded-tl-md bg-bg-secondary border border-border-subtle px-4 py-3 text-[14.5px] leading-[1.65] text-content">
        {SALUDO}
      </div>
    </div>
  </div>

  <!-- Entrada -->
  <div class="shrink-0 pb-5 pt-3 border-t border-border-subtle bg-bg-primary">
    <form id="chat-form" class="flex items-end gap-2.5">
      <label for="chat-input" class="sr-only">Escribí tu consulta para el asesor</label>
      <textarea id="chat-input" name="mensaje" rows="1" required
                placeholder="Ej.: quiero aprender desarrollo web…"
                class="flex-1 resize-none rounded-2xl border border-border-default bg-bg-tertiary text-content px-4 py-3 text-[14.5px] leading-[1.5] max-h-[140px] focus:outline-none focus:ring-2 focus:ring-brand transition-colors"></textarea>
      <button id="chat-enviar" type="submit" aria-label="Enviar mensaje"
              class="btn-primary shrink-0 inline-flex items-center justify-center rounded-full bg-accent2 text-white w-11 h-11 hover:bg-accent-hover transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M3 10L17 3l-4 14-3-6-7-1z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
        </svg>
      </button>
    </form>
    <p class="text-[11px] text-content-muted mt-2 text-center">
      Enter envía · Shift+Enter agrega un salto de línea
    </p>
  </div>
</div>

<script>
  (() => {
    const form = document.getElementById('chat-form') as HTMLFormElement
    const input = document.getElementById('chat-input') as HTMLTextAreaElement
    const enviarBtn = document.getElementById('chat-enviar') as HTMLButtonElement
    const lista = document.getElementById('chat-mensajes') as HTMLElement
    if (!form || !input || !lista) return

    type Turno = { rol: 'prospecto' | 'asesor'; texto: string }
    const historial: Turno[] = []
    let enviando = false

    const scrollAlFondo = () => { lista.scrollTop = lista.scrollHeight }

    // Auto-resize del textarea.
    const ajustarAltura = () => {
      input.style.height = 'auto'
      input.style.height = Math.min(input.scrollHeight, 140) + 'px'
    }
    input.addEventListener('input', ajustarAltura)

    function fila(lado: 'prospecto' | 'asesor'): HTMLDivElement {
      const wrap = document.createElement('div')
      wrap.className = 'flex ' + (lado === 'prospecto' ? 'justify-end' : 'justify-start')
      return wrap
    }

    function burbujaProspecto(texto: string) {
      const wrap = fila('prospecto')
      const b = document.createElement('div')
      b.className = 'max-w-[85%] rounded-2xl rounded-tr-md bg-brand text-white px-4 py-3 text-[14.5px] leading-[1.65] whitespace-pre-wrap'
      b.textContent = texto
      wrap.appendChild(b)
      lista.appendChild(wrap)
      scrollAlFondo()
    }

    function burbujaAsesor(texto: string, programas: { slug: string; titulo: string; url: string }[] = [], tono: 'normal' | 'aviso' = 'normal') {
      const wrap = fila('asesor')
      const cont = document.createElement('div')
      cont.className = 'max-w-[85%] space-y-3'

      const b = document.createElement('div')
      b.className = 'rounded-2xl rounded-tl-md border px-4 py-3 text-[14.5px] leading-[1.65] whitespace-pre-wrap '
        + (tono === 'aviso'
            ? 'bg-accent2-soft border-accent2/30 text-content'
            : 'bg-bg-secondary border-border-subtle text-content')
      b.textContent = texto
      cont.appendChild(b)

      if (programas.length > 0) {
        const cards = document.createElement('div')
        cards.className = 'grid gap-2'
        for (const p of programas) {
          const a = document.createElement('a')
          a.href = p.url
          a.className = 'group flex items-center justify-between gap-3 rounded-xl border border-border-subtle bg-bg-secondary px-4 py-2.5 no-underline hover:border-brand transition-colors'
          const t = document.createElement('span')
          t.className = 'text-[13.5px] font-semibold text-content group-hover:text-brand transition-colors'
          t.textContent = p.titulo
          const arrow = document.createElement('span')
          arrow.className = 'text-brand text-[13px] shrink-0'
          arrow.textContent = 'Ver programa →'
          a.appendChild(t); a.appendChild(arrow)
          cards.appendChild(a)
        }
        cont.appendChild(cards)
      }

      wrap.appendChild(cont)
      lista.appendChild(wrap)
      scrollAlFondo()
      return wrap
    }

    function mostrarEscribiendo(): HTMLElement {
      const wrap = fila('asesor')
      wrap.dataset.typing = '1'
      const b = document.createElement('div')
      b.className = 'rounded-2xl rounded-tl-md bg-bg-secondary border border-border-subtle px-4 py-3'
      b.setAttribute('aria-label', 'El asesor está escribiendo')
      b.innerHTML = '<span class="typing-dots flex gap-1"><i></i><i></i><i></i></span>'
      wrap.appendChild(b)
      lista.appendChild(wrap)
      scrollAlFondo()
      return wrap
    }

    function bloquear(v: boolean) {
      enviando = v
      enviarBtn.disabled = v
      input.disabled = v
    }

    async function enviar(mensaje: string) {
      bloquear(true)
      const typing = mostrarEscribiendo()

      try {
        const res = await fetch('/api/asesor', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ mensaje, historial }),
        })

        typing.remove()

        if (res.status === 429) {
          burbujaAsesor('Estás enviando consultas muy seguido. Esperá unos segundos y volvé a intentar.', [], 'aviso')
          bloquear(false); input.focus()
          return
        }

        if (!res.ok) {
          // 503 u otros: mensaje amable con derivación.
          let msg = 'El asesor no está disponible ahora. Probá de nuevo en un momento o dejanos tus datos en Solicitar información.'
          try { const j = await res.json(); if (j?.error) msg = j.error } catch {}
          const wrap = burbujaAsesor(msg, [], 'aviso')
          const a = document.createElement('a')
          a.href = '/admision/solicitar-informacion'
          a.className = 'inline-block mt-1 text-[13px] font-semibold text-accent2 hover:text-accent-hover'
          a.textContent = 'Solicitar información →'
          wrap.querySelector('div')!.appendChild(a)
          bloquear(false); input.focus()
          return
        }

        const data = await res.json()
        const respuesta = typeof data?.respuesta === 'string' ? data.respuesta : 'No pude generar una respuesta.'
        const programas = Array.isArray(data?.programas) ? data.programas : []
        burbujaAsesor(respuesta, programas)

        historial.push({ rol: 'prospecto', texto: mensaje })
        historial.push({ rol: 'asesor', texto: respuesta })
        bloquear(false); input.focus()
      } catch {
        // Error de red: permitir reintentar.
        typing.remove()
        const wrap = burbujaAsesor('Hubo un problema de conexión.', [], 'aviso')
        const btn = document.createElement('button')
        btn.type = 'button'
        btn.className = 'inline-block mt-1 text-[13px] font-semibold text-brand hover:text-brand-hover'
        btn.textContent = '↻ Reintentar'
        btn.addEventListener('click', () => { wrap.remove(); enviar(mensaje) })
        wrap.querySelector('div')!.appendChild(btn)
        bloquear(false); input.focus()
      }
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault()
      if (enviando) return
      const mensaje = input.value.trim()
      if (!mensaje) return
      burbujaProspecto(mensaje)
      input.value = ''
      ajustarAltura()
      enviar(mensaje)
    })

    // Enter envía; Shift+Enter inserta salto de línea.
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault()
        form.requestSubmit()
      }
    })

    input.focus()
  })()
</script>

<style>
  .typing-dots i {
    width: 6px; height: 6px; border-radius: 9999px;
    background: var(--color-content-muted);
    display: inline-block;
    animation: typing-bounce 1.2s infinite ease-in-out both;
  }
  .typing-dots i:nth-child(2) { animation-delay: 0.15s; }
  .typing-dots i:nth-child(3) { animation-delay: 0.3s; }
  @keyframes typing-bounce {
    0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
    40% { transform: translateY(-4px); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .typing-dots i { animation: none; opacity: 0.6; }
  }
</style>
