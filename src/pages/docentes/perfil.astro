---
import Base from '../../layouts/Base.astro'
import { requireAuth } from '../../lib/auth'
import { db } from '../../db/client'
import { docentes } from '../../db/schema'
import { eq } from 'drizzle-orm'

const user = await requireAuth(Astro.request)
if (!user) return Astro.redirect('/login?next=/docentes/perfil')

// Admin sin perfil docente → redirigir al panel admin
const docente = await db.query.docentes.findFirst({ where: eq(docentes.userId, user.id) })
if (!docente && user.rol === 'admin') return Astro.redirect('/admin')
if (!docente) {
  return new Response(
    '<p style="font-family:sans-serif;padding:2rem">Tu cuenta no tiene un perfil de docente asignado. Contactá al administrador.</p>',
    { status: 403, headers: { 'Content-Type': 'text/html' } }
  )
}

let error   = ''
const updated = Astro.url.searchParams.get('updated')

if (Astro.request.method === 'POST') {
  const form  = await Astro.request.formData()

  const nombre        = (form.get('nombre')        as string).trim()
  const titulo        = (form.get('titulo')        as string).trim()
  const bio           = (form.get('bio')           as string)?.trim() || null
  const fotoUrl       = (form.get('fotoUrl')       as string)?.trim() || null
  const linkedin      = (form.get('linkedin')      as string)?.trim() || null
  const especialidades = (form.get('especialidades') as string)
    ?.split(',').map(e => e.trim()).filter(Boolean) ?? []

  if (!nombre || !titulo) {
    error = 'Nombre y título son obligatorios.'
  } else if (fotoUrl && !fotoUrl.startsWith('https://')) {
    error = 'La URL de la foto debe comenzar con https://'
  } else if (linkedin && !linkedin.startsWith('https://')) {
    error = 'La URL de LinkedIn debe comenzar con https://'
  } else {
    try {
      await db.update(docentes)
        .set({ nombre, titulo, bio, fotoUrl, linkedin, especialidades, updatedAt: new Date() })
        .where(eq(docentes.id, docente.id))
      return Astro.redirect('/docentes/perfil?updated=1')
    } catch {
      error = 'Error al guardar. Intentá de nuevo.'
    }
  }
}

const espec = (docente.especialidades as string[] ?? []).join(', ')
---

<Base
  title="Mi perfil docente"
  description="Editá tu perfil de docente en ESOFT."
>
  <section class="max-w-3xl mx-auto px-6 py-12 md:py-20">

    <!-- Breadcrumb -->
    <nav class="text-[13px] text-content-muted mb-8 flex items-center gap-2">
      <a href="/escuela/docentes" class="hover:text-brand transition-colors">Equipo docente</a>
      <span>/</span>
      <span class="text-content">Mi perfil</span>
      <span class="ml-auto">
        <form method="POST" action="/api/auth/logout" class="inline">
          <button type="submit"
                  class="text-[12px] text-content-muted hover:text-brand transition-colors">
            Cerrar sesión →
          </button>
        </form>
      </span>
    </nav>

    <h1 class="headline-display text-[2rem] mb-2">Mi perfil docente</h1>
    <p class="text-content-secondary text-[14px] mb-8">
      Esta información es visible públicamente en la página de equipo docente.
    </p>

    <!-- Notificación de éxito -->
    {updated && (
      <div role="status"
           class="mb-6 flex items-center gap-3 px-5 py-3.5 rounded-2xl text-[13px]"
           style="background: rgba(22,74,152,0.06); border: 1px solid rgba(22,74,152,0.18); color: var(--color-brand);">
        ✓ Perfil actualizado correctamente.
      </div>
    )}

    <!-- Error -->
    {error && (
      <div role="alert"
           class="mb-6 flex items-start gap-3 px-5 py-3.5 rounded-2xl text-[13px]"
           style="background: rgba(200,31,102,0.06); border: 1px solid rgba(200,31,102,0.20); color: #9b1153;">
        <span class="shrink-0">⚠</span> {error}
      </div>
    )}

    <!-- Vista previa del avatar -->
    <div class="card-premium rounded-2xl p-6 mb-6 flex items-center gap-5">
      <div class="shrink-0 w-16 h-16 rounded-full overflow-hidden"
           style="background: var(--color-bg-elevated);">
        {docente.fotoUrl
          ? <img src={docente.fotoUrl} alt={docente.nombre}
                 class="w-full h-full object-cover"
                 onerror="this.style.display='none'" />
          : <div class="w-full h-full flex items-center justify-center text-brand font-bold text-2xl">
              {docente.nombre.charAt(0).toUpperCase()}
            </div>
        }
      </div>
      <div>
        <p class="text-[15px] font-bold text-content">{docente.nombre}</p>
        <p class="text-[13px] text-content-secondary">{docente.titulo}</p>
        {(docente.especialidades as string[]).length > 0 && (
          <div class="flex flex-wrap gap-1.5 mt-2">
            {(docente.especialidades as string[]).slice(0, 4).map(e => (
              <span class="text-[11px] font-medium px-2 py-0.5 rounded-full"
                    style="background: var(--color-brand-soft); color: var(--color-brand);">
                {e}
              </span>
            ))}
          </div>
        )}
      </div>
    </div>

    <!-- Formulario -->
    <form method="POST" class="card-premium rounded-2xl p-8 space-y-6">

      <!-- Nombre + Título -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label for="nombre" class="block text-[13px] font-medium text-content-secondary mb-1.5">
            Nombre completo <span class="text-accent2">*</span>
          </label>
          <input type="text" id="nombre" name="nombre" required maxlength="200"
                 value={docente.nombre}
                 class="w-full rounded-xl border border-border-default bg-bg-tertiary text-content px-4 py-2.5 text-[14px] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
        </div>
        <div>
          <label for="titulo" class="block text-[13px] font-medium text-content-secondary mb-1.5">
            Título / Cargo <span class="text-accent2">*</span>
          </label>
          <input type="text" id="titulo" name="titulo" required maxlength="300"
                 value={docente.titulo}
                 placeholder="ej. Ingeniero de Software · Full Stack"
                 class="w-full rounded-xl border border-border-default bg-bg-tertiary text-content px-4 py-2.5 text-[14px] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
        </div>
      </div>

      <!-- Bio -->
      <div>
        <label for="bio" class="block text-[13px] font-medium text-content-secondary mb-1.5">
          Biografía <span class="text-content-muted text-[12px]">(visible en el sitio, opcional)</span>
        </label>
        <textarea id="bio" name="bio" rows="4"
                  placeholder="Describí tu experiencia, especialización y enfoque docente..."
                  class="w-full rounded-xl border border-border-default bg-bg-tertiary text-content px-4 py-2.5 text-[14px] focus:outline-none focus:ring-2 focus:ring-brand transition-colors resize-y"
        >{docente.bio ?? ''}</textarea>
      </div>

      <!-- Especialidades -->
      <div>
        <label for="especialidades" class="block text-[13px] font-medium text-content-secondary mb-1.5">
          Especialidades <span class="text-content-muted text-[12px]">(separadas por coma, opcional)</span>
        </label>
        <input type="text" id="especialidades" name="especialidades"
               value={espec}
               placeholder="ej. TypeScript, Node.js, Arquitectura de Software, DevOps"
               class="w-full rounded-xl border border-border-default bg-bg-tertiary text-content px-4 py-2.5 text-[14px] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
      </div>

      <!-- Foto URL -->
      <div>
        <label for="fotoUrl" class="block text-[13px] font-medium text-content-secondary mb-1.5">
          URL de foto de perfil <span class="text-content-muted text-[12px]">(debe comenzar con https://, opcional)</span>
        </label>
        <input type="url" id="fotoUrl" name="fotoUrl"
               value={docente.fotoUrl ?? ''}
               placeholder="https://ejemplo.com/mi-foto.jpg"
               class="w-full rounded-xl border border-border-default bg-bg-tertiary text-content px-4 py-2.5 text-[14px] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
      </div>

      <!-- LinkedIn -->
      <div>
        <label for="linkedin" class="block text-[13px] font-medium text-content-secondary mb-1.5">
          LinkedIn <span class="text-content-muted text-[12px]">(debe comenzar con https://linkedin.com, opcional)</span>
        </label>
        <input type="url" id="linkedin" name="linkedin"
               value={docente.linkedin ?? ''}
               placeholder="https://linkedin.com/in/tu-perfil"
               class="w-full rounded-xl border border-border-default bg-bg-tertiary text-content px-4 py-2.5 text-[14px] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
      </div>

      <div class="h-px bg-border-subtle"></div>

      <div class="flex items-center gap-4">
        <button type="submit"
                class="btn-primary bg-brand text-white font-semibold px-6 py-2.5 rounded-xl text-[14px]">
          Guardar cambios
        </button>
        <a href="/escuela/docentes"
           class="text-[13px] text-content-secondary hover:text-content transition-colors">
          Ver perfil público
        </a>
      </div>

    </form>
  </section>
</Base>
