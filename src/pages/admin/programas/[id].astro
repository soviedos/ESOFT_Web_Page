---
import Admin from '../../../layouts/Admin.astro'
import ProgramaForm from '../../../components/admin/ProgramaForm.astro'
import { requireAuth } from '../../../lib/auth'
import { db } from '../../../db/client'
import { programas, areasCurriculares } from '../../../db/schema'
import { and, eq, ne } from 'drizzle-orm'
import { MODALIDAD_CONFIG, parseProgramaForm } from '../../../lib/modalidades'
import { actualizarPrograma } from '../../../lib/programa-write'

const user = await requireAuth(Astro.request, 'admin')
if (!user) return Astro.redirect(`/login?next=/admin/programas`)

const { id } = Astro.params
if (!id) return Astro.redirect('/admin/programas')

const programa = await db.query.programas.findFirst({ where: eq(programas.id, id) })
if (!programa) return new Response(null, { status: 404 })

// La modalidad es inmutable: se toma siempre del registro, no del form.
const modalidad = programa.modalidad
const cfg = MODALIDAD_CONFIG[modalidad]

let error = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const valores = parseProgramaForm(form, modalidad)

  if (!valores.titulo || !valores.descripcion) {
    error = 'Completá el título y la descripción.'
  } else {
    try {
      await actualizarPrograma(id, modalidad, valores)
      return Astro.redirect('/admin/programas?updated=1')
    } catch (err: any) {
      error = 'Error al guardar. Intentá de nuevo.'
    }
  }
}

// Datos para los selects según la modalidad.
let areas: { id: string; nombre: string }[] = []
let prerequisitos: { id: string; nombre: string }[] = []
if (cfg?.campos.area) {
  areas = await db.select({ id: areasCurriculares.id, nombre: areasCurriculares.nombre })
    .from(areasCurriculares).where(eq(areasCurriculares.activo, true)).orderBy(areasCurriculares.nombre)
}
if (cfg?.campos.prerequisito) {
  // Programas activos, excluyendo el propio (no puede ser su propio prerequisito).
  prerequisitos = await db.select({ id: programas.id, nombre: programas.titulo })
    .from(programas).where(and(eq(programas.activo, true), ne(programas.id, id))).orderBy(programas.titulo)
}

const updated = Astro.url.searchParams.get('updated')
---

<Admin user={user} title={`Editar: ${programa.titulo}`}>

  <div class="mb-6 flex items-center justify-between">
    <a href="/admin/programas" class="text-[13px] text-content-muted hover:text-brand transition-colors">
      ← Volver a programas
    </a>
    <a href={`/programas/${programa.slug}`} target="_blank" rel="noopener"
       class="text-[13px] text-content-muted hover:text-brand transition-colors">
      Ver página pública →
    </a>
  </div>

  {updated && (
    <div role="status"
         class="mb-6 flex items-center gap-3 px-5 py-3.5 rounded-2xl text-[13px]"
         style="background: rgba(22,74,152,0.06); border: 1px solid rgba(22,74,152,0.18); color: var(--color-brand);">
      ✓ Cambios guardados correctamente.
    </div>
  )}

  <ProgramaForm
    modalidad={modalidad}
    modo="editar"
    formAction={`/admin/programas/${id}`}
    areas={areas}
    prerequisitos={prerequisitos}
    programa={programa}
    error={error}
  />

  <!-- Acceso al editor del plan de estudios -->
  <div class="mt-6 bg-bg-secondary rounded-2xl border border-border-subtle p-6 flex items-center justify-between gap-4">
    <div>
      <p class="text-[14px] font-semibold text-content">Plan de estudios</p>
      <p class="text-[12px] text-content-muted mt-0.5">
        {cfg?.plan.tipoUnidad
          ? `Gestioná ${cfg.plan.unidadLabelPlural.toLowerCase()} y sus competencias.`
          : 'Gestioná las competencias del programa.'}
      </p>
    </div>
    <a href={`/admin/programas/${id}/plan`}
       class="shrink-0 text-[13px] font-medium px-4 py-2.5 rounded-xl border border-brand text-brand hover:bg-brand-soft transition-colors">
      Editar plan →
    </a>
  </div>

</Admin>
