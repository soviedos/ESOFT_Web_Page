---
import Admin from '../../../layouts/Admin.astro'
import ProgramaForm from '../../../components/admin/ProgramaForm.astro'
import { requireAuth } from '../../../lib/auth'
import { db } from '../../../db/client'
import { programas, areasCurriculares } from '../../../db/schema'
import { eq } from 'drizzle-orm'
import {
  MODALIDADES, MODALIDAD_CONFIG, esModalidadValida, parseProgramaForm, slugify,
} from '../../../lib/modalidades'

const user = await requireAuth(Astro.request, 'admin')
if (!user) return Astro.redirect(`/login?next=/admin/programas/nuevo`)

const modalidad = Astro.url.searchParams.get('modalidad')
const modalidadValida = esModalidadValida(modalidad)

let error = ''

// POST: alta de programa (solo si la modalidad es válida).
if (Astro.request.method === 'POST' && modalidadValida) {
  const form = await Astro.request.formData()
  const valores = parseProgramaForm(form, modalidad)

  if (!valores.titulo || !valores.descripcion) {
    error = 'Completá el título y la descripción.'
  } else {
    try {
      await db.insert(programas).values({
        slug: slugify(valores.titulo),
        titulo:                valores.titulo,
        descripcion:           valores.descripcion,
        modalidad:             modalidad as any,
        nivel:                 valores.nivel as any,
        objetivo:              valores.objetivo,
        perfilEgresado:        valores.perfilEgresado,
        tecnologias:           valores.tecnologias,
        activo:                valores.activo,
        duracionCuatrimestres: valores.duracionCuatrimestres,
        areaCurricularId:      valores.areaCurricularId,
        nivelCredencial:       valores.nivelCredencial as any,
        totalMicrociclos:      valores.totalMicrociclos,
        duracionHoras:         valores.duracionHoras,
        prerequisitoId:        valores.prerequisitoId,
      })
      return Astro.redirect('/admin/programas?created=1')
    } catch (err: any) {
      error = err?.code === '23505'
        ? 'Ya existe un programa con un título similar. Cambiá el título.'
        : 'Error al guardar. Intentá de nuevo.'
    }
  }
}

// Datos para los selects (solo cuando hay formulario).
let areas: { id: string; nombre: string }[] = []
let prerequisitos: { id: string; nombre: string }[] = []
if (modalidadValida) {
  const cfg = MODALIDAD_CONFIG[modalidad]
  if (cfg.campos.area) {
    areas = await db.select({ id: areasCurriculares.id, nombre: areasCurriculares.nombre })
      .from(areasCurriculares).where(eq(areasCurriculares.activo, true)).orderBy(areasCurriculares.nombre)
  }
  if (cfg.campos.prerequisito) {
    prerequisitos = await db.select({ id: programas.id, nombre: programas.titulo })
      .from(programas).where(eq(programas.activo, true)).orderBy(programas.titulo)
  }
}

const cfg = modalidadValida ? MODALIDAD_CONFIG[modalidad] : null
---

<Admin user={user} title={cfg ? `Nuevo: ${cfg.label}` : 'Nuevo programa'}>

  <div class="mb-6">
    <a href={modalidadValida ? '/admin/programas/nuevo' : '/admin/programas'}
       class="text-[13px] text-content-muted hover:text-brand transition-colors">
      {modalidadValida ? '← Cambiar modalidad' : '← Volver a programas'}
    </a>
  </div>

  {!modalidadValida ? (
    <>
      <div class="mb-6">
        <h2 class="text-[18px] font-semibold text-content mb-1">Elegí la modalidad del programa</h2>
        <p class="text-[13px] text-content-muted">Cada modalidad tiene su propio formato de datos. La modalidad no se puede cambiar después.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {MODALIDADES.map(m => (
          <a href={`/admin/programas/nuevo?modalidad=${m.value}`}
             class="group block rounded-2xl border border-border-subtle bg-bg-secondary p-6 hover:border-brand transition-colors">
            <div class="flex items-start justify-between gap-3">
              <h3 class="text-[15px] font-semibold text-content group-hover:text-brand transition-colors">{m.label}</h3>
              <svg class="w-4 h-4 text-content-muted group-hover:text-brand transition-colors shrink-0 mt-0.5" viewBox="0 0 14 14" fill="none">
                <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="text-[13px] text-content-secondary leading-[1.7] mt-2">{m.descripcion}</p>
            <p class="text-[11px] font-medium text-brand-label bg-brand-soft/50 rounded-lg px-2.5 py-1.5 mt-4 inline-block">{m.formato}</p>
          </a>
        ))}
      </div>
    </>
  ) : (
    <ProgramaForm
      modalidad={modalidad}
      modo="crear"
      formAction={`/admin/programas/nuevo?modalidad=${modalidad}`}
      areas={areas}
      prerequisitos={prerequisitos}
      error={error}
    />
  )}

</Admin>
