---
import Admin from '../../../layouts/Admin.astro'
import { requireAuth } from '../../../lib/auth'
import { db } from '../../../db/client'
import { bloquesContenido } from '../../../db/schema'
import { asc } from 'drizzle-orm'

const user = await requireAuth(Astro.request, 'admin')
if (!user) return Astro.redirect(`/login?next=/admin/contenido`)

const lista = await db.select().from(bloquesContenido)
  .orderBy(asc(bloquesContenido.seccion), asc(bloquesContenido.orden))

const updated = Astro.url.searchParams.get('updated')

// Agrupar por sección, preservando el orden.
const SECCION_LABEL: Record<string, string> = {
  modalidad:   'Modalidades',
  metodologia: 'Metodología',
}
const grupos = new Map<string, typeof lista>()
for (const b of lista) {
  const k = b.seccion ?? 'otros'
  if (!grupos.has(k)) grupos.set(k, [])
  grupos.get(k)!.push(b)
}

const fmt = (d: Date) => new Date(d).toLocaleDateString('es-CR', { day: 'numeric', month: 'short', year: 'numeric' })
---

<Admin user={user} title="Contenido">

  {updated && (
    <div role="status"
         class="mb-6 flex items-center gap-3 px-5 py-3.5 rounded-2xl text-[13px]"
         style="background: rgba(22,74,152,0.06); border: 1px solid rgba(22,74,152,0.18); color: var(--color-brand);">
      ✓ Bloque actualizado correctamente.
    </div>
  )}

  <div class="mb-6">
    <h2 class="text-[18px] font-semibold text-content mb-1">Bloques de contenido</h2>
    <p class="text-[13px] text-content-muted">Textos editables que se muestran en las páginas públicas del sitio.</p>
  </div>

  <div class="space-y-8">
    {[...grupos.entries()].map(([seccion, bloques]) => (
      <div>
        <p class="text-[11px] font-semibold uppercase tracking-widest text-brand-label mb-3">
          {SECCION_LABEL[seccion] ?? seccion}
        </p>
        <div class="bg-bg-secondary rounded-2xl border border-border-subtle overflow-hidden">
          {bloques.map(b => (
            <a href={`/admin/contenido/${b.id}`}
               class="flex items-center justify-between gap-4 px-5 py-4 border-b border-border-subtle last:border-0 hover:bg-bg-tertiary transition-colors">
              <div class="min-w-0">
                <p class="text-[14px] font-medium text-content truncate">{b.titulo ?? b.clave}</p>
                <p class="text-[12px] text-content-muted mt-0.5">
                  <span class="font-mono">{b.clave}</span> · actualizado {fmt(b.actualizadoEn)}
                </p>
              </div>
              <span class="shrink-0 text-[13px] font-medium text-brand">Editar →</span>
            </a>
          ))}
        </div>
      </div>
    ))}

    {lista.length === 0 && (
      <p class="text-content-muted text-[14px] py-12 text-center">No hay bloques de contenido todavía.</p>
    )}
  </div>

</Admin>
