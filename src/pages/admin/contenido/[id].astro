---
import Admin from '../../../layouts/Admin.astro'
import { requireAuth } from '../../../lib/auth'
import { db } from '../../../db/client'
import { bloquesContenido } from '../../../db/schema'
import { eq } from 'drizzle-orm'
import { guardarBloque } from '../../../lib/programa-write'

const user = await requireAuth(Astro.request, 'admin')
if (!user) return Astro.redirect(`/login?next=/admin/contenido`)

const { id } = Astro.params
if (!id) return Astro.redirect('/admin/contenido')

const bloque = await db.query.bloquesContenido.findFirst({ where: eq(bloquesContenido.id, id) })
if (!bloque) return new Response(null, { status: 404 })

let error = ''

if (Astro.request.method === 'POST') {
  const form   = await Astro.request.formData()
  const titulo = ((form.get('titulo') as string) ?? '').trim() || null
  const cuerpo = ((form.get('cuerpo') as string) ?? '').trim() || null

  if (!cuerpo) {
    error = 'El cuerpo no puede quedar vacío.'
  } else {
    try {
      await guardarBloque(id, { titulo, cuerpo }, user.id)
      return Astro.redirect('/admin/contenido?updated=1')
    } catch {
      error = 'Error al guardar. Intentá de nuevo.'
    }
  }
}

const INPUT = 'w-full rounded-xl border border-border-default bg-bg-tertiary text-content px-4 py-2.5 text-[14px] focus:outline-none focus:ring-2 focus:ring-brand transition-colors'
const LABEL = 'block text-[13px] font-medium text-content-secondary mb-1.5'
const fmt = (d: Date) => new Date(d).toLocaleString('es-CR', { dateStyle: 'long', timeStyle: 'short' })
---

<Admin user={user} title={`Editar: ${bloque.titulo ?? bloque.clave}`}>

  <div class="mb-6">
    <a href="/admin/contenido" class="text-[13px] text-content-muted hover:text-brand transition-colors">
      ← Volver a contenido
    </a>
  </div>

  {error && (
    <div role="alert"
         class="mb-6 flex items-start gap-3 px-5 py-3.5 rounded-2xl text-[13px]"
         style="background: rgba(200,31,102,0.06); border: 1px solid rgba(200,31,102,0.20); color: var(--color-accent-hover);">
      <span class="shrink-0">⚠</span> {error}
    </div>
  )}

  <form method="POST" class="bg-bg-secondary rounded-2xl border border-border-subtle p-8 space-y-6">

    <!-- Clave (no editable) -->
    <div class="flex items-center justify-between gap-4 rounded-xl bg-bg-tertiary border border-border-subtle px-4 py-3">
      <div>
        <p class="text-[12px] font-medium text-content-muted">Clave</p>
        <p class="text-[13px] font-mono font-semibold text-content">{bloque.clave}</p>
      </div>
      <span class="text-[11px] text-content-muted bg-bg-elevated px-2.5 py-1 rounded-full">No editable</span>
    </div>

    <!-- Título -->
    <div>
      <label for="titulo" class={LABEL}>Título</label>
      <input type="text" id="titulo" name="titulo" maxlength="300" value={bloque.titulo ?? ''} class={INPUT} />
    </div>

    <!-- Cuerpo -->
    <div>
      <label for="cuerpo" class={LABEL}>Cuerpo <span class="text-accent2">*</span></label>
      <textarea id="cuerpo" name="cuerpo" required rows="10"
                class={`${INPUT} resize-y leading-[1.7]`}>{bloque.cuerpo ?? ''}</textarea>
      <p class="text-[12px] text-content-muted mt-1.5">Separá los párrafos con una línea en blanco.</p>
    </div>

    <p class="text-[12px] text-content-muted">Última actualización: {fmt(bloque.actualizadoEn)}</p>

    <div class="h-px bg-border-subtle"></div>

    <div class="flex items-center gap-4">
      <button type="submit"
              class="btn-primary bg-accent2 text-white font-semibold px-6 py-2.5 rounded-xl text-[14px] hover:bg-accent-hover transition-colors">
        Guardar cambios
      </button>
      <a href="/admin/contenido" class="text-[13px] text-content-secondary hover:text-content transition-colors">
        Cancelar
      </a>
    </div>
  </form>

</Admin>
