---
import Base from '../../layouts/Base.astro';
import RichText from '../../components/RichText.astro';
import { getBloque } from '../../lib/contenido';

const FALLBACK = {
  titulo: 'Metodología XperiencEd',
  cuerpo: 'XperiencEd es la metodología de aprendizaje de CENFOTEC, con una distribución de 20% teoría, 60% práctica y 20% reflexión. Es el pilar del modelo Credentials as you Grow, que acredita competencias de forma progresiva.',
};
const bloque = await getBloque('metodologia-xperienced');
const titulo = bloque?.titulo ?? FALLBACK.titulo;
const cuerpo = bloque?.cuerpo ?? FALLBACK.cuerpo;

const pilares = [
  { titulo: 'Formación por competencias', texto: 'Cada programa está diseñado alrededor de competencias profesionales reales que el mercado demanda. Los estudiantes desarrollan habilidades técnicas y blandas desde el primer día.' },
  { titulo: 'Aprendizaje basado en proyectos', texto: 'Los cursos integran proyectos reales como eje central del aprendizaje. Los estudiantes trabajan en equipos, con metodologías ágiles y herramientas de la industria.' },
  { titulo: 'Evaluación auténtica', texto: 'La evaluación se centra en la demostración de competencias a través de entregables, presentaciones y portafolios profesionales, no solo exámenes teóricos.' },
  { titulo: 'Vinculación con la industria', texto: 'Programas co-diseñados con empresas del sector, prácticas profesionales, certificaciones y mentorías con profesionales activos.' },
];
---

<Base title="Metodología" description="Modelo educativo de ESOFT: formación por competencias y aprendizaje basado en proyectos.">
  <section class="max-w-6xl mx-auto px-6 py-12 md:py-20">
    <nav class="text-sm text-content-muted mb-6">
      <a href="/escuela" class="hover:text-content">Escuela</a> / <span class="text-content">Metodología</span>
    </nav>
    <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-6">Modelo educativo</h1>

    <!-- Bloque editable: metodologia-xperienced -->
    <div class="card-premium rounded-[20px] p-8 md:p-10 max-w-3xl mb-12 md:mb-16">
      <span class="text-[11px] font-bold uppercase tracking-widest text-brand">Metodología</span>
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight mt-2 mb-4">{titulo}</h2>
      <div class="space-y-4">
        <RichText texto={cuerpo} pClass="text-content-secondary text-[15px] md:text-base leading-[1.85]" />
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
      {pilares.map(p => (
        <div>
          <h3 class="text-xl md:text-2xl font-semibold mb-3">{p.titulo}</h3>
          <p class="text-content-muted max-w-3xl">{p.texto}</p>
        </div>
      ))}
    </div>
  </section>
</Base>
