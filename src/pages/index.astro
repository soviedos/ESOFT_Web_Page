---
import Base from '../layouts/Base.astro';
import Card from '../components/Card.astro';
import Terminal from '../components/Terminal.astro';
---

<Base title="Inicio" description="ESOFT — Escuela de Ingeniería de Software de la Universidad CENFOTEC. IA, cloud, testing, arquitectura y desarrollo real.">

  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       1. HERO — Cinematic, high-impact, premium
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <section class="relative min-h-[100dvh] flex flex-col items-center justify-center overflow-hidden -mt-[72px] pt-[72px]" aria-label="Hero — Escuela de Ingeniería de Software">
    <!-- Hero-specific layers -->
    <div class="aurora-orb" aria-hidden="true"></div>
    <!-- Single unified glow -->
    <div class="ambient-glow w-[500px] md:w-[900px] h-[350px] md:h-[600px] top-[-10%] left-1/2 -translate-x-1/2 animate-pulse-glow" style="background: radial-gradient(ellipse at 50% 30%, rgba(27,58,140,0.08) 0%, rgba(249,115,22,0.04) 50%, transparent 70%);" aria-hidden="true"></div>
    <!-- Light sweep overlay -->
    <div class="absolute inset-0 light-sweep" aria-hidden="true"></div>
    <!-- Bottom gradient fade -->
    <div class="absolute bottom-0 left-0 right-0 h-[300px]" style="background: linear-gradient(to top, var(--color-bg-primary) 0%, transparent 100%);" aria-hidden="true"></div>

    <div class="relative max-w-[820px] mx-auto text-center px-6">

      <h1 class="headline-display text-[clamp(3.25rem,7.5vw,5.5rem)] animate-fade-up" style="animation-delay: 0.15s; text-shadow: 0 0 20px rgba(0,229,255,0.12);">
        El software del futuro<br />
        <span class="text-gradient-hero text-glow-cyan">se construye aquí.</span>
      </h1>

      <div class="mt-8 inline-flex items-center gap-3 rounded-full px-7 py-3 animate-fade-up" style="animation-delay: 0.2s; background: rgba(27,58,140,0.07); border: 1px solid rgba(27,58,140,0.18); box-shadow: 0 2px 12px rgba(27,58,140,0.10);">
        <span class="w-2 h-2 rounded-full shrink-0" style="background: #F97316; box-shadow: 0 0 6px rgba(249,115,22,0.5); animation: pulse 2s ease-in-out infinite;" aria-hidden="true"></span>
        <span class="text-[clamp(0.9rem,1.6vw,1.05rem)] font-semibold tracking-wide text-brand-label">Escuela de Ingeniería de Software (ESOFT) · Universidad CENFOTEC</span>
      </div>

      <p class="mt-5 text-[clamp(1.05rem,2vw,1.2rem)] text-content-secondary leading-[1.85] max-w-[520px] mx-auto animate-fade-up" style="animation-delay: 0.25s">
        La escuela 100&percnt; especializada en Ingeniería de Software de la Universidad CENFOTEC. IA, cloud, microservicios y arquitectura moderna.
      </p>

      <div class="mt-12 flex flex-col sm:flex-row gap-4 justify-center animate-fade-up" style="animation-delay: 0.35s">
        <a href="/programas" class="btn-primary inline-flex justify-center items-center bg-brand text-bg-primary font-semibold px-8 py-3.5 rounded-full text-[15px]">
          Conocer programas
        </a>
        <a href="/admision/solicitar-informacion" class="btn-ghost inline-flex justify-center items-center border border-border-default text-content-secondary font-medium px-8 py-3.5 rounded-full text-[15px]">
          Solicitar información
        </a>
      </div>

      <!-- Logos -->
      <div class="flex items-center justify-center gap-6 mt-16 animate-fade-up" style="animation-delay: 0.5s" aria-hidden="true">
        <img src="/ESOFT_Software-Engineering-Azul.png" alt="" class="w-[130px] md:w-[180px] h-auto" />
        <div class="w-px h-7 bg-border-default"></div>
        <img src="/UCENFOTEC_LogoHorizontal-Azul.png" alt="" class="w-[110px] md:w-[150px] h-auto" />
      </div>
    </div>
  </section>


  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       2. TRUST BAR — Glassy stat cards with count-up
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <section class="relative py-20 md:py-32 px-6" style="background: var(--color-bg-secondary);" aria-label="Estadísticas de ESOFT">
    <div class="section-divider max-w-[400px] mx-auto mb-16 md:mb-28"></div>
    <div class="max-w-[1060px] mx-auto reveal">
      <p class="text-center text-content-secondary text-[clamp(1rem,1.8vw,1.15rem)] max-w-[560px] mx-auto mb-12 md:mb-20 leading-[1.85]">
        La Universidad CENFOTEC creó ESOFT como su escuela especializada en Ingeniería de Software. Cada recurso, cada docente y cada decisión existe para formar <span class="text-content font-medium">ingenieros de software de clase mundial.</span>
      </p>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-5">
        <div class="card-stat p-5 md:p-8 text-center">
          <p class="text-[clamp(1.75rem,4vw,3rem)] font-extrabold tracking-tight text-content stat-number" data-count="200" data-prefix="+">+200</p>
          <p class="text-[14px] md:text-[15px] text-content-secondary mt-1.5 md:mt-2.5">Egresados de UCENFOTEC en la industria</p>
        </div>
        <div class="card-stat p-5 md:p-8 text-center">
          <p class="text-[clamp(1.75rem,4vw,3rem)] font-extrabold tracking-tight stat-number" data-count="93" data-suffix="%">93<span class="text-brand">%</span></p>
          <p class="text-[14px] md:text-[15px] text-content-secondary mt-1.5 md:mt-2.5">Colocación laboral en 6 meses</p>
        </div>
        <div class="card-stat p-5 md:p-8 text-center">
          <p class="text-[clamp(1.75rem,4vw,3rem)] font-extrabold tracking-tight text-content stat-number" data-count="100" data-prefix="" data-suffix="+">100+</p>
          <p class="text-[14px] md:text-[15px] text-content-secondary mt-1.5 md:mt-2.5">Docentes activos de la industria tecnológica</p>
        </div>
        <div class="card-stat p-5 md:p-8 text-center">
          <img src="/Logo_SINAES.jpg" alt="SINAES" class="h-16 md:h-20 w-auto mx-auto object-contain" />
          <p class="text-[14px] md:text-[15px] text-content-secondary mt-1.5 md:mt-2.5 font-medium">Carrera acreditada</p>
          <p class="text-[12px] md:text-[13px] text-content-muted mt-0.5">Bachillerato en Ingeniería del Software</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       ¿QUÉ ES ESOFT? — Institutional clarity
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <section class="relative py-20 md:py-28 px-6" style="background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(0,229,255,0.03) 0%, transparent 50%), var(--color-bg-primary);" aria-label="¿Qué es ESOFT?">
    <div class="max-w-[860px] mx-auto reveal">
      <div class="card-feature p-8 md:p-14 text-center">
            <p class="text-[14px] font-bold text-brand-label tracking-widest uppercase mb-4">¿Qué es ESOFT?</p>
            <h2 class="headline-display text-[clamp(1.5rem,3.5vw,2.25rem)] mb-5">
              La Escuela de Ingeniería de Software<br class="hidden md:block" />
              <span class="text-content-muted">de la Universidad CENFOTEC.</span>
            </h2>
            <p class="text-content-secondary text-[16px] leading-[1.85] mb-10 max-w-[620px] mx-auto">
              Es la escuela especializada que la <span class="text-content font-medium">Universidad CENFOTEC</span> creó para concentrar toda su experiencia en una sola disciplina: Ingeniería de Software.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
              <div>
                <p class="text-[13px] font-bold text-brand-label tracking-widest uppercase mb-3 text-center">Visión</p>
                <p class="text-content-secondary text-[15px] leading-[1.85]">
                  Ser reconocida como una Escuela que contribuya a la excelencia académica de la Universidad, promoviendo el desarrollo académico, profesional y personal de sus estudiantes y profesores, mediante la promoción de iniciativas, proyectos, valores y principios que trasciendan el ámbito institucional, y que dejen huella en la sociedad costarricense y fuera de nuestras fronteras.
                </p>
              </div>
              <div>
                <p class="text-[13px] font-bold text-brand-label tracking-widest uppercase mb-3 text-center">Misión</p>
                <p class="text-content-secondary text-[15px] leading-[1.85]">
                  Formar profesionales en ingeniería del software íntegros y conscientes de sus responsabilidades profesionales, que se guíen por los principios y valores propios de la Universidad Cenfotec, y que los promuevan en sus interacciones familiares, sociales y profesionales, de forma que contribuyan al desarrollo de la sociedad, con responsabilidad social, ética y moral.
                </p>
              </div>
            </div>
      </div>
    </div>
  </section>


  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       EDITORIAL BREAK — Brand statement
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <section class="relative py-24 md:py-36 px-6 overflow-hidden section-dramatic" aria-label="Declaración de marca">
    <hr class="hr-gradient max-w-[500px] mx-auto mb-16 md:mb-24" role="presentation" />
    <div class="ambient-glow w-[400px] md:w-[700px] h-[280px] md:h-[450px] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" style="background: radial-gradient(ellipse at center, rgba(139,92,246,0.06) 0%, rgba(0,229,255,0.03) 50%, transparent 70%);" aria-hidden="true"></div>
    <div class="relative max-w-[800px] mx-auto text-center reveal">
      <h2 class="headline-display text-[clamp(2.25rem,5.5vw,4rem)] leading-[1.06]">
        Cada línea de código<br />
        <span class="text-gradient-purple text-glow-purple">resuelve un problema real.</span>
      </h2>
      <p class="mt-8 text-content-secondary text-[clamp(1rem,1.8vw,1.15rem)] leading-[1.8] max-w-[480px] mx-auto">
        No enseñamos tecnología por moda. En la Universidad CENFOTEC formamos ingenieros que entienden el porqué, el cómo y el para quién.
      </p>
    </div>
  </section>


  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       3. RUTAS — Premium card grid
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <section class="relative py-24 md:py-36 lg:py-48 px-6 overflow-hidden section-deep" aria-label="Rutas de especialización">
    <div class="ambient-glow w-[300px] md:w-[600px] h-[200px] md:h-[350px] top-[25%] right-[-5%]" style="background: radial-gradient(ellipse at center, rgba(0,229,255,0.03) 0%, transparent 70%);" aria-hidden="true"></div>

    <div class="relative max-w-[1060px] mx-auto">
      <div class="text-center max-w-[600px] mx-auto mb-14 md:mb-20 reveal">
        <p class="text-[14px] font-bold text-brand-label tracking-widest uppercase mb-5">Rutas de especialización</p>
        <h2 class="headline-display text-[clamp(1.75rem,4.5vw,3rem)]">
          Tu camino. Tu especialización.
          <span class="text-content-muted">Tu decisión.</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 reveal-stagger">
        <Card title="Desarrollo Full-Stack" description="React, Node, Python, TypeScript y cloud. Construyes productos reales con deploys a producción desde el primer cuatrimestre." href="/rutas/desarrollo-software" icon="development" />
        <Card title="QA &amp; Testing con IA" description="Automatización, pruebas inteligentes y CI/CD. Dominás la calidad de software con las herramientas que usan equipos de clase mundial." href="/rutas/software-testing" icon="testing" />
        <Card title="Diseño UX/UI" description="Research, prototipado y diseño de producto. Creás experiencias digitales que los usuarios realmente necesitan." href="/rutas/ux-ui" icon="design" />
        <Card title="Inteligencia Artificial" description="Machine learning, deep learning y MLOps en producción. Sistemas inteligentes reales, no solo modelos académicos." href="/rutas/inteligencia-artificial" icon="ai" />
        <Card title="Arquitectura de Software" description="Microservicios, cloud-native, event-driven. Diseñás los sistemas que soportan millones de transacciones." href="/rutas/arquitectura-software" icon="architecture" />
        <Card title="Elegí tu ruta" description="Un camino claro desde cero hasta la especialización. Vos elegís hacia dónde crecés." href="/rutas" icon="routes" />
      </div>
    </div>
  </section>


  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       4. PROGRAMAS — Feature program showcase
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <section class="relative py-24 md:py-36 lg:py-48 px-6" style="background: radial-gradient(ellipse 60% 40% at 30% 0%, rgba(139,92,246,0.04) 0%, transparent 50%), var(--color-bg-secondary);" aria-label="Programas académicos">
    <div class="section-divider max-w-[400px] mx-auto mb-16 md:mb-28"></div>

    <div class="max-w-[1060px] mx-auto">
      <div class="text-center max-w-[620px] mx-auto mb-14 md:mb-20 reveal">
        <p class="text-[14px] font-bold text-accent2 tracking-widest uppercase mb-5">Programas académicos · Universidad CENFOTEC</p>
        <h2 class="headline-display text-[clamp(1.75rem,4.5vw,3rem)]">
          Diseñados por la industria.
          <span class="text-content-muted">Para la industria.</span>
        </h2>
      </div>

      <!-- Hero card: Bachillerato -->
      <div class="card-feature p-6 md:p-12 mb-6 reveal">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-[14px] font-bold text-brand-label tracking-widest uppercase mb-5">Bachillerato &middot; 9 cuatrimestres</p>
            <h3 class="text-2xl md:text-[2.25rem] font-extrabold tracking-[-0.03em] leading-tight mb-5">Ingeniería de Software</h3>
            <p class="text-content-secondary text-[15px] leading-[1.85] mb-6">
              4 años para dominar el ciclo completo: desarrollo, testing, IA, arquitectura y gestión de proyectos. Acreditado por SINAES.
            </p>
            <!-- Avatares de estudiantes del programa -->
            <div class="flex items-center gap-3 mb-8">
              <div class="flex -space-x-3">
                <div class="w-9 h-9 rounded-full border-2 border-bg-card flex items-center justify-center text-[14px] font-bold text-brand" style="background: rgba(0,229,255,0.12);">S</div>
                <div class="w-9 h-9 rounded-full border-2 border-bg-card flex items-center justify-center text-[14px] font-bold text-accent2" style="background: rgba(139,92,246,0.12);">M</div>
                <div class="w-9 h-9 rounded-full border-2 border-bg-card flex items-center justify-center text-[14px] font-bold text-accent3" style="background: rgba(52,211,153,0.12);">K</div>
                <div class="w-9 h-9 rounded-full border-2 border-bg-card flex items-center justify-center text-[14px] font-bold text-brand" style="background: rgba(0,229,255,0.12);">+</div>
              </div>
              <p class="text-[14px] text-content-secondary">+200 graduados</p>
            </div>
            <a href="/programas/bachillerato-ingenieria-software" class="link-arrow">
              Conocer programa <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </a>
          </div>
          <div class="hidden md:grid grid-cols-2 gap-4">
            <div class="rounded-2xl bg-bg-secondary/80 border border-border-subtle p-6 text-center">
              <p class="text-[2rem] font-extrabold stat-number">43</p>
              <p class="text-[14px] text-content-secondary mt-1.5">Cursos</p>
            </div>
            <div class="rounded-2xl bg-bg-secondary/80 border border-border-subtle p-6 text-center">
              <p class="text-[2rem] font-extrabold stat-number">4</p>
              <p class="text-[14px] text-content-secondary mt-1.5">Años</p>
            </div>
            <div class="rounded-2xl bg-bg-secondary/80 border border-border-subtle p-6 text-center">
              <p class="text-[2rem] font-extrabold text-brand">IA</p>
              <p class="text-[14px] text-content-secondary mt-1.5">Integrada</p>
            </div>
            <div class="rounded-2xl bg-bg-secondary/80 border border-border-subtle p-6 text-center">
              <p class="text-[2rem] font-extrabold stat-number">100%</p>
              <p class="text-[14px] text-content-secondary mt-1.5">Práctico</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Two secondary programs -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 reveal-stagger">
        <div class="card-premium rounded-[20px] p-8 md:p-10 group">
          <p class="text-[14px] font-bold text-accent2 tracking-widest uppercase mb-5">Maestría &middot; 6 cuatrimestres</p>
          <h3 class="text-lg md:text-xl font-bold tracking-tight mb-3">Software e Inteligencia Artificial</h3>
          <p class="text-content-secondary text-[15px] leading-[1.85] mb-8">Pasá de ejecutar a definir la estrategia técnica. IA aplicada, arquitectura avanzada y liderazgo de equipos de ingeniería.</p>
          <a href="/programas/maestria-ingenieria-software-ia" class="link-arrow text-[15px]">
            Explorar <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>
        <div class="card-premium rounded-[20px] p-8 md:p-10 group">
          <p class="text-[14px] font-bold text-accent2 tracking-widest uppercase mb-5">Técnico</p>
          <h3 class="text-lg md:text-xl font-bold tracking-tight mb-3">Testing de Software con IA</h3>
          <p class="text-content-secondary text-[15px] leading-[1.85] mb-8">La ruta más rápida hacia la industria de QA. Testing manual, automatizado y potenciado con sistemas inteligentes.</p>
          <a href="/programas/testing-software-ia-sistemas-inteligentes" class="link-arrow text-[15px]">
            Explorar <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>
      </div>

      <div class="text-center mt-16 reveal">
        <a href="/programas" class="btn-ghost inline-flex items-center border border-border-default text-content-secondary font-medium px-8 py-3.5 rounded-full text-[14px]">
          Ver todos los programas
        </a>
      </div>
    </div>
  </section>


  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       MID CTA — Conversion break
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <section class="relative py-20 md:py-32 px-6 overflow-hidden" style="background: var(--color-bg-primary);" aria-label="Solicitar información">
    <div class="ambient-glow w-[300px] md:w-[600px] h-[200px] md:h-[350px] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" style="background: radial-gradient(ellipse at center, rgba(0,229,255,0.04) 0%, transparent 60%);" aria-hidden="true"></div>
    <div class="relative max-w-[620px] mx-auto text-center reveal">
      <h2 class="headline-display text-[clamp(1.5rem,3.5vw,2.5rem)] mb-6">
        ¿Listo para construir el software<br />que el mundo necesita?
      </h2>
      <p class="text-content-secondary text-[15px] leading-[1.8] mb-10 max-w-[440px] mx-auto">
        Descubrí cuál es la ruta ideal para vos. En minutos tenés toda la información.
      </p>
      <a href="/admision/solicitar-informacion" class="btn-primary inline-flex items-center bg-brand text-bg-primary font-semibold px-8 py-3.5 rounded-full text-[15px]">
        Solicitar información
      </a>
    </div>
  </section>


  <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
       5. DIFERENCIADORES — Full-width accent section
  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
  <section class="relative py-24 md:py-36 lg:py-48 px-6 overflow-hidden section-alt" aria-label="Diferenciadores de ESOFT">

    <div class="relative max-w-[1060px] mx-auto">
      <div class="text-center max-w-[620px] mx-auto mb-14 md:mb-20 reveal">
