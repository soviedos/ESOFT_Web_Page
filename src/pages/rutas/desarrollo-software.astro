---
import Base from '../../layouts/Base.astro';
---

<Base title="Ruta: Desarrollo de Software" description="Ruta profesional de desarrollo de software: full-stack development.">
  <section class="max-w-6xl mx-auto px-6 py-12 md:py-20">
    <nav class="text-sm text-content-muted mb-6">
      <a href="/rutas" class="hover:text-content">Rutas</a> / <span class="text-content">Desarrollo de Software</span>
    </nav>
    <div class="max-w-3xl">
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-6">Ruta: Desarrollo de Software</h1>
      <p class="text-content-muted mb-6 md:mb-8 text-base md:text-lg">
        Dominá el desarrollo full-stack: front-end, back-end, APIs, bases de datos y despliegue en la nube.
      </p>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Objetivo profesional</h2>
      <p class="text-content-muted mb-8">Software Developer / Full-Stack Engineer / Tech Lead</p>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Nivel de entrada</h2>
      <p class="text-content-muted mb-8">Sin experiencia previa requerida.</p>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Progresión</h2>
      <ol class="space-y-4 mb-8">
        <li class="flex gap-4 items-start">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-bg-elevated text-brand font-bold flex items-center justify-center text-sm">1</span>
          <div>
            <a href="/programas/tecnico-ingenieria-software" class="font-semibold text-brand hover:underline">Técnico en Ingeniería de Software</a>
            <p class="text-sm text-content-muted">Fundamentos de programación, bases de datos y metodologías.</p>
          </div>
        </li>
        <li class="flex gap-4 items-start">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-bg-elevated text-brand font-bold flex items-center justify-center text-sm">2</span>
          <div>
            <a href="/programas/tecnico-desarrollo-web-avanzado" class="font-semibold text-brand hover:underline">Técnico en Desarrollo Web Avanzado</a>
            <p class="text-sm text-content-muted">Frameworks modernos, APIs, cloud deployment.</p>
          </div>
        </li>
        <li class="flex gap-4 items-start">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-bg-elevated text-brand font-bold flex items-center justify-center text-sm">3</span>
          <div>
            <a href="/programas/bachillerato-ingenieria-software" class="font-semibold text-brand hover:underline">Bachillerato en Ingeniería de Software</a>
            <p class="text-sm text-content-muted">Formación integral como ingeniero de software.</p>
          </div>
        </li>
      </ol>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Tecnologías</h2>
      <div class="flex flex-wrap gap-2 mb-8">
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">JavaScript</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">TypeScript</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">React</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">Node.js</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">Python</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">PostgreSQL</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">Docker</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">AWS</span>
      </div>

      <a href="/admision/solicitar-informacion" class="btn-primary inline-block rounded-full bg-brand text-white px-6 py-3 text-sm font-semibold hover:bg-brand-hover transition-all duration-300">
        Empezar esta ruta
      </a>
    </div>
  </section>
</Base>
