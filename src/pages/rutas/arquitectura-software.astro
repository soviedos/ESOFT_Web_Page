---
import Base from '../../layouts/Base.astro';
---

<Base title="Ruta: Arquitectura de Software" description="Ruta profesional de arquitectura de software: diseño de sistemas escalables.">
  <section class="max-w-6xl mx-auto px-6 py-12 md:py-20">
    <nav class="text-sm text-content-muted mb-6">
      <a href="/rutas" class="hover:text-content">Rutas</a> / <span class="text-content">Arquitectura de Software</span>
    </nav>
    <div class="max-w-3xl">
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-6">Ruta: Arquitectura de Software</h1>
      <p class="text-content-muted mb-6 md:mb-8 text-base md:text-lg">
        Diseñá sistemas escalables, resilientes y bien estructurados. Liderá decisiones técnicas a nivel enterprise.
      </p>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Objetivo profesional</h2>
      <p class="text-content-muted mb-8">Software Architect / Principal Engineer / CTO</p>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Nivel de entrada</h2>
      <p class="text-content-muted mb-8">Experiencia en desarrollo de software recomendada.</p>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Progresión</h2>
      <ol class="space-y-4 mb-8">
        <li class="flex gap-4 items-start">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-bg-elevated text-brand font-bold flex items-center justify-center text-sm">1</span>
          <div>
            <a href="/programas/bachillerato-ingenieria-software" class="font-semibold text-brand hover:underline">Bachillerato en Ingeniería de Software</a>
            <p class="text-sm text-content-muted">Base sólida en ingeniería de software.</p>
          </div>
        </li>
        <li class="flex gap-4 items-start">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-bg-elevated text-brand font-bold flex items-center justify-center text-sm">2</span>
          <div>
            <a href="/programas/maestria-arquitectura-diseno-software" class="font-semibold text-brand hover:underline">Maestría en Arquitectura y Diseño de Software</a>
            <p class="text-sm text-content-muted">Especialización en patrones, sistemas distribuidos y liderazgo técnico.</p>
          </div>
        </li>
      </ol>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Tecnologías</h2>
      <div class="flex flex-wrap gap-2 mb-8">
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">Microservicios</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">Docker</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">Kubernetes</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">AWS/Azure/GCP</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">Kafka</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">GraphQL</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">Terraform</span>
      </div>

      <a href="/admision/solicitar-informacion" class="btn-primary inline-block rounded-full bg-accent2 text-white px-6 py-3 text-sm font-semibold hover:bg-orange-600 transition-all duration-300">
        Empezar esta ruta
      </a>
    </div>
  </section>
</Base>
