---
import Base from '../../layouts/Base.astro';
---

<Base title="Ruta: Inteligencia Artificial" description="Ruta profesional de inteligencia artificial aplicada al software.">
  <section class="max-w-6xl mx-auto px-6 py-12 md:py-20">
    <nav class="text-sm text-content-muted mb-6">
      <a href="/rutas" class="hover:text-content">Rutas</a> / <span class="text-content">Inteligencia Artificial</span>
    </nav>
    <div class="max-w-3xl">
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-6">Ruta: Inteligencia Artificial</h1>
      <p class="text-content-muted mb-6 md:mb-8 text-base md:text-lg">
        Desarrollá sistemas inteligentes, modelos de machine learning y soluciones de IA aplicadas al software.
      </p>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Objetivo profesional</h2>
      <p class="text-content-muted mb-8">ML Engineer / AI Engineer / Data Scientist</p>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Nivel de entrada</h2>
      <p class="text-content-muted mb-8">Fundamentos de programación recomendados.</p>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Progresión</h2>
      <ol class="space-y-4 mb-8">
        <li class="flex gap-4 items-start">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-bg-elevated text-brand font-bold flex items-center justify-center text-sm">1</span>
          <div>
            <a href="/programas/tecnico-ingenieria-software" class="font-semibold text-brand hover:underline">Técnico en Ingeniería de Software</a>
            <p class="text-sm text-content-muted">Fundamentos de programación y desarrollo.</p>
          </div>
        </li>
        <li class="flex gap-4 items-start">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-bg-elevated text-brand font-bold flex items-center justify-center text-sm">2</span>
          <div>
            <a href="/programas/bachillerato-ingenieria-software" class="font-semibold text-brand hover:underline">Bachillerato en Ingeniería de Software</a>
            <p class="text-sm text-content-muted">Base sólida en ingeniería de software.</p>
          </div>
        </li>
        <li class="flex gap-4 items-start">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-bg-elevated text-brand font-bold flex items-center justify-center text-sm">3</span>
          <div>
            <a href="/programas/maestria-ingenieria-software-ia" class="font-semibold text-brand hover:underline">Maestría en Ingeniería de Software e IA</a>
            <p class="text-sm text-content-muted">Especialización en IA, ML y sistemas inteligentes.</p>
          </div>
        </li>
      </ol>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Tecnologías</h2>
      <div class="flex flex-wrap gap-2 mb-8">
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">Python</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">TensorFlow</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">PyTorch</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">scikit-learn</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">Pandas</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">MLflow</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">Hugging Face</span>
      </div>

      <a href="/admision/solicitar-informacion" class="btn-primary inline-block rounded-full bg-accent2 text-white px-6 py-3 text-sm font-semibold hover:bg-[#a01855] transition-all duration-300">
        Empezar esta ruta
      </a>
    </div>
  </section>
</Base>
