---
import Base from '../../layouts/Base.astro';
---

<Base title="Ruta: UX/UI" description="Ruta profesional de diseño UX/UI: experiencia de usuario y diseño de interfaces.">
  <section class="max-w-6xl mx-auto px-6 py-12 md:py-20">
    <nav class="text-sm text-content-muted mb-6">
      <a href="/rutas" class="hover:text-content">Rutas</a> / <span class="text-content">UX/UI</span>
    </nav>
    <div class="max-w-3xl">
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-6">Ruta: UX/UI Design</h1>
      <p class="text-content-muted mb-6 md:mb-8 text-base md:text-lg">
        Diseñá experiencias digitales centradas en el usuario. Desde investigación de usuarios hasta prototipado y diseño de producto.
      </p>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Objetivo profesional</h2>
      <p class="text-content-muted mb-8">UX Designer / UI Designer / Product Designer</p>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Nivel de entrada</h2>
      <p class="text-content-muted mb-8">Sin experiencia previa requerida. Interés en diseño y tecnología.</p>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Progresión</h2>
      <ol class="space-y-4 mb-8">
        <li class="flex gap-4 items-start">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-bg-elevated text-brand font-bold flex items-center justify-center text-sm">1</span>
          <div>
            <a href="/programas/tecnico-diseno-grafico-web-ux" class="font-semibold text-brand hover:underline">Técnico en Diseño Gráfico Web y UX</a>
            <p class="text-sm text-content-muted">Fundamentos de diseño, UI, UX, prototipado.</p>
          </div>
        </li>
      </ol>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">Tecnologías</h2>
      <div class="flex flex-wrap gap-2 mb-8">
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">Figma</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">Adobe XD</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">HTML/CSS</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">Design Systems</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">Usability Testing</span>
        <span class="glass text-content-secondary px-3 py-1.5 rounded-lg text-sm">Prototyping</span>
      </div>

      <a href="/admision/solicitar-informacion" class="btn-primary inline-block rounded-full bg-brand text-white px-6 py-3 text-sm font-semibold hover:bg-brand-hover transition-all duration-300">
        Empezar esta ruta
      </a>
    </div>
  </section>
</Base>
