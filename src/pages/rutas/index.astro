---
import Base from '../../layouts/Base.astro'
import { db } from '../../db/client'
import { rutas } from '../../db/schema'
import { eq } from 'drizzle-orm'

const lista = await db.select({
  id:          rutas.id,
  slug:        rutas.slug,
  titulo:      rutas.titulo,
  descripcion: rutas.descripcion,
  programaIds: rutas.programaIds,
}).from(rutas).where(eq(rutas.activo, true))
---

<Base
  title="Rutas de aprendizaje"
  description="Rutas de aprendizaje de ESOFT: itinerarios completos en desarrollo, IA, arquitectura, testing y UX."
>
  <section class="relative py-12 md:py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">Rutas de aprendizaje</h1>
      <p class="text-content-secondary text-base md:text-lg max-w-3xl">
        Itinerarios completos de formación. Cada ruta combina programas en progresión
        lógica para llevarte desde cero hasta un perfil profesional específico.
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-20">
    {lista.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {lista.map(r => (
          <a href={`/rutas/${r.slug}`}
             class="card-premium rounded-[20px] p-8 flex flex-col gap-4 no-underline">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0"
                 style="background: rgba(22,74,152,0.08);">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M2 9h14M9 2l7 7-7 7" stroke="var(--color-brand)" stroke-width="1.8"
                      stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="flex-1">
              <h2 class="text-[17px] font-bold text-content mb-2 leading-snug">{r.titulo}</h2>
              {r.descripcion && (
                <p class="text-[14px] text-content-secondary leading-[1.75]">{r.descripcion}</p>
              )}
            </div>
            <div class="flex items-center justify-between">
              <span class="text-[12px] text-content-muted">
                {(r.programaIds as string[]).length} {(r.programaIds as string[]).length === 1 ? 'programa' : 'programas'}
              </span>
              <span class="link-arrow text-[13px]">
                Ver ruta
                <svg viewBox="0 0 14 14" fill="none">
                  <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5"
                        stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="py-20 text-center">
        <p class="text-content-muted text-[15px]">No hay rutas disponibles. Volvé pronto.</p>
      </div>
    )}
  </section>
</Base>
