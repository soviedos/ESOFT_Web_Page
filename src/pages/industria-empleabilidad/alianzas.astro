---
import Base from '../../layouts/Base.astro';
---

<Base title="Alianzas" description="Alianzas estratégicas de ESOFT con la industria tecnológica.">
  <section class="max-w-6xl mx-auto px-4 py-10 md:py-16">
    <nav class="text-sm text-content-muted mb-6">
      <a href="/industria-empleabilidad" class="hover:text-brand">Industria</a> / <span class="text-content">Alianzas</span>
    </nav>
    <div class="max-w-3xl">
      <h1 class="text-3xl md:text-4xl font-bold break-words mb-6">Alianzas estratégicas</h1>
      <p class="text-content-muted mb-6 md:mb-8 text-base md:text-lg">
        ESOFT colabora con empresas tecnológicas líderes para asegurar que la formación sea relevante, actualizada y conectada con oportunidades reales.
      </p>
      <p class="text-sm text-content-muted">— Lista de alianzas pendiente de publicar.</p>
    </div>
  </section>
</Base>
