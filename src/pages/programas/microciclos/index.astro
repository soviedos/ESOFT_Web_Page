---
import Base from '../../../layouts/Base.astro'
import { db } from '../../../db/client'
import { programas } from '../../../db/schema'
import { eq } from 'drizzle-orm'

const todos = await db.select({ modalidad: programas.modalidad })
  .from(programas).where(eq(programas.activo, true))

const count = (m: string) => todos.filter(p => p.modalidad === m).length

const secciones = [
  {
    href: '/programas/microciclos/rutas',
    titulo: 'Rutas de conocimiento',
    descripcion: 'Itinerarios fundacionales por microciclos que construyen una base sólida y común para especializarte después.',
    conteo: count('path'),
  },
  {
    href: '/programas/microciclos/cursos-360',
    titulo: 'Cursos 360',
    descripcion: 'Especializaciones modulares que cubren un dominio o tecnología de principio a fin, con enfoque aplicado.',
    conteo: count('curso_360'),
  },
  {
    href: '/programas/microciclos/cursos-continuos',
    titulo: 'Cursos de aprendizaje continuo',
    descripcion: 'Formación corta y puntual para sumar una competencia específica sin comprometer un plan completo.',
    conteo: count('curso_continuo'),
  },
]
---

<Base
  title="Microciclos"
  description="Aprendizaje modular de ESOFT por microciclos: rutas de conocimiento, cursos 360 y cursos de aprendizaje continuo."
>
  <section class="relative py-12 md:py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <nav class="text-[13px] text-content-muted mb-5" aria-label="Ruta de navegación">
        <a href="/programas" class="hover:text-content transition-colors">Programas</a>
        <span class="mx-2">/</span>
        <span class="text-content-secondary">Microciclos</span>
      </nav>
      <span class="text-[11px] font-bold uppercase tracking-widest text-brand">Formación modular</span>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight mt-2 mb-4">Microciclos</h1>
      <p class="text-content-secondary text-base md:text-lg max-w-3xl">
        Aprendizaje flexible que se adapta a tu ritmo y tus metas. Cada microciclo suma competencias
        y microcredenciales verificables, y se combina con los demás para construir tu propio camino.
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-20 md:pb-28">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {secciones.map(s => (
        <a href={s.href} class="card-premium rounded-[20px] p-7 flex flex-col gap-3 no-underline">
          <h2 class="text-[18px] font-bold text-content leading-snug">{s.titulo}</h2>
          <p class="text-[14px] text-content-secondary leading-[1.75] flex-1">{s.descripcion}</p>
          <div class="flex items-center justify-between mt-2 pt-4 border-t border-border-subtle">
            <span class="text-[13px] text-content-muted">{s.conteo} {s.conteo === 1 ? 'programa' : 'programas'}</span>
            <span class="link-arrow text-[14px]">Ver <svg viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>
