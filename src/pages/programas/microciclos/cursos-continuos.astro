---
import Base from '../../../layouts/Base.astro'
import ModalidadListing from '../../../components/sections/ModalidadListing.astro'
import { db } from '../../../db/client'
import { programas } from '../../../db/schema'
import { and, eq } from 'drizzle-orm'
import { getBloque } from '../../../lib/contenido'

const rows = await db.select({
  slug:          programas.slug,
  titulo:        programas.titulo,
  descripcion:   programas.descripcion,
  duracionHoras: programas.duracionHoras,
}).from(programas).where(and(eq(programas.activo, true), eq(programas.modalidad, 'curso_continuo')))

const items = rows.map(p => ({
  slug: p.slug,
  titulo: p.titulo,
  descripcion: p.descripcion,
  meta: p.duracionHoras ? `Curso continuo · ${p.duracionHoras} horas` : 'Curso continuo',
}))

const FALLBACK_INTRO = 'Los cursos de aprendizaje continuo son formaciones cortas y puntuales pensadas para sumar una competencia concreta sin comprometerte con un plan completo. Son perfectos para actualizarte, cubrir una brecha específica o probar un tema nuevo en pocas horas. Cada curso es independiente y otorga una microcredencial al completarlo.'
const bloque = await getBloque('cursos-continuos-intro')
const intro = bloque?.cuerpo ?? FALLBACK_INTRO
---

<Base
  title="Cursos de aprendizaje continuo"
  description="Cursos de aprendizaje continuo de ESOFT: formación corta y puntual para sumar una competencia específica a tu ritmo."
>
  <ModalidadListing
    breadcrumbLabel="Cursos de aprendizaje continuo"
    eyebrow="Microciclos · Formación corta"
    titulo="Cursos de aprendizaje continuo"
    intro={intro}
    items={items}
  />
</Base>
