---
import ProgramaLayout from '../../components/programa/ProgramaLayout.astro'
import SectionBadge from '../../components/ui/SectionBadge.astro'

const programa = {
  titulo:               'Técnico en Desarrollo de Software',
  tituloAcento:         'Desarrollo de Software',
  descripcion:          'Formación integral diseñada para proporcionarte las habilidades esenciales del desarrollo de software. Desarrollarás competencias digitales, socioemocionales y técnicas para enfrentar los desafíos de una industria en constante cambio.',
  tipo:                 'tecnico',
  duracionCuatrimestres: 4,
  badgeOverride:        'Técnico Nivel 2 · SOFTN2 · 4 cuatrimestres',
  estadisticas: [
    { valor: '10',          label: 'Materias' },
    { valor: '36',          label: 'Créditos' },
    { valor: '1 año',       label: '4 cuatrimestres',  colorValor: 'brand'   as const, size: 'lg' as const },
    { valor: 'Virtual\nen vivo', label: 'Modalidad',   colorValor: 'accent2' as const, size: 'lg' as const },
  ],
  ctaTitulo:       'Tu primera puerta a la',
  ctaTituloAcento: 'industria del software.',
  ctaDescripcion:  '4 cuatrimestres · 10 materias · 36 créditos · Virtual en vivo · Universidad CENFOTEC',
  cursos: [
    { nombre: 'Introducción a las Tecnologías de Información', cuatrimestre: 1, orden: 1, creditos: 3 },
    { nombre: 'Expresión Oral y Escrita',                      cuatrimestre: 1, orden: 2, creditos: 3 },
    { nombre: 'Introducción a la Ing. del Software',           cuatrimestre: 1, orden: 3, creditos: 3 },
    { nombre: 'Desarrollo de Habilidades Blandas',             cuatrimestre: 2, orden: 1, creditos: 3 },
    { nombre: 'Principios de Programación 1',                  cuatrimestre: 2, orden: 2, creditos: 5 },
    { nombre: 'Inglés Conversacional 1',                       cuatrimestre: 3, orden: 1, creditos: 2 },
    { nombre: 'Principios de Programación 2',                  cuatrimestre: 3, orden: 2, creditos: 5 },
    { nombre: 'Diseño y Programación Web',                     cuatrimestre: 3, orden: 3, creditos: 4 },
    { nombre: 'Pensamiento Crítico',                           cuatrimestre: 4, orden: 1, creditos: 3 },
    { nombre: 'Proyecto Integrador 1',                         cuatrimestre: 4, orden: 2, creditos: 5 },
  ],
}
---
<ProgramaLayout programa={programa}>
  <section slot="before-curriculum" class="py-16 md:py-24 px-6" style="background: var(--color-bg-primary);">
    <div class="max-w-[1060px] mx-auto grid grid-cols-1 lg:grid-cols-3 gap-10">
      <div>
        <SectionBadge texto="Perfil de entrada" />
        <p class="text-content-secondary text-[15px] leading-[1.85]">III Ciclo de la Educación General Básica o equivalente, y disposición para asumir retos en la resolución de problemas tecnológicos de mediana complejidad.</p>
      </div>
      <div>
        <SectionBadge texto="Perfil de salida" />
        <p class="text-content-secondary text-[14px] mb-3">Alineado con niveles 1, 2 y 3 del marco SFIA. Podrás aplicar a:</p>
        <ul class="space-y-2">
          {['Programador de Aplicaciones', 'Programador Web'].map(r => (
            <li class="flex gap-2 text-[14px] text-content-secondary"><span class="text-accent2 shrink-0">◆</span>{r}</li>
          ))}
        </ul>
      </div>
      <div>
        <SectionBadge texto="Fortalezas del programa" />
        <ul class="space-y-3">
          {[
            'Base sólida en desarrollo de software con conceptos fundamentales.',
            'Competencias digitales y socioemocionales para el entorno laboral cambiante.',
            'Certificaciones opcionales: Scrum Foundation Level, People Cert Software Development Skills Essentials.',
          ].map(f => <li class="flex gap-2 text-[13px] text-content-secondary"><span class="text-brand shrink-0 mt-0.5">◆</span>{f}</li>)}
        </ul>
      </div>
    </div>
  </section>
</ProgramaLayout>
