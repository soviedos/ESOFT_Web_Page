---
import ProgramaLayout from '../../components/programa/ProgramaLayout.astro'
import SectionBadge from '../../components/ui/SectionBadge.astro'

const certificaciones = ['Scrum Foundation Level','People Cert Software Development Skills Essentials','Intro to Web Programming','People Cert Scrum Developer','DevOps Foundation','People Cert Scrum Master 1']

const fortalezas = [
  { title: 'Formación práctica',          desc: 'Metodología XperiencEd™: 20% teoría, 60% práctica y 20% reflexión. Proyectos reales desde el primer cuatrimestre.' },
  { title: 'Actualización constante',     desc: 'Tecnologías y tendencias actualizadas constantemente para garantizarte los conocimientos necesarios ante los retos profesionales.' },
  { title: 'Base sólida en Ing. del Software', desc: 'Conceptos fundamentales que sustentan el desarrollo de software y comprensión del rol de la tecnología en la sociedad actual.' },
]

const programa = {
  titulo:               'Técnico en Ingeniería del Software',
  tituloAcento:         'Ingeniería del Software',
  descripcion:          'La Ingeniería del Software es una de las diez carreras de mayor demanda en Costa Rica. Con este técnico desarrollarás competencias digitales, socioemocionales y conocimiento técnico para analizar problemas y diseñar soluciones creativas que los resuelvan.',
  tipo:                 'tecnico',
  duracionCuatrimestres: 7,
  badgeOverride:        'Técnico Nivel 5 · SOFTN5 · 7 cuatrimestres',
  estadisticas: [
    { valor: '17',          label: 'Materias' },
    { valor: '62',          label: 'Créditos' },
    { valor: '2 años',      label: '7 cuatrimestres', colorValor: 'brand'   as const, size: 'lg' as const },
    { valor: 'Virtual\nen vivo', label: 'Modalidad',  colorValor: 'accent2' as const, size: 'lg' as const },
  ],
  ctaTitulo:       'Empezá tu carrera en',
  ctaTituloAcento: 'Ingeniería del Software.',
  ctaDescripcion:  '7 cuatrimestres · 17 materias · 62 créditos · Virtual en vivo · Universidad CENFOTEC',
  cursos: [
    { nombre: 'Introducción a las Tecnologías de Información', cuatrimestre: 1, orden: 1, creditos: 3 },
    { nombre: 'Expresión Oral y Escrita',                      cuatrimestre: 1, orden: 2, creditos: 3 },
    { nombre: 'Introducción a la Ing. del Software',           cuatrimestre: 1, orden: 3, creditos: 3 },
    { nombre: 'Desarrollo de Habilidades Blandas',             cuatrimestre: 2, orden: 1, creditos: 3 },
    { nombre: 'Principios de Programación 1',                  cuatrimestre: 2, orden: 2, creditos: 5 },
    { nombre: 'Inglés Conversacional 1',                       cuatrimestre: 3, orden: 1, creditos: 2 },
    { nombre: 'Principios de Programación 2',                  cuatrimestre: 3, orden: 2, creditos: 5 },
    { nombre: 'Diseño y Programación Web',                     cuatrimestre: 3, orden: 3, creditos: 4 },
    { nombre: 'Pensamiento Crítico',                           cuatrimestre: 4, orden: 1, creditos: 3 },
    { nombre: 'Proyecto Integrador 1',                         cuatrimestre: 4, orden: 2, creditos: 5 },
    { nombre: 'Fundamentos de Bases de Datos',                 cuatrimestre: 5, orden: 1, creditos: 4 },
    { nombre: 'Programación Orientada a Objetos',              cuatrimestre: 5, orden: 2, creditos: 5 },
    { nombre: 'Estructuras de Datos',                          cuatrimestre: 5, orden: 3, creditos: 3 },
    { nombre: 'Inglés Conversacional 2',                       cuatrimestre: 6, orden: 1, creditos: 2 },
    { nombre: 'Programación Web Avanzada',                     cuatrimestre: 6, orden: 2, creditos: 4 },
    { nombre: 'Arquitectura de Software',                      cuatrimestre: 6, orden: 3, creditos: 3 },
    { nombre: 'Proyecto Integrador 2',                         cuatrimestre: 7, orden: 1, creditos: 5 },
  ],
}
---
<ProgramaLayout programa={programa}>
  <section slot="before-curriculum" class="py-16 md:py-24 px-6" style="background: var(--color-bg-primary);">
    <div class="max-w-[1060px] mx-auto grid grid-cols-1 lg:grid-cols-3 gap-10">
      <div>
        <SectionBadge texto="Perfil de entrada" />
        <p class="text-content-secondary text-[15px] leading-[1.85]">Bachillerato en Educación Media. Si no lo tenés, podés iniciar con el <strong>Técnico en Desarrollo de Software (SOFTN2)</strong> y al graduarte ingresar a este programa.</p>
      </div>
      <div>
        <SectionBadge texto="Perfil de salida" />
        <p class="text-content-secondary text-[14px] mb-3">Alineado con niveles 1, 2 y 3 del marco SFIA. Podrás aplicar a:</p>
        <ul class="space-y-1.5">
          {['Desarrollador de Software','Analista de Software y Sistemas','Desarrollador Web'].map(r => (
            <li class="flex gap-2 text-[14px] text-content-secondary"><span class="text-accent2 shrink-0">◆</span>{r}</li>
          ))}
        </ul>
      </div>
      <div>
        <SectionBadge texto="Certificaciones opcionales" />
        <ul class="space-y-1.5">
          {certificaciones.map(c => <li class="flex gap-2 text-[13px] text-content-secondary"><span class="text-brand shrink-0">·</span>{c}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <div slot="curriculum-extra" class="mt-6 card-premium rounded-[18px] p-6 border-l-4 border-accent2">
    <p class="text-[13px] font-bold text-accent2 tracking-widest uppercase mb-2">Salida lateral — Técnico en Desarrollo de Software (SOFTN2)</p>
    <p class="text-[14px] text-content-secondary leading-[1.8]">Al completar los cuatrimestres I a IV (10 materias, 36 créditos) podés solicitar el título de <strong>Técnico en Desarrollo de Software</strong> como certificación adicional, sin detener tu avance en el SOFTN5.<br/><span class="text-content-muted">Puestos: Programador de Aplicaciones · Programador Web</span></p>
  </div>

  <section slot="after-curriculum" class="py-16 md:py-20 px-6" style="background: var(--color-bg-primary);">
    <div class="max-w-[1060px] mx-auto">
      <SectionBadge texto="Fortalezas del programa" mb="mb-6" />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {fortalezas.map(f => <div class="card-premium rounded-[18px] p-6"><p class="text-[15px] font-bold text-content mb-2">{f.title}</p><p class="text-[14px] text-content-secondary leading-[1.8]">{f.desc}</p></div>)}
      </div>
    </div>
  </section>
</ProgramaLayout>
