---
import Base from '../../layouts/Base.astro'
import Breadcrumb from '../../components/ui/Breadcrumb.astro'
import CTAButton from '../../components/ui/CTAButton.astro'

const items = [
  'Selenium, Cypress y Playwright',
  'Automatización de pruebas API (Postman, RestAssured)',
  'Integración continua y despliegue (CI/CD)',
  'Scripting con Python y JavaScript',
  'Frameworks de automatización (Page Object Model)',
  'Estrategias de testing automatizado',
]
---
<Base title="Automatización de Pruebas de Software" description="Técnico ágil en automatización de pruebas de software.">
  <section class="max-w-6xl mx-auto px-6 py-12 md:py-20">
    <Breadcrumb items={[{ label: 'Programas', href: '/programas' }, { label: 'Automatización de Pruebas' }]} />
    <div class="max-w-3xl">
      <span class="text-sm font-medium text-brand mb-2 block">Técnico ágil</span>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-6">Automatización de Pruebas de Software</h1>
      <p class="text-content-muted mb-6 md:mb-8 text-base md:text-lg">
        Frameworks de automatización, CI/CD, scripting y estrategias de testing automatizado.
      </p>
      <h2 class="text-xl md:text-2xl font-semibold mb-4">¿Qué aprenderás?</h2>
      <ul class="space-y-2 text-content-muted mb-8">
        {items.map(i => <li>• {i}</li>)}
      </ul>
      <CTAButton href="/admision/solicitar-informacion" texto="Solicitar información" />
    </div>
  </section>
</Base>
