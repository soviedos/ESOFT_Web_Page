---
<ProgramaLayout programa={programa}>
  <!-- Perspectiva laboral -->
  <section slot="before-curriculum" class="py-16 md:py-24 px-6" style="background: var(--color-bg-primary);">
    <div class="max-w-[1060px] mx-auto">
      <div class="text-center mb-12">
        <SectionBadge texto="Perspectiva laboral y empleabilidad" mb="mb-3" />
        <h2 class="headline-display text-[clamp(1.5rem,3vw,2.25rem)]">Nuestros egresados no son usuarios de la tecnología:<span class="text-content-muted"> la crean, la transforman y lideran su evolución.</span></h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
        <div class="card-stat p-6 text-center"><p class="text-[2.5rem] font-extrabold text-brand">97%</p><p class="text-[14px] text-content-secondary mt-1">Tasa de empleo</p></div>
        <div class="card-stat p-6 text-center"><p class="text-[2.5rem] font-extrabold text-accent2">2</p><p class="text-[14px] text-content-secondary mt-1">Meses promedio para emplearse</p></div>
        <div class="card-stat p-6 text-center"><p class="text-[1.6rem] font-extrabold text-content">¢987,524</p><p class="text-[14px] text-content-secondary mt-1">Ingreso mensual promedio</p></div>
        <div class="card-stat p-6 text-center"><p class="text-[2.5rem] font-extrabold text-accent2">4.47<span class="text-[1.2rem] text-content-muted">/5</span></p><p class="text-[14px] text-content-secondary mt-1">Satisfacción laboral</p></div>
      </div>
      <p class="text-center text-[12px] text-content-muted">Fuente: Observatorio Laboral de Profesiones · olap.conare.ac.cr</p>
    </div>
  </section>

  <!-- Qué hace único + Por qué elegir -->
  <section class="py-16 md:py-24 px-6" style="background: var(--color-bg-secondary);">
    <div class="max-w-[1060px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div>
        <SectionBadge texto="¿Qué hace único nuestro programa?" />
        <ul class="space-y-4">{unicoProg.map(i => <li class="flex gap-3"><span class="text-brand shrink-0 mt-1">◆</span><span class="text-content-secondary text-[15px] leading-[1.8]">{i}</span></li>)}</ul>
      </div>
      <div>
        <SectionBadge texto="¿Por qué elegir este bachillerato?" />
        <ul class="space-y-4">{porQueElegir.map(i => <li class="flex gap-3"><span class="text-accent2 shrink-0 mt-1">◆</span><span class="text-content-secondary text-[15px] leading-[1.8]">{i}</span></li>)}</ul>
      </div>
    </div>
  </section>

  <!-- Habilidades -->
  <section class="py-16 md:py-24 px-6" style="background: var(--color-bg-primary);">
    <div class="max-w-[1060px] mx-auto">
      <div class="text-center max-w-[600px] mx-auto mb-12">
        <SectionBadge texto="Las habilidades que te diferenciarán en el mercado laboral" mb="mb-3" />
        <h2 class="headline-display text-[clamp(1.5rem,3vw,2.25rem)]">Ingeniería real.<span class="text-content-muted"> No solo programación.</span></h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {habilidades.map(h => <div class="card-premium rounded-[18px] p-7"><p class="text-[15px] font-bold text-content mb-2">{h.title}</p><p class="text-[14px] text-content-secondary leading-[1.8]">{h.desc}</p></div>)}
      </div>
    </div>
  </section>

  <!-- Roles + Áreas -->
  <section class="py-16 md:py-24 px-6" style="background: var(--color-bg-secondary);">
    <div class="max-w-[1060px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-14 items-start">
      <div>
        <SectionBadge texto="¿Dónde podés trabajar y en qué roles?" />
        <p class="text-content-secondary text-[15px] leading-[1.85] mb-8">En un mercado donde la IA acelera el desarrollo, estos roles requieren ingenieros capaces de validar, supervisar y liderar soluciones tecnológicas complejas.</p>
        <div class="grid grid-cols-1 gap-2">
          {roles.map(r => <div class="flex items-center gap-3 rounded-xl border border-border-subtle px-4 py-3 bg-bg-primary"><span class="w-2 h-2 rounded-full bg-accent2 shrink-0"></span><span class="text-[14px] text-content-secondary">{r}</span></div>)}
        </div>
      </div>
      <div>
        <SectionBadge texto="¿Qué vas a aprender y desarrollar?" />
        <div class="space-y-3">
          {areas.map(a => <div><div class="flex justify-between text-[13px] mb-1"><span class="text-content-secondary">{a.area} <span class="text-content-muted">({a.cursos} cursos)</span></span><span class="font-bold text-brand">{a.pct}%</span></div><div class="h-2 rounded-full bg-bg-elevated overflow-hidden"><div class="h-full rounded-full bg-brand" style={`width: ${a.pct}%`}></div></div></div>)}
        </div>
      </div>
    </div>
  </section>

  <!-- Electivas + Ejes (curriculum-extra, aparece dentro de CurriculumSection) -->
  <div slot="curriculum-extra" class="mt-14 space-y-10">
    <div>
      <SectionBadge texto="Cursos electivos" mb="mb-6" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[{ label: 'Electiva 1', items: electivas1 }, { label: 'Electiva 2', items: electivas2 }].map(g => (
          <div class="card-premium rounded-[18px] overflow-hidden">
            <div class="px-5 py-3 border-b border-border-subtle" style="background: var(--color-bg-secondary);"><p class="text-[13px] font-bold text-content">{g.label}</p></div>
            <div class="p-4 space-y-2">
              {g.items.map(c => <div class="flex items-center gap-3"><span class="text-[11px] font-mono font-bold text-brand-label bg-brand-soft px-1.5 py-0.5 rounded shrink-0">{c.code}</span><span class="text-[13px] text-content-secondary">{c.name}</span></div>)}
            </div>
          </div>
        ))}
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {[{ titulo: 'Ejes curriculares', items: ejesCurr, color: 'text-brand' }, { titulo: 'Ejes transversales', items: ejesTransv, color: 'text-accent2' }, { titulo: 'Áreas disciplinares', items: areasDis, color: 'text-content-muted' }].map(sec => (
        <div class="card-premium rounded-[18px] p-6">
          <SectionBadge texto={sec.titulo} mb="mb-4" />
          <ul class="space-y-2">{sec.items.map(e => <li class="flex gap-2 text-[13px] text-content-secondary"><span class={`${sec.color} shrink-0`}>◆</span>{e}</li>)}</ul>
        </div>
      ))}
    </div>
  </div>
</ProgramaLayout>
