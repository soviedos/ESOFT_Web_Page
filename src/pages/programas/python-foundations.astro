---
import ProgramaLayout from '../../components/programa/ProgramaLayout.astro'
import SectionBadge from '../../components/ui/SectionBadge.astro'

const microciclos = [
  { num: 1, name: 'Pensamiento computacional y lógica de programación', desc: 'Variables, tipos de datos, operadores, algoritmos, pseudocódigo y primeros programas en Python.' },
  { num: 2, name: 'Control de flujo, validaciones y solución de problemas', desc: 'Condicionales, ciclos for/while, menús interactivos, validación de entradas y manejo de excepciones.' },
  { num: 3, name: 'Funciones, modularidad y buenas prácticas', desc: 'Declaración de funciones, parámetros, retorno de valores, modularidad, documentación y código limpio.' },
  { num: 4, name: 'Colecciones, archivos y datos estructurados', desc: 'Listas, diccionarios, tuplas, archivos CSV, JSON, filtros, transformaciones y generación de reportes.' },
  { num: 5, name: 'Python aplicado a bases de datos, APIs y automatización', desc: 'Conexión a SQLite/PostgreSQL, operaciones CRUD, consumo de APIs REST y automatización de tareas.' },
  { num: 6, name: 'Pruebas, Git y proyecto integrador', desc: 'Pruebas unitarias con pytest, control de versiones con Git, documentación técnica y presentación del proyecto final.' },
]

const paths = ['Desarrollo SQL y Bases de Datos Relacionales','Bases de Datos NoSQL y Distribuidas','Bases de Datos Vectoriales, IA Generativa y RAG','Testing de Software (Manual, Automatización e IA)']

const programa = {
  titulo:               'Python Foundations: Programación Aplicada desde Cero',
  descripcion:          'Programa base, nivelatorio y propedéutico para aprender a programar desde cero con Python. Puerta de entrada a todos los paths técnicos especializados: bases de datos, testing, IA y automatización.',
  tipo:                 'tecnico',
  duracionCuatrimestres: 6,
  badgeOverride:        'Curso base habilitador · 6 microciclos',
  estadisticas: [
    { valor: '6',    label: 'Microciclos' },
    { valor: '144',  label: 'Horas totales' },
    { valor: '4 sem',label: '24 semanas total', size: 'lg' as const },
    { valor: 'Virtual\nen vivo', label: 'Modalidad', colorValor: 'accent2' as const, size: 'lg' as const },
  ],
  ctaTitulo:       'Empezá a programar.',
  ctaTituloAcento: 'Sin experiencia previa.',
  ctaDescripcion:  '6 microciclos · 144 horas · 24 semanas · Virtual en vivo · Universidad CENFOTEC',
  cursos: [],
}
---
<ProgramaLayout programa={programa} heroGradient="rgba(244,180,0,0.08)">
  <section slot="before-curriculum" class="py-16 md:py-20 px-6" style="background: var(--color-bg-primary);">
    <div class="max-w-[1060px] mx-auto grid grid-cols-1 lg:grid-cols-3 gap-10">
      <div>
        <SectionBadge texto="Perfil de entrada" />
        <ul class="space-y-2">
          {['Manejo básico de computadora.','Uso básico de internet, navegador y archivos.','Capacidad para seguir instrucciones técnicas.','No se requiere experiencia previa en programación.'].map(r => (
            <li class="flex gap-2 text-[14px] text-content-secondary"><span class="text-brand shrink-0">·</span>{r}</li>
          ))}
        </ul>
      </div>
      <div>
        <SectionBadge texto="Perfil de salida" />
        <p class="text-content-secondary text-[14px] leading-[1.85]">Al finalizar, la persona será capaz de desarrollar programas básicos en Python, procesar datos desde archivos, consumir APIs simples, conectarse a una base de datos, aplicar pruebas unitarias iniciales, usar Git y documentar soluciones técnicas.</p>
      </div>
      <div>
        <SectionBadge texto="Paths habilitados" />
        <ul class="space-y-2">
          {paths.map(p => <li class="flex gap-2 text-[13px] text-content-secondary"><span class="text-brand shrink-0">◆</span>{p}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section slot="after-curriculum" class="py-16 md:py-24 px-6" style="background: var(--color-bg-secondary);">
    <div class="max-w-[1060px] mx-auto">
      <div class="text-center mb-12">
        <SectionBadge texto="Estructura curricular" mb="mb-3" />
        <h2 class="headline-display text-[clamp(1.5rem,3vw,2.25rem)] mb-4">6 Microciclos · 144 horas</h2>
        <p class="text-content-secondary text-[15px]">Cada microciclo: 24 horas · 4 semanas · 2 días/semana · 3 horas/sesión · 8 sesiones</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {microciclos.map(m => (
          <div class="card-premium rounded-[18px] overflow-hidden">
            <div class="px-5 py-3 border-b border-border-subtle flex items-center gap-3" style="background: var(--color-bg-primary);">
              <span class="w-8 h-8 rounded-full flex items-center justify-center text-[13px] font-bold text-white shrink-0 bg-brand">{m.num}</span>
              <p class="text-[13px] font-bold text-content leading-snug">{m.name}</p>
            </div>
            <div class="p-4"><p class="text-[13px] text-content-secondary leading-[1.7]">{m.desc}</p></div>
          </div>
        ))}
      </div>
      <div class="mt-8 rounded-[18px] p-6 text-white text-center" style="background: linear-gradient(135deg, #7a5600, #9a6a00);">
        <p class="text-[13px] font-bold tracking-widest uppercase mb-2 opacity-80">Evidencia final</p>
        <p class="text-[16px] font-bold mb-2">Sistema básico de procesamiento y gestión de datos con Python</p>
        <p class="text-[14px] opacity-90 max-w-[600px] mx-auto">Aplicación funcional con entrada de datos, procesamiento, almacenamiento en BD, pruebas unitarias, repositorio Git y documentación técnica.</p>
      </div>
    </div>
  </section>
</ProgramaLayout>
