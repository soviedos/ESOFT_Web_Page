---
import Base from '../../layouts/Base.astro';
---

<Base title="Técnico en Desarrollo y Diseño Web Avanzado — WEBN5" description="Técnico en Desarrollo y Diseño Web Avanzado. 7 cuatrimestres, 15 materias, 61 créditos. Virtual en vivo. Universidad CENFOTEC.">

  <!-- Hero -->
  <section class="relative py-16 md:py-24 px-6" style="background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(14,165,233,0.05) 0%, transparent 60%), var(--color-bg-secondary);">
    <div class="max-w-[1060px] mx-auto">
      <nav class="text-[13px] text-content-muted mb-8">
        <a href="/programas" class="hover:text-content transition-colors">Programas</a>
        <span class="mx-2">·</span>
        <span class="text-content">Técnico en Desarrollo y Diseño Web Avanzado</span>
      </nav>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">
        <div>
          <p class="text-[13px] font-bold text-brand-label tracking-widest uppercase mb-4">Técnico · WEBN5 · 7 cuatrimestres</p>
          <h1 class="headline-display text-[clamp(2rem,4.5vw,3rem)] mb-6">
            Técnico en Desarrollo<br />
            <span class="text-gradient-hero">y Diseño Web Avanzado</span>
          </h1>
          <p class="text-content-secondary text-[16px] leading-[1.85] mb-6 max-w-[480px]">
            Diseñado para formar profesionales altamente competitivos en un mercado digital en constante evolución. Combina diseño, programación y gestión de plataformas web para desarrollar soluciones completas, escalables y alineadas con las últimas tendencias.
          </p>
          <div class="card-premium rounded-[14px] p-4 mb-8 flex gap-3 items-start">
            <span class="text-brand text-[18px] shrink-0">ℹ</span>
            <p class="text-[13px] text-content-secondary leading-snug">
              <strong>Requisito de ingreso:</strong> Haber completado el <strong>Técnico en Desarrollo y Diseño Web (WEBTEC)</strong> — 4 cuatrimestres, 9 materias, 35 créditos — o tener el Bachillerato en Educación Media.
            </p>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="/admision/solicitar-informacion" class="btn-primary inline-flex items-center bg-accent2 text-white font-semibold px-7 py-3.5 rounded-full text-[15px] hover:bg-orange-600 transition-colors duration-300">
              Solicitar información
            </a>
            <a href="/admision" class="btn-ghost inline-flex items-center border border-border-default text-content-secondary font-medium px-7 py-3.5 rounded-full text-[15px]">
              Proceso de admisión
            </a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="card-stat p-6 text-center">
            <p class="text-[2.25rem] font-extrabold text-content">15</p>
            <p class="text-[14px] text-content-secondary mt-1">Materias</p>
          </div>
          <div class="card-stat p-6 text-center">
            <p class="text-[2.25rem] font-extrabold text-content">61</p>
            <p class="text-[14px] text-content-secondary mt-1">Créditos</p>
          </div>
          <div class="card-stat p-6 text-center">
            <p class="text-[2.25rem] font-extrabold text-brand">7</p>
            <p class="text-[14px] text-content-secondary mt-1">Cuatrimestres</p>
          </div>
          <div class="card-stat p-6 text-center">
            <p class="text-[1.25rem] font-extrabold text-accent2 leading-tight">Virtual<br/>en vivo</p>
            <p class="text-[14px] text-content-secondary mt-1">Modalidad</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Perfil de salida y razones -->
  <section class="py-16 md:py-24 px-6" style="background: var(--color-bg-primary);">
    <div class="max-w-[1060px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div>
        <p class="text-[13px] font-bold text-brand-label tracking-widest uppercase mb-4">Perfil de salida — roles</p>
        <ul class="space-y-3">
          {[
            { role: 'Web Developer Junior', desc: 'Desarrollo y optimización de sitios y aplicaciones web.' },
            { role: 'Asistente de Programación Web', desc: 'Apoyo en implementación y mantenimiento de plataformas digitales.' },
            { role: 'Asistente de Diseñador Web', desc: 'Creación y mejora de interfaces visuales intuitivas y funcionales.' },
            { role: 'Desarrollador Web Full Stack', desc: 'Desarrollo completo desde el Front-End hasta el Back-End.' },
            { role: 'Desarrollador y Diseñador Web', desc: 'Integración de diseño y programación para experiencias digitales eficientes.' },
          ].map(r => (
            <div class="flex gap-3">
              <span class="text-accent2 shrink-0 mt-1">◆</span>
              <div>
                <p class="text-[14px] font-semibold text-content">{r.role}</p>
                <p class="text-[13px] text-content-secondary">{r.desc}</p>
              </div>
            </div>
          ))}
        </ul>
      </div>
      <div>
        <p class="text-[13px] font-bold text-brand-label tracking-widest uppercase mb-4">Razones para llevar este programa</p>
        <ul class="space-y-4">
          {[
            { title: 'Alta demanda en la industria digital', desc: 'El desarrollo web es una de las áreas de mayor crecimiento. Las empresas buscan profesionales que creen plataformas innovadoras y optimicen la experiencia del usuario.' },
            { title: 'Enfoque integral en desarrollo y diseño', desc: 'Combina diseño, programación y gestión de plataformas web. No solo programás: creás soluciones completas.' },
            { title: 'Metodología basada en proyectos reales', desc: 'Desde el inicio aplicás conocimientos en proyectos reales, construyendo un portafolio profesional que destaque ante empleadores.' },
            { title: 'Formación alineada con el mercado', desc: 'Metodologías y estándares que las empresas buscan en desarrolladores modernos, con perfil competitivo y atractivo.' },
          ].map(r => (
            <div class="flex gap-3">
              <span class="text-brand shrink-0 mt-1">◆</span>
              <div>
                <p class="text-[14px] font-semibold text-content">{r.title}</p>
                <p class="text-[13px] text-content-secondary leading-[1.7]">{r.desc}</p>
              </div>
            </div>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Malla curricular -->
  <section class="py-16 md:py-24 px-6" style="background: var(--color-bg-secondary);">
    <div class="max-w-[1060px] mx-auto">
      <div class="text-center mb-12">
        <p class="text-[13px] font-bold text-brand-label tracking-widest uppercase mb-3">Plan de estudios</p>
        <h2 class="headline-display text-[clamp(1.5rem,3vw,2.25rem)] mb-4">Malla Curricular · WEBN5</h2>
        <p class="text-content-secondary text-[15px]">15 materias · 61 créditos · 2874 horas · 7 cuatrimestres</p>
      </div>

      <!-- WEBTEC note (prerequisite / cuatrimestres 1-4) -->
      <div class="card-premium rounded-[18px] p-5 mb-6 border-l-4 border-brand">
        <p class="text-[13px] font-bold text-brand tracking-widest uppercase mb-1">Técnico en Desarrollo y Diseño Web — WEBTEC (prerequisito)</p>
        <p class="text-[13px] text-content-secondary">Los cuatrimestres 1 al 4 corresponden al WEBTEC: 9 materias, 35 créditos, 1638 horas. Al completarlo obtenés este título previo.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          {
            num: '1', creditos: 9, tag: 'WEBTEC',
            cursos: [
              { code: 'FUN-01', name: 'Introducción a las Tecnologías de Información', cr: 3, req: '' },
              { code: 'FUN-08', name: 'Expresión Oral y Escrita', cr: 3, req: '' },
              { code: 'SOFT-28', name: 'Introducción al Diseño y Desarrollo Web', cr: 3, req: '' },
            ]
          },
          {
            num: '2', creditos: 9, tag: 'WEBTEC',
            cursos: [
              { code: 'SOFT-01', name: 'Principios de Programación 1', cr: 5, req: '' },
              { code: 'SOFT-29', name: 'Diseño Web 1', cr: 4, req: 'SOFT-28' },
            ]
          },
          {
            num: '3', creditos: 9, tag: 'WEBTEC',
            cursos: [
              { code: 'SOFT-30', name: 'Programación Web 1', cr: 5, req: 'SOFT-01 + SOFT-29' },
              { code: 'SOFT-39', name: 'Experiencia-Interfaz de Usuario UX-UI', cr: 4, req: 'SOFT-29' },
            ]
          },
          {
            num: '4', creditos: 8, tag: 'WEBTEC',
            cursos: [
              { code: 'FUN-09', name: 'Desarrollo de Habilidades Blandas', cr: 3, req: 'FUN-08' },
              { code: 'SOFT-31', name: 'Proyecto Integrador Web 1', cr: 5, req: 'SOFT-30 + SOFT-39' },
            ]
          },
          {
            num: '5', creditos: 12, tag: 'WEBN5',
            cursos: [
              { code: 'SOFT-03', name: 'Fundamentos de Bases de Datos', cr: 4, req: 'FUN-01 + SOFT-01' },
              { code: 'SOFT-32', name: 'Programación Web 2', cr: 5, req: 'SOFT-30' },
              { code: 'SOFT-38', name: 'Administración y Posicionamiento de Sitios Web', cr: 3, req: 'SOFT-31' },
            ]
          },
          {
            num: '6', creditos: 9, tag: 'WEBN5',
            cursos: [
              { code: 'SOFT-33', name: 'Diseño Web 2', cr: 4, req: 'SOFT-29' },
              { code: 'SOFT-34', name: 'Programación Web 3', cr: 5, req: 'SOFT-32 + SOFT-03' },
            ]
          },
          {
            num: '7', creditos: 5, tag: 'WEBN5',
            cursos: [
              { code: 'SOFT-40', name: 'Proyecto Integrador Web 2', cr: 5, req: 'SOFT-34 + SOFT-31 + SOFT-33' },
            ]
          },
        ].map(q => (
          <div class="card-premium rounded-[18px] overflow-hidden">
            <div class="flex items-center justify-between px-5 py-3 border-b border-border-subtle" style="background: var(--color-bg-primary);">
              <div class="flex items-center gap-2">
                <p class="text-[13px] font-bold text-content uppercase tracking-wide">Cuatrimestre {q.num}</p>
                <span class={`text-[10px] font-bold px-1.5 py-0.5 rounded ${q.tag === 'WEBTEC' ? 'bg-brand-soft text-brand-label' : 'bg-accent2/10 text-accent2'}`}>{q.tag}</span>
              </div>
              <span class="text-[12px] font-semibold text-brand bg-brand-soft px-2 py-0.5 rounded-full">{q.creditos} cr</span>
            </div>
            <div class="p-4 space-y-3">
              {q.cursos.map(c => (
                <div>
                  <div class="flex items-start gap-2">
                    <span class="text-[11px] font-mono font-bold text-brand-label bg-brand-soft px-1.5 py-0.5 rounded shrink-0 mt-0.5">{c.code}</span>
                    <div class="flex-1 flex items-start justify-between gap-2">
                      <span class="text-[13px] text-content-secondary leading-snug">{c.name}</span>
                      <span class="text-[12px] font-semibold text-content-muted shrink-0">{c.cr}cr</span>
                    </div>
                  </div>
                  {c.req && <p class="text-[11px] text-content-muted mt-0.5 pl-1">Req: {c.req}</p>}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24 px-6 text-center" style="background: var(--color-bg-primary);">
    <div class="max-w-[560px] mx-auto">
      <h2 class="headline-display text-[clamp(1.5rem,3.5vw,2.5rem)] mb-5">
        Construí el web del futuro.<br />
        <span class="text-gradient-hero">Desde el diseño hasta el servidor.</span>
      </h2>
      <p class="text-content-secondary text-[15px] leading-[1.8] mb-8">
        7 cuatrimestres · 15 materias · 61 créditos · Virtual en vivo · Universidad CENFOTEC
      </p>
      <a href="/admision/solicitar-informacion" class="btn-primary inline-flex items-center bg-accent2 text-white font-semibold px-8 py-3.5 rounded-full text-[15px] hover:bg-orange-600 transition-colors duration-300">
        Solicitar información
      </a>
    </div>
  </section>

</Base>
