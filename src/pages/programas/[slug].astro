---
import { db } from '../../db/client'
import { programas } from '../../db/schema'
import { eq } from 'drizzle-orm'
import type { ProgramaData } from '../../lib/types'

const { slug } = Astro.params
if (!slug) return Astro.redirect('/programas')

const row = await db.query.programas.findFirst({
  where: eq(programas.slug, slug),
  with: { cursos: { orderBy: (c, { asc }) => [asc(c.cuatrimestre), asc(c.orden)] } }
})

if (!row || !row.activo) {
  return new Response(null, { status: 404 })
}

const programa: ProgramaData = {
  titulo:               row.titulo,
  descripcion:          row.descripcion,
  modalidad:            row.modalidad,
  nivel:                row.nivel,
  duracionCuatrimestres: row.duracionCuatrimestres,
  totalMicrociclos:     row.totalMicrociclos,
  duracionHoras:        row.duracionHoras,
  estadisticas:         (row.estadisticas ?? []) as ProgramaData['estadisticas'],
  tecnologias:          (row.tecnologias  ?? []) as string[],
  objetivo:             row.objetivo,
  cursos:               (row.cursos ?? []).map(c => ({
    codigo:         c.codigo,
    nombre:         c.nombre,
    // microciclos/módulos no tienen cuatrimestre: se agrupan por su secuencia
    cuatrimestre:   c.cuatrimestre ?? c.secuencia,
    secuencia:      c.secuencia,
    orden:          c.orden,
    creditos:       c.creditos,
    horasLectivas:  c.horasLectivas,
    horasPracticas: c.horasPracticas,
    horasEstudio:   c.horasEstudio,
  })),
}

// Mapeo mínimo: todas las modalidades usan el layout que sí renderiza el plan
// (ProgramaTecnico → ProgramaLayout → CurriculumSection). Los layouts ricos por
// modalidad son Fase 2. (ProgramaCorporativo se descarta acá porque oculta el plan.)
const LayoutPrograma = (await import('../../components/programa/ProgramaTecnico.astro')).default
---
<LayoutPrograma programa={programa} />
