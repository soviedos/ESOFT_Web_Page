---
import Base from '../../layouts/Base.astro'
import { db } from '../../db/client'
import { programas } from '../../db/schema'
import { eq } from 'drizzle-orm'

const todos = await db.select({ modalidad: programas.modalidad })
  .from(programas).where(eq(programas.activo, true))

const cuatri = todos.filter(p => p.modalidad === 'cuatrimestral').length
const micros = todos.filter(p => p.modalidad !== 'cuatrimestral').length

const modalidades = [
  {
    href: '/programas/cuatrimestrales',
    eyebrow: 'Formación titulada',
    titulo: 'Cuatrimestrales',
    descripcion: 'Programas titulados por cuatrimestres: técnicos, bachillerato y maestrías. La ruta formal hacia un grado académico en ingeniería de software.',
    bullets: ['Técnicos', 'Bachillerato', 'Maestrías'],
    conteo: cuatri,
    unidad: cuatri === 1 ? 'programa' : 'programas',
  },
  {
    href: '/programas/microciclos',
    eyebrow: 'Formación modular',
    titulo: 'Microciclos',
    descripcion: 'Aprendizaje flexible por microciclos: rutas de conocimiento, cursos 360 y cursos de aprendizaje continuo. Sumá competencias y microcredenciales a tu ritmo.',
    bullets: ['Rutas de conocimiento', 'Cursos 360', 'Cursos de aprendizaje continuo'],
    conteo: micros,
    unidad: micros === 1 ? 'programa' : 'programas',
  },
]
---

<Base
  title="Programas académicos"
  description="Oferta académica de ESOFT: programas cuatrimestrales titulados y microciclos modulares en software, IA, testing, UX y arquitectura."
>
  <section class="relative py-12 md:py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">Programas académicos</h1>
      <p class="text-content-secondary text-base md:text-lg max-w-3xl">
        Dos modalidades para construir tu camino en ingeniería de software: formación titulada
        por cuatrimestres o aprendizaje modular por microciclos. Elegí cómo querés avanzar.
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 pb-20 md:pb-28">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {modalidades.map(m => (
        <a href={m.href} class="card-premium rounded-[20px] p-8 md:p-10 flex flex-col gap-4 no-underline group">
          <span class="text-[11px] font-bold uppercase tracking-widest text-brand">{m.eyebrow}</span>
          <h2 class="text-2xl md:text-3xl font-bold text-content tracking-tight">{m.titulo}</h2>
          <p class="text-[15px] text-content-secondary leading-[1.8] flex-1">{m.descripcion}</p>
          <ul class="flex flex-wrap gap-2 mt-1">
            {m.bullets.map(b => (
              <li class="rounded-full border border-border-default bg-brand-soft/30 px-3 py-1 text-[12.5px] font-medium text-content-secondary">{b}</li>
            ))}
          </ul>
          <div class="flex items-center justify-between mt-3 pt-4 border-t border-border-subtle">
            <span class="text-[13px] text-content-muted">{m.conteo} {m.unidad} disponibles</span>
            <span class="link-arrow text-[14px]">
              Explorar <svg viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>
