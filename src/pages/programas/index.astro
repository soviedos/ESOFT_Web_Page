---
import Base from '../../layouts/Base.astro';
import Card from '../../components/Card.astro';
---

<Base title="Programas" description="Oferta académica de ESOFT: maestrías, bachillerato, técnicos cuatrimestrales y técnicos ágiles.">
  <section class="relative py-12 md:py-20 px-6">
    <div class="relative max-w-6xl mx-auto">
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">Programas académicos</h1>
      <p class="text-content-secondary text-base md:text-lg max-w-3xl">
        Formación especializada en software, IA, testing, UX y arquitectura. Elegí el programa que se adapta a tus metas.
      </p>
    </div>
  </section>

  <!-- Maestrías -->
  <section class="max-w-6xl mx-auto px-6 py-12 md:py-20">
    <h2 class="text-xl md:text-2xl font-bold mb-6">Maestrías</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <Card title="Maestría en Ingeniería de Software e IA" description="Liderá proyectos de software con inteligencia artificial, machine learning y sistemas inteligentes." href="/programas/maestria-ingenieria-software-ia" />
      <Card title="Maestría en Arquitectura y Diseño de Software" description="Diseñá sistemas escalables, patrones arquitectónicos y soluciones enterprise." href="/programas/maestria-arquitectura-diseno-software" />
    </div>
  </section>

  <!-- Bachillerato -->
  <section class="py-12 md:py-20 px-6 border-t border-border-subtle">
    <div class="relative max-w-6xl mx-auto">
      <h2 class="text-xl md:text-2xl font-bold mb-6">Bachillerato</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <Card title="Bachillerato en Ingeniería del Software" description="Programa de 3 años (9 cuatrimestres) para formar ingenieros del software con criterio ingenieril y dominio de IA. Acreditado por SINAES." href="/programas/bachillerato-ingenieria-software" />
      </div>
    </div>
  </section>

  <!-- Técnicos cuatrimestrales -->
  <section class="py-12 md:py-20 px-6 border-t border-border-subtle">
    <div class="relative max-w-6xl mx-auto">
      <h2 class="text-xl md:text-2xl font-bold mb-2">Técnicos cuatrimestrales</h2>
      <p class="text-content-secondary text-[14px] mb-8">Nivel N5 (7 cuatrimestres) y Nivel N2 (4 cuatrimestres). Los N2 sirven como puerta de entrada o salida lateral de los N5.</p>
      <p class="text-[13px] font-bold text-brand-label tracking-widest uppercase mb-4">Nivel N5 — 7 cuatrimestres</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <Card title="Técnico en Ingeniería del Software (SOFTN5)" description="7 cuatrimestres · 17 materias · 62 créditos. Desarrollador de Software, Analista y Desarrollador Web. Incluye salida lateral SOFTN2." href="/programas/tecnico-ingenieria-software" />
        <Card title="Técnico en Desarrollo y Diseño Web Avanzado (WEBN5)" description="7 cuatrimestres · 15 materias · 61 créditos. Full Stack, Front-End y Diseño Web. Requiere WEBTEC." href="/programas/tecnico-desarrollo-web-avanzado" />
      </div>
      <p class="text-[13px] font-bold text-brand-label tracking-widest uppercase mb-4">Nivel N2 — 4 cuatrimestres</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <Card title="Técnico en Desarrollo de Software (SOFTN2)" description="4 cuatrimestres · 10 materias · 36 créditos. Programador de Aplicaciones y Web. Puerta de entrada al SOFTN5." href="/programas/tecnico-desarrollo-software" />
        <Card title="Técnico en Desarrollo y Diseño Web (WEBTEC)" description="4 cuatrimestres · 9 materias · 35 créditos. Web Developer Junior y Diseñador Web. Puerta de entrada al WEBN5." href="/programas/tecnico-desarrollo-diseno-web" />
      </div>
    </div>
  </section>

  <!-- Técnicos ágiles -->
  <section class="py-12 md:py-20 px-6 border-t border-border-subtle">
    <div class="relative max-w-6xl mx-auto">
      <h2 class="text-xl md:text-2xl font-bold mb-6">Técnicos ágiles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <Card title="Diseño Gráfico Web y UX" description="Diseño de interfaces, experiencia de usuario, prototipado y diseño visual para productos digitales." href="/programas/tecnico-diseno-grafico-web-ux" />
        <Card title="Testing Manual de Software" description="Fundamentos del testing, diseño de casos de prueba, gestión de defectos y herramientas de QA." href="/programas/testing-manual-software" />
        <Card title="Automatización de Pruebas" description="Frameworks de automatización, CI/CD, scripting y estrategias de testing automatizado." href="/programas/automatizacion-pruebas-software" />
        <Card title="Testing de Software con IA" description="Testing potenciado con inteligencia artificial, análisis predictivo de defectos y generación automática de pruebas." href="/programas/testing-software-ia-sistemas-inteligentes" />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-10 md:py-16 px-4 text-center border-t border-border-subtle">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-xl md:text-2xl font-bold mb-4">¿No sabés cuál elegir?</h2>
      <p class="text-content-muted mb-6">Explorá nuestras rutas de aprendizaje para encontrar el camino ideal según tu perfil.</p>
      <a href="/rutas" class="btn-primary inline-block rounded-full bg-brand text-white px-6 py-3 text-sm font-semibold hover:bg-brand-hover transition-all duration-300">
        Ver rutas de aprendizaje
      </a>
    </div>
  </section>
</Base>
