---
import ProgramaLayout from '../../components/programa/ProgramaLayout.astro'
import SectionBadge from '../../components/ui/SectionBadge.astro'

const rolesGeneral = ['Ingeniero de requerimientos','Desarrollador de software de alto nivel de complejidad','Diseñador de sistemas de software','Experto en calidad y pruebas de software','Gerente de procesos y administración de software']
const rolesEnfasis = ['Arquitecto de sistemas de software que incorporan componentes de IA','Especialista en rendimiento de sistemas intensivos en uso de datos','Especialista en aprendizaje automático']

const nivelatoria = [
  { code: 'NIV-01', name: 'Programación' }, { code: 'NIV-02', name: 'Bases de Datos' },
  { code: 'NIV-05', name: 'Estructuras Formales y Analíticas' }, { code: 'NIV-06', name: 'Infraestructura Informática' },
  { code: 'NIV-07', name: 'Proyecto de Desarrollo Web (*)' },
]
const electivos = [
  { code: 'PSWE-19', name: 'Sistemas Basados en Conocimiento',    req: 'PSWE-02, PSWE-04' },
  { code: 'PSWE-20', name: 'Aprendizaje Automático',              req: 'PSWE-03, PSWE-04' },
  { code: 'PSWE-21', name: 'Inteligencia Artificial Distribuida', req: 'PSWE-01, PSWE-18' },
  { code: 'PSWE-22', name: 'Recuperación de Información',         req: 'PSWE-03, PSWE-18' },
]

const programa = {
  titulo:               'Maestría en Ingeniería del Software — MISIA',
  tituloAcento:         'Énfasis en Inteligencia Artificial',
  descripcion:          'Dominá todos los aspectos de producción de software con aplicación de principios ingenieriles e inteligencia artificial. Conceptualizá, diseñá y liderá sistemas de software que incorporen componentes de IA con criterio técnico, ético y estratégico.',
  tipo:                 'maestria',
  duracionCuatrimestres: 6,
  badgeOverride:        'Maestría · MISIA · 6 cuatrimestres',
  estadisticas: [
    { valor: '15',          label: 'Cursos' },
    { valor: '64',          label: 'Créditos' },
    { valor: '2',           label: 'Años · 6 cuatrimestres', colorValor: 'brand' as const },
    { valor: 'Virtual\nen vivo', label: 'Modalidad',         colorValor: 'accent2' as const, size: 'lg' as const },
  ],
  ctaTitulo:       'Liderá la próxima generación',
  ctaTituloAcento: 'de sistemas inteligentes.',
  ctaDescripcion:  '2 años · 15 cursos · 64 créditos · Modalidad presencial · Universidad CENFOTEC',
  cursos: [
    { code: 'PSWE-01', nombre: 'Tendencias en Ingeniería del Software',    cuatrimestre: 1, orden: 1, creditos: 4 },
    { code: 'PSWE-02', nombre: 'Requerimientos de Software y Sistemas',     cuatrimestre: 1, orden: 2, creditos: 5 },
    { code: 'PSWE-03', nombre: 'Construcción y Mantenimiento de Software',  cuatrimestre: 2, orden: 1, creditos: 5 },
    { code: 'PSWE-04', nombre: 'Diseño de Sistemas de Software',            cuatrimestre: 2, orden: 2, creditos: 5 },
    { code: 'PSWE-05', nombre: 'Taller de Innovación en Software 1',        cuatrimestre: 2, orden: 3, creditos: 3 },
    { code: 'PSWE-06', nombre: 'Calidad y Pruebas de Software',             cuatrimestre: 3, orden: 1, creditos: 4 },
    { code: 'PSWE-07', nombre: 'Procesos y Administración de Software',     cuatrimestre: 3, orden: 2, creditos: 4 },
    { code: 'PSWE-08', nombre: 'Taller de Innovación en Software 2',        cuatrimestre: 3, orden: 3, creditos: 3 },
    { code: 'PSWE-18', nombre: 'Aplicaciones de la Inteligencia Artificial', cuatrimestre: 4, orden: 1, creditos: 4 },
    { code: 'PSWE-09', nombre: 'Metodología de Investigación en Informática', cuatrimestre: 4, orden: 2, creditos: 4 },
    { code: 'Electivo',nombre: 'Electivo del Énfasis',                      cuatrimestre: 4, orden: 3, creditos: 4 },
    { code: 'PSWE-10', nombre: 'Proyecto de Investigación Aplicada 1 (*)',  cuatrimestre: 5, orden: 1, creditos: 5 },
    { code: 'Electivo',nombre: 'Electivo del Énfasis',                      cuatrimestre: 5, orden: 2, creditos: 4 },
    { code: 'PSWE-11', nombre: 'Proyecto de Investigación Aplicada 2',      cuatrimestre: 6, orden: 1, creditos: 6 },
    { code: 'Electivo',nombre: 'Electivo del Énfasis',                      cuatrimestre: 6, orden: 2, creditos: 4 },
  ],
}
---
<ProgramaLayout programa={programa} heroGradient="rgba(139,92,246,0.06)">
  <section slot="before-curriculum" class="py-16 md:py-24 px-6" style="background: var(--color-bg-primary);">
    <div class="max-w-[1060px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div>
        <SectionBadge texto="Perfil de ingreso" />
        <p class="text-content-secondary text-[15px] leading-[1.85] mb-6">Bachillerato universitario en Ingeniería Informática o afín. Se requiere presentar atestados académicos y de experiencia profesional, además de demostrar dominio instrumental del idioma inglés.</p>
        <SectionBadge texto="Requisitos de graduación" />
        <ul class="space-y-2">
          {['Haber aprobado los 15 cursos del programa de estudios.','Haber defendido exitosamente el Proyecto de Investigación Aplicada 1 y 2 ante un Tribunal Examinador.'].map(r => (
            <li class="flex gap-3 text-[15px] text-content-secondary"><span class="text-brand shrink-0 mt-1">◆</span>{r}</li>
          ))}
        </ul>
      </div>
      <div>
        <SectionBadge texto="Perfil de salida" />
        <p class="text-content-secondary text-[14px] mb-3">Como graduado general podés desempeñarte como:</p>
        <ul class="space-y-1.5 mb-5">{rolesGeneral.map(r => <li class="flex gap-2 text-[14px] text-content-secondary"><span class="text-brand shrink-0">·</span>{r}</li>)}</ul>
        <p class="text-content-secondary text-[14px] mb-3">El énfasis en IA aplicada te permite desempeñarte específicamente como:</p>
        <ul class="space-y-1.5">{rolesEnfasis.map(r => <li class="flex gap-2 text-[14px] text-content-secondary"><span class="text-accent2 shrink-0">·</span>{r}</li>)}</ul>
      </div>
    </div>
  </section>

  <div slot="curriculum-extra" class="mt-8 space-y-6">
    <div class="card-premium rounded-[18px] p-6">
      <p class="text-[13px] font-bold text-content-muted tracking-widest uppercase mb-4">Ciclo Nivelatorio (0 créditos — según necesidad)</p>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
        {nivelatoria.map(c => <div class="flex flex-col gap-1 bg-bg-elevated rounded-xl p-3"><span class="text-[11px] font-mono font-bold text-content-muted">{c.code}</span><span class="text-[12px] text-content-secondary leading-snug">{c.name}</span></div>)}
      </div>
    </div>
    <div class="card-premium rounded-[18px] overflow-hidden">
      <div class="px-5 py-3 border-b border-border-subtle" style="background: var(--color-bg-primary);"><p class="text-[13px] font-bold text-content">Electivos del Énfasis en Inteligencia Artificial</p></div>
      <div class="p-5 grid grid-cols-1 md:grid-cols-2 gap-3">
        {electivos.map(c => <div class="flex items-start gap-3 rounded-xl border border-border-subtle p-3 bg-bg-primary"><span class="text-[11px] font-mono font-bold text-brand-label bg-brand-soft px-1.5 py-0.5 rounded shrink-0 mt-0.5">{c.code}</span><div><p class="text-[13px] text-content-secondary font-medium">{c.name}</p><p class="text-[12px] text-content-muted mt-0.5">Req: {c.req}</p></div></div>)}
      </div>
    </div>
  </div>

  <section slot="after-curriculum" class="py-16 md:py-20 px-6" style="background: var(--color-bg-primary);">
    <div class="max-w-[1060px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="card-premium rounded-[18px] p-6">
        <SectionBadge texto="Áreas disciplinarias" />
        <ul class="space-y-2">{['Desarrollo','Gestión','Innovación','Inteligencia Artificial Aplicada','Investigación'].map(e => <li class="flex gap-2 text-[14px] text-content-secondary"><span class="text-brand shrink-0">◆</span>{e}</li>)}</ul>
      </div>
      <div class="card-premium rounded-[18px] p-6">
        <SectionBadge texto="Ejes curriculares" />
        <ul class="space-y-2">{['Ingeniería de Sistemas','Pensamiento de Diseño','Tecnología Informática'].map(e => <li class="flex gap-2 text-[14px] text-content-secondary"><span class="text-accent2 shrink-0">◆</span>{e}</li>)}</ul>
      </div>
    </div>
  </section>
</ProgramaLayout>
