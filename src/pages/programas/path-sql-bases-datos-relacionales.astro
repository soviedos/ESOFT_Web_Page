---
import ProgramaLayout from '../../components/programa/ProgramaLayout.astro'
import SectionBadge from '../../components/ui/SectionBadge.astro'

const ACCENT = '#164a98'
const ACCENT_LIGHT = 'rgba(22,74,152,0.3)'
const GRADIENT = `linear-gradient(135deg, #164a98, #006AEA)`

const roles = [
  { role: 'Desarrollador SQL junior',                nivel: 'Junior' },
  { role: 'Analista técnico de datos',               nivel: 'Junior' },
  { role: 'Asistente de bases de datos',             nivel: 'Entrada/técnico' },
  { role: 'Soporte de aplicaciones con BD',          nivel: 'Técnico' },
  { role: 'Desarrollador backend con énfasis en datos', nivel: 'Junior' },
]

const proyectoFinal = {
  num: 13, nombre: 'Proyecto final integrador SQL relacional',
  tareas: ['Análisis del caso empresarial y requerimientos de datos.','Diseño e implementación de la base de datos (modelo conceptual, lógico y físico).','Consultas SQL, vistas, funciones, procedimientos o triggers.','Documentación técnica, integración básica y defensa del proyecto.'],
}

const microciclos = [
  {
    num: 1, name: 'Fundamentos del dato y sistemas de bases de datos', hours: 24,
    temas: [
      { t: 'El dato en los sistemas organizacionales', s: 'Dato, información y conocimiento; uso del dato en procesos empresariales; datos estructurados; problemas comunes de calidad e inconsistencia.' },
      { t: 'Fundamentos de bases de datos', s: 'Concepto de base de datos; diferencia entre archivos y bases de datos; propósito de un sistema gestor; usuarios y roles.' },
      { t: 'Modelo relacional introductorio', s: 'Tablas, filas y columnas; claves primarias; claves foráneas; relaciones entre tablas; integridad básica.' },
      { t: 'Operaciones básicas sobre datos', s: 'Operaciones CRUD; consulta, inserción, actualización y eliminación; relación entre aplicaciones y bases de datos.' },
    ]
  },
  {
    num: 2, name: 'Modelado conceptual y lógico de bases de datos', hours: 24,
    temas: [
      { t: 'Análisis de requerimientos de datos', s: 'Identificación de necesidades de información; reglas de negocio; actores del sistema.' },
      { t: 'Modelado entidad-relación', s: 'Entidades; atributos; identificadores; relaciones; cardinalidad; opcionalidad.' },
      { t: 'Diseño conceptual de datos', s: 'Diagramas entidad-relación; representación de reglas de negocio; validación del modelo con escenarios.' },
      { t: 'Diseño lógico relacional', s: 'Transformación del modelo conceptual al modelo lógico; tablas resultantes; claves primarias y foráneas.' },
    ]
  },
  {
    num: 3, name: 'Normalización y diseño físico relacional', hours: 24,
    temas: [
      { t: 'Normalización de datos', s: 'Propósito de la normalización; redundancia; dependencia funcional; 1FN, 2FN y 3FN.' },
      { t: 'Diseño físico de tablas', s: 'Tipos de datos; definición de columnas; claves primarias; claves foráneas; restricciones básicas.' },
      { t: 'Restricciones de integridad', s: 'NOT NULL; UNIQUE; CHECK; DEFAULT; integridad de entidad, referencial y de dominio.' },
      { t: 'Scripts de creación de base de datos', s: 'CREATE DATABASE; CREATE TABLE; ALTER TABLE; organización de scripts; carga inicial de datos.' },
    ]
  },
  {
    num: 4, name: 'SQL básico para consulta de datos', hours: 24,
    temas: [
      { t: 'Introducción a SQL', s: 'Propósito de SQL; lenguaje de definición, manipulación y consulta de datos; estructura básica de una consulta.' },
      { t: 'Consultas simples', s: 'SELECT; selección de columnas; alias; expresiones calculadas; eliminación de duplicados con DISTINCT.' },
      { t: 'Filtrado y ordenamiento', s: 'WHERE; operadores relacionales y lógicos; BETWEEN; IN; LIKE; ORDER BY.' },
      { t: 'Funciones básicas', s: 'Funciones de texto, numéricas y de fecha; manejo básico de valores nulos.' },
    ]
  },
  {
    num: 5, name: 'SQL intermedio y consultas multitabla', hours: 24,
    temas: [
      { t: 'Consultas con múltiples tablas', s: 'Necesidad de relacionar datos; claves primarias y foráneas en consultas; combinación de información.' },
      { t: 'Joins', s: 'INNER JOIN; LEFT JOIN; RIGHT JOIN; FULL JOIN; errores comunes en joins; duplicidad de resultados.' },
      { t: 'Agregación de datos', s: 'COUNT; SUM; AVG; MIN; MAX; GROUP BY; agrupamientos por múltiples columnas.' },
      { t: 'Filtros sobre agregados', s: 'HAVING; diferencia entre WHERE y HAVING; reportes resumidos; consultas para indicadores operativos.' },
    ]
  },
  {
    num: 6, name: 'SQL avanzado para análisis y reportes operativos', hours: 24,
    temas: [
      { t: 'Subconsultas', s: 'Subconsultas escalares; subconsultas con múltiples resultados; subconsultas correlacionadas; uso de EXISTS.' },
      { t: 'Common Table Expressions', s: 'Uso de WITH; legibilidad de consultas complejas; CTEs encadenadas; consultas reutilizables.' },
      { t: 'Funciones de ventana', s: 'OVER; PARTITION BY; ORDER BY; rankings; acumulados; comparaciones entre filas.' },
      { t: 'Consultas para reportes operativos', s: 'Consolidación de datos; indicadores por período; segmentación; preparación de consultas para dashboards.' },
    ]
  },
  {
    num: 7, name: 'Integridad, transacciones y consistencia', hours: 24,
    temas: [
      { t: 'Integridad de datos', s: 'Integridad de entidad, referencial y de dominio; reglas de negocio implementadas en la base de datos.' },
      { t: 'Transacciones', s: 'Concepto de transacción; operaciones atómicas; COMMIT; ROLLBACK; errores en operaciones de actualización.' },
      { t: 'Propiedades ACID', s: 'Atomicidad; consistencia; aislamiento; durabilidad; importancia de ACID en sistemas empresariales.' },
      { t: 'Concurrencia básica', s: 'Acceso simultáneo a datos; bloqueos; conflictos de actualización; consistencia con múltiples usuarios.' },
    ]
  },
  {
    num: 8, name: 'Programación en BD I: vistas y funciones', hours: 24,
    temas: [
      { t: 'Vistas', s: 'Propósito de las vistas; creación de vistas; simplificación de consultas; seguridad y acceso controlado.' },
      { t: 'Funciones definidas por el usuario', s: 'Concepto de función; parámetros; valores de retorno; funciones escalares aplicadas a reglas de negocio.' },
      { t: 'Reutilización de lógica SQL', s: 'Encapsulamiento de cálculos; reducción de duplicidad; organización de lógica consultiva.' },
      { t: 'Buenas prácticas en vistas y funciones', s: 'Nombres claros; límites de uso; impacto en rendimiento; documentación de objetos programables.' },
    ]
  },
  {
    num: 9, name: 'Programación en BD II: procedimientos y triggers', hours: 24,
    temas: [
      { t: 'Procedimientos almacenados', s: 'Propósito; creación; parámetros de entrada y salida; ejecución; casos de uso en procesos empresariales.' },
      { t: 'Lógica procedural en base de datos', s: 'Variables; condicionales; ciclos básicos; control de errores; operaciones transaccionales dentro de procedimientos.' },
      { t: 'Triggers', s: 'Concepto de trigger; eventos INSERT, UPDATE y DELETE; automatización de reglas; auditoría básica.' },
      { t: 'Uso responsable de lógica en la BD', s: 'Separación entre lógica de aplicación y lógica de datos; riesgos de sobrecargar la base; trazabilidad.' },
    ]
  },
  {
    num: 10, name: 'Integración de bases de datos con aplicaciones', hours: 24,
    temas: [
      { t: 'Arquitectura de integración', s: 'Relación entre aplicación y base de datos; capas de acceso a datos; cliente, servidor y DBMS.' },
      { t: 'Conexión desde aplicaciones', s: 'Cadenas de conexión; drivers; credenciales; manejo de conexiones; buenas prácticas básicas.' },
      { t: 'Operaciones CRUD desde código', s: 'Consultas parametrizadas; inserción, actualización, consulta y eliminación desde una aplicación.' },
      { t: 'Seguridad en la integración', s: 'Riesgo de SQL injection; uso de parámetros; manejo seguro de credenciales; validación de entradas.' },
    ]
  },
  {
    num: 11, name: 'Rendimiento básico, indexación y planes de ejecución', hours: 24,
    temas: [
      { t: 'Fundamentos de rendimiento SQL', s: 'Diferencia entre consulta funcional y consulta eficiente; volumen de datos; costo de operaciones.' },
      { t: 'Índices', s: 'Concepto de índice; índices sobre claves y columnas de búsqueda; cuándo usar índices; efectos en escrituras.' },
      { t: 'Planes de ejecución', s: 'Lectura básica de planes; operaciones de escaneo y búsqueda; identificación de cuellos de botella.' },
      { t: 'Buenas prácticas de optimización inicial', s: 'Optimización de filtros; joins eficientes; evitar consultas innecesariamente complejas.' },
    ]
  },
  {
    num: 12, name: 'Seguridad básica, calidad de datos y documentación técnica', hours: 24,
    temas: [
      { t: 'Seguridad básica en bases de datos', s: 'Usuarios; roles; permisos; principio de mínimo privilegio; acceso a objetos de base de datos.' },
      { t: 'Protección de datos sensibles', s: 'Identificación de datos sensibles; exposición innecesaria de información; buenas prácticas de consulta.' },
      { t: 'Calidad de datos', s: 'Completitud; consistencia; exactitud; duplicidad; validaciones; reglas de calidad en datos estructurados.' },
      { t: 'Documentación técnica', s: 'Diccionario de datos; documentación de tablas, relaciones y restricciones; convenciones de nombres.' },
    ]
  },
]

const programa = {
  titulo:               'Path: Desarrollo SQL y Bases de Datos Relacionales',
  tituloAcento:         'Bases de Datos Relacionales',
  descripcion:          'Formá competencias aplicadas en diseño, construcción, consulta, integración y documentación de bases de datos relacionales para aplicaciones empresariales y procesos organizacionales.',
  tipo:                 'tecnico',
  duracionCuatrimestres: 13,
  badgeOverride:        'Path técnico especializado · 13 microciclos',
  estadisticas: [
    { valor: '13',     label: 'Microciclos' },
    { valor: '304',    label: 'Horas totales' },
    { valor: 'SFIA',   label: 'Nivel 2–3', colorValor: 'brand' as const, size: 'lg' as const },
    { valor: 'Virtual\nen vivo', label: 'Modalidad', colorValor: 'accent2' as const, size: 'lg' as const },
  ],
  ctaTitulo:       'Dominá SQL.',
  ctaTituloAcento: 'Construí soluciones con datos reales.',
  ctaDescripcion:  '13 microciclos · 304 horas · Virtual en vivo · Universidad CENFOTEC',
  cursos: [],
}
---
<ProgramaLayout programa={programa} heroGradient="rgba(22,74,152,0.06)">
  <section slot="before-curriculum" class="py-12 md:py-16 px-6" style="background: var(--color-bg-primary);">
    <div class="max-w-[1060px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-10">
      <div>
        <SectionBadge texto="Perfil de salida" />
        <p class="text-content-secondary text-[15px] leading-[1.85]">Diseñar, construir, consultar e integrar bases de datos relacionales aplicando modelado de datos, SQL, restricciones de integridad, transacciones, vistas, procedimientos almacenados, funciones, triggers, documentación técnica y buenas prácticas de seguridad y calidad.</p>
      </div>
      <div>
        <SectionBadge texto="Roles laborales" />
        <ul class="space-y-2">
          {roles.map(r => (
            <li class="flex items-center justify-between rounded-xl border border-border-subtle px-4 py-2.5 bg-bg-secondary">
              <span class="text-[14px] text-content-secondary">{r.role}</span>
              <span class="text-[11px] font-bold text-brand bg-brand-soft px-2 py-0.5 rounded-full shrink-0 ml-2">{r.nivel}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section slot="after-curriculum" class="py-16 md:py-24 px-6" style="background: var(--color-bg-secondary);">
    <div class="max-w-[1060px] mx-auto">
      <div class="text-center mb-12">
        <SectionBadge texto="Plan de estudios" mb="mb-3" />
        <h2 class="headline-display text-[clamp(1.5rem,3vw,2.25rem)] mb-4">13 Microciclos · 304 horas</h2>
        <p class="text-content-secondary text-[15px]">12 microciclos formativos de 24h + 1 microciclo final integrador de 16h</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        {microciclos.map(m => (
          <div class="card-premium rounded-[18px] overflow-hidden">
            <div class="flex items-center gap-3 px-5 py-3 border-b border-border-subtle" style="background: var(--color-bg-primary);">
              <span class="w-8 h-8 rounded-full flex items-center justify-center text-[12px] font-bold text-white shrink-0" style={`background: ${ACCENT};`}>{m.num}</span>
              <div class="flex-1">
                <p class="text-[13px] font-bold text-content leading-snug">{m.name}</p>
                <p class="text-[11px] text-content-muted">{m.hours} horas · 4 semanas</p>
              </div>
            </div>
            <div class="p-4 space-y-3">
              {m.temas.map(tema => (
                <div class="border-l-2 pl-3" style={`border-color: ${ACCENT_LIGHT};`}>
                  <p class="text-[12px] font-bold text-content mb-0.5">{tema.t}</p>
                  <p class="text-[11px] text-content-secondary leading-snug">{tema.s}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div class="rounded-[18px] p-6 text-white mb-6" style={`background: ${GRADIENT};`}>
        <div class="flex items-center gap-3 mb-3">
          <span class="w-8 h-8 rounded-full flex items-center justify-center text-[12px] font-bold bg-white/20 shrink-0">{proyectoFinal.num}</span>
          <div>
            <p class="text-[12px] font-bold tracking-widest uppercase opacity-80">Microciclo {proyectoFinal.num} · Proyecto final integrador · 16 horas</p>
            <p class="text-[15px] font-bold">{proyectoFinal.nombre}</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-3">
          {proyectoFinal.tareas.map(t => <div class="flex gap-2 text-[13px] opacity-90"><span class="shrink-0">·</span>{t}</div>)}
        </div>
      </div>
      <div class="card-premium rounded-[18px] p-6 text-center">
        <p class="text-[13px] font-bold text-brand-label tracking-widest uppercase mb-2">Credencial al completar</p>
        <p class="text-[15px] font-bold text-content">CENFOTEC Certified SQL & Relational Database Developer – Junior</p>
      </div>
    </div>
  </section>
</ProgramaLayout>
