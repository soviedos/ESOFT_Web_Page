---
import Base from '../../layouts/Base.astro';
---

<Base title="Path: Desarrollo SQL y Bases de Datos Relacionales" description="Path técnico especializado en SQL y bases de datos relacionales. 13 microciclos, 304 horas. Universidad CENFOTEC.">

  <section class="relative py-16 md:py-24 px-6" style="background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(22,74,152,0.06) 0%, transparent 60%), var(--color-bg-secondary);">
    <div class="max-w-[1060px] mx-auto">
      <nav class="text-[13px] text-content-muted mb-8">
        <a href="/programas" class="hover:text-content transition-colors">Programas</a>
        <span class="mx-2">·</span>
        <span class="text-content">Path: Desarrollo SQL y Bases de Datos Relacionales</span>
      </nav>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">
        <div>
          <p class="text-[13px] font-bold text-brand-label tracking-widest uppercase mb-4">Path técnico especializado · 13 microciclos</p>
          <h1 class="headline-display text-[clamp(2rem,4.5vw,3rem)] mb-6">
            Desarrollo SQL y<br />
            <span class="text-gradient-hero">Bases de Datos Relacionales</span>
          </h1>
          <p class="text-content-secondary text-[16px] leading-[1.85] mb-6 max-w-[480px]">
            Formá competencias aplicadas en diseño, construcción, consulta, integración y documentación de bases de datos relacionales para aplicaciones empresariales y procesos organizacionales.
          </p>
          <div class="card-premium rounded-[14px] p-4 mb-8 flex gap-3 items-start">
            <span class="text-brand text-[18px] shrink-0">→</span>
            <p class="text-[13px] text-content-secondary leading-snug">
              <strong>Requisito:</strong> Haber aprobado <a href="/programas/python-foundations" class="text-brand underline">Python Foundations</a> o demostrar suficiencia equivalente en lógica, funciones, archivos, conexión básica a BD y Git.
            </p>
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="/admision/solicitar-informacion" class="btn-primary inline-flex items-center bg-accent2 text-white font-semibold px-7 py-3.5 rounded-full text-[15px] hover:bg-orange-600 transition-colors duration-300">
              Solicitar información
            </a>
            <a href="/admision" class="btn-ghost inline-flex items-center border border-border-default text-content-secondary font-medium px-7 py-3.5 rounded-full text-[15px]">
              Proceso de admisión
            </a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="card-stat p-6 text-center">
            <p class="text-[2.25rem] font-extrabold text-content">13</p>
            <p class="text-[14px] text-content-secondary mt-1">Microciclos</p>
          </div>
          <div class="card-stat p-6 text-center">
            <p class="text-[2.25rem] font-extrabold text-content">304</p>
            <p class="text-[14px] text-content-secondary mt-1">Horas totales</p>
          </div>
          <div class="card-stat p-6 text-center">
            <p class="text-[1.75rem] font-extrabold text-brand leading-tight">SFIA<br/><span class="text-[1rem]">Nivel 2–3</span></p>
            <p class="text-[14px] text-content-secondary mt-1">Alineación</p>
          </div>
          <div class="card-stat p-6 text-center">
            <p class="text-[1.25rem] font-extrabold text-accent2 leading-tight">Virtual<br/>en vivo</p>
            <p class="text-[14px] text-content-secondary mt-1">Modalidad</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Perfil de salida y roles -->
  <section class="py-16 md:py-20 px-6" style="background: var(--color-bg-primary);">
    <div class="max-w-[1060px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-10">
      <div>
        <p class="text-[13px] font-bold text-brand-label tracking-widest uppercase mb-4">Perfil de salida</p>
        <p class="text-content-secondary text-[15px] leading-[1.85]">
          Diseñar, construir, consultar e integrar bases de datos relacionales para aplicaciones empresariales, aplicando modelado de datos, SQL, restricciones de integridad, transacciones, vistas, procedimientos almacenados, funciones, triggers, documentación técnica y buenas prácticas básicas de seguridad y calidad.
        </p>
      </div>
      <div>
        <p class="text-[13px] font-bold text-brand-label tracking-widest uppercase mb-4">Roles laborales</p>
        <ul class="space-y-2">
          {[
            { role: 'Desarrollador SQL junior', nivel: 'Junior' },
            { role: 'Analista técnico de datos', nivel: 'Junior' },
            { role: 'Asistente de bases de datos', nivel: 'Entrada/técnico' },
            { role: 'Soporte de aplicaciones con BD', nivel: 'Técnico' },
            { role: 'Desarrollador backend con énfasis en datos', nivel: 'Junior' },
          ].map(r => (
            <li class="flex items-center justify-between rounded-xl border border-border-subtle px-4 py-2.5 bg-bg-secondary">
              <span class="text-[14px] text-content-secondary">{r.role}</span>
              <span class="text-[11px] font-bold text-brand bg-brand-soft px-2 py-0.5 rounded-full shrink-0 ml-2">{r.nivel}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Malla de microciclos -->
  <section class="py-16 md:py-24 px-6" style="background: var(--color-bg-secondary);">
    <div class="max-w-[1060px] mx-auto">
      <div class="text-center mb-12">
        <p class="text-[13px] font-bold text-brand-label tracking-widest uppercase mb-3">Plan de estudios</p>
        <h2 class="headline-display text-[clamp(1.5rem,3vw,2.25rem)] mb-4">13 Microciclos · 304 horas</h2>
        <p class="text-content-secondary text-[15px]">12 microciclos formativos de 24h + 1 microciclo final integrador de 16h</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
        {[
          { num: 1, name: 'Fundamentos del dato y sistemas de bases de datos', hours: 24 },
          { num: 2, name: 'Modelado conceptual y lógico de bases de datos', hours: 24 },
          { num: 3, name: 'Normalización y diseño físico relacional', hours: 24 },
          { num: 4, name: 'SQL básico para consulta de datos', hours: 24 },
          { num: 5, name: 'SQL intermedio y consultas multitabla', hours: 24 },
          { num: 6, name: 'SQL avanzado para análisis y reportes operativos', hours: 24 },
          { num: 7, name: 'Integridad, transacciones y consistencia', hours: 24 },
          { num: 8, name: 'Programación en BD I: vistas y funciones', hours: 24 },
          { num: 9, name: 'Programación en BD II: procedimientos y triggers', hours: 24 },
          { num: 10, name: 'Integración de bases de datos con aplicaciones', hours: 24 },
          { num: 11, name: 'Rendimiento básico, indexación y planes de ejecución', hours: 24 },
          { num: 12, name: 'Seguridad básica, calidad de datos y documentación', hours: 24 },
        ].map(m => (
          <div class="flex items-center gap-3 rounded-[14px] border border-border-subtle p-3 bg-bg-primary">
            <span class="w-8 h-8 rounded-full flex items-center justify-center text-[12px] font-bold text-white shrink-0" style="background: #164a98;">{m.num}</span>
            <div>
              <p class="text-[12px] text-content-secondary leading-snug">{m.name}</p>
              <p class="text-[11px] text-content-muted">{m.hours}h</p>
            </div>
          </div>
        ))}
      </div>

      <div class="rounded-[18px] p-6 text-white" style="background: linear-gradient(135deg, #164a98, #006AEA);">
        <p class="text-[12px] font-bold tracking-widest uppercase mb-2 opacity-80">Microciclo 13 · Proyecto final integrador · 16 horas</p>
        <p class="text-[15px] font-bold mb-1">Proyecto final integrador SQL relacional</p>
        <p class="text-[13px] opacity-90">Solución relacional completa con modelo de datos, scripts SQL, consultas básicas/intermedias/avanzadas, objetos programables, integración básica, documentación y defensa técnica.</p>
      </div>

      <!-- Credencial -->
      <div class="mt-8 card-premium rounded-[18px] p-6 text-center">
        <p class="text-[13px] font-bold text-brand-label tracking-widest uppercase mb-2">Credencial al completar</p>
        <p class="text-[15px] font-bold text-content">CENFOTEC Certified SQL & Relational Database Developer – Junior</p>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 px-6 text-center" style="background: var(--color-bg-primary);">
    <div class="max-w-[560px] mx-auto">
      <h2 class="headline-display text-[clamp(1.5rem,3.5vw,2.5rem)] mb-5">
        Dominá SQL.<br />
        <span class="text-gradient-hero">Construí soluciones con datos reales.</span>
      </h2>
      <p class="text-content-secondary text-[15px] leading-[1.8] mb-8">
        13 microciclos · 304 horas · Virtual en vivo · Universidad CENFOTEC
      </p>
      <a href="/admision/solicitar-informacion" class="btn-primary inline-flex items-center bg-accent2 text-white font-semibold px-8 py-3.5 rounded-full text-[15px] hover:bg-orange-600 transition-colors duration-300">
        Solicitar información
      </a>
    </div>
  </section>

</Base>
