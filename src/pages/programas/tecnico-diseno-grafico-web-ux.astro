---
import ProgramaLayout from '../../components/programa/ProgramaLayout.astro'
import SectionBadge from '../../components/ui/SectionBadge.astro'

const cursos = [
  { code: 'SOFT-329', nombre: 'Diseño Gráfico 1',                     cuatrimestre: 1, orden: 1,  creditos: 3 },
  { code: 'SOFT-330', nombre: 'Diseño Gráfico 2',                     cuatrimestre: 1, orden: 2,  creditos: 3 },
  { code: 'SOFT-331', nombre: 'Diseño Visual Digital 1',              cuatrimestre: 2, orden: 1,  creditos: 3 },
  { code: 'SOFT-332', nombre: 'Diseño Visual Digital 2',              cuatrimestre: 2, orden: 2,  creditos: 3 },
  { code: 'SOFT-343', nombre: 'Diseño Responsivo 1',                  cuatrimestre: 3, orden: 1,  creditos: 3 },
  { code: 'SOFT-344', nombre: 'Diseño Responsivo 2',                  cuatrimestre: 3, orden: 2,  creditos: 3 },
  { code: 'SOFT-334', nombre: 'Introducción a Design Thinking',       cuatrimestre: 4, orden: 1,  creditos: 3 },
  { code: 'SOFT-342', nombre: 'Fundamentos UX',                       cuatrimestre: 4, orden: 2,  creditos: 3 },
  { code: 'SOFT-333', nombre: 'UX Avanzado',                          cuatrimestre: 5, orden: 1,  creditos: 3 },
  { code: 'SOFT-346', nombre: 'Interfaces visuales con FIGMA',        cuatrimestre: 5, orden: 2,  creditos: 3 },
  { code: 'FUN-450',  nombre: 'Inteligencia Emocional aplicada 1',    cuatrimestre: 6, orden: 1,  creditos: 3 },
  { code: 'SOFT-347', nombre: 'Portafolio Profesional',               cuatrimestre: 6, orden: 2,  creditos: 3 },
  { code: 'SOFT-335', nombre: 'Proyecto de Diseño UX 1',              cuatrimestre: 6, orden: 3,  creditos: 3 },
]

const programa = {
  titulo:               'Técnico en Diseño Gráfico Web y Experiencia de Usuario',
  tituloAcento:         'y Experiencia de Usuario',
  descripcion:          'Desarrollá tus habilidades para crear y comunicar ideas utilizando herramientas y principios de diseño, experiencia de usuario y design thinking. El diseño correcto, centrado en el usuario, es hoy una ventaja competitiva clave en la industria digital.',
  tipo:                 'tecnico',
  duracionCuatrimestres: 12,
  badgeOverride:        'Técnico ágil · EXUTEC · 12 microciclos',
  estadisticas: [
    { valor: '13',           label: 'Cursos' },
    { valor: '12',           label: 'Microciclos',                 colorValor: 'brand'   as const },
    { valor: '4 sem',        label: 'Duración de cada microciclo', size: 'lg' as const },
    { valor: 'Virtual\nen vivo', label: 'Modalidad',               colorValor: 'accent2' as const, size: 'lg' as const },
  ],
  ctaTitulo:        'Creá interfaces que',
  ctaTituloAcento:  'las personas realmente necesitan.',
  ctaDescripcion:   '12 microciclos · 13 cursos · Virtual en vivo · Universidad CENFOTEC',
  cursos,
}
---
<ProgramaLayout programa={programa} heroGradient="rgba(139,92,246,0.05)">
  <section slot="before-curriculum" class="py-16 md:py-24 px-6" style="background: var(--color-bg-primary);">
    <div class="max-w-[1060px] mx-auto grid grid-cols-1 lg:grid-cols-3 gap-10">
      <div>
        <SectionBadge texto="Perfil de entrada" />
        <p class="text-content-secondary text-[15px] leading-[1.85]">Tercer Ciclo de Educación General Básica (9° año). No se requiere experiencia previa en diseño.</p>
      </div>
      <div>
        <SectionBadge texto="Perfil de salida — roles" />
        <ul class="space-y-2">
          {['Diseñador web','Diseñador gráfico','Diseñador multimedia','Diseñador de interfaz de usuario','Adoption & User Experience'].map(r => (
            <li class="flex gap-2 text-[14px] text-content-secondary"><span class="text-accent2 shrink-0">◆</span>{r}</li>
          ))}
        </ul>
      </div>
      <div>
        <SectionBadge texto="Razones para llevar este programa" />
        <ul class="space-y-3">
          {[
            'Las nuevas generaciones tienen una gran necesidad de crear e inspirarse — el diseño canaliza esa creatividad.',
            'El diseño correcto centrado en UX tiene una relevancia creciente. Comunicar más con menos es hoy una ventaja estratégica.',
            'El diseño gráfico potencia el desarrollo intelectual y la resolución creativa de problemas.',
          ].map(r => <li class="flex gap-2 text-[13px] text-content-secondary leading-[1.7]"><span class="text-brand shrink-0 mt-0.5">◆</span>{r}</li>)}
        </ul>
      </div>
    </div>
  </section>
</ProgramaLayout>
