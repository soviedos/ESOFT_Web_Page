---
import Base from '../../layouts/Base.astro';
---

<Base title="Diseño Gráfico Web y UX" description="Técnico ágil en diseño gráfico web y experiencia de usuario.">
  <section class="max-w-6xl mx-auto px-6 py-12 md:py-20">
    <nav class="text-sm text-content-muted mb-6">
      <a href="/programas" class="hover:text-content">Programas</a> / <span class="text-content">Diseño Gráfico Web y UX</span>
    </nav>
    <div class="max-w-3xl">
      <span class="text-sm font-medium text-brand mb-2 block">Técnico ágil</span>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-6">Técnico en Diseño Gráfico Web y UX</h1>
      <p class="text-content-muted mb-6 md:mb-8 text-base md:text-lg">
        Diseño de interfaces, experiencia de usuario, prototipado y diseño visual para productos digitales.
      </p>

      <h2 class="text-xl md:text-2xl font-semibold mb-4">¿Qué aprenderás?</h2>
      <ul class="space-y-2 text-content-muted mb-8">
        <li>• Fundamentos de diseño visual y tipografía</li>
        <li>• Diseño de interfaces (UI)</li>
        <li>• Investigación y diseño de experiencia de usuario (UX)</li>
        <li>• Prototipado con Figma</li>
        <li>• Design systems y componentes</li>
        <li>• Accesibilidad web</li>
      </ul>

      <a href="/admision/solicitar-informacion" class="btn-primary inline-block rounded-full bg-brand text-white px-6 py-3 text-sm font-semibold hover:bg-brand-hover transition-all duration-300">
        Solicitar información
      </a>
    </div>
  </section>
</Base>
