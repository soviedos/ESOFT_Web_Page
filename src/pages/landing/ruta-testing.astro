---
import Base from '../../layouts/Base.astro';
---

<Base title="Ruta de Testing" description="Formá tu carrera en testing de software: manual, automatización e IA.">
  <section class="relative py-16 md:py-28 px-6 overflow-hidden">
    <div class="relative max-w-4xl mx-auto text-center">
      <span class="text-content-secondary text-sm font-medium mb-4 block">Ruta profesional</span>
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Convertite en QA Engineer</h1>
      <p class="text-lg text-content-secondary max-w-2xl mx-auto mb-8">
        De cero a experto: testing manual, automatización con Selenium y Cypress, e inteligencia artificial aplicada al testing.
      </p>
      <a href="/admision/solicitar-informacion" class="btn-primary inline-block rounded-full bg-brand text-white px-8 py-4 text-sm font-semibold hover:bg-brand-hover hover:shadow-glow-soft transition-all duration-300">
        Solicitar información ahora
      </a>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-10 md:py-16">
    <h2 class="text-xl md:text-2xl font-bold mb-6 text-center">Tu progresión</h2>
    <div class="space-y-6">
      <div class="flex gap-4 items-start">
        <span class="flex-shrink-0 w-10 h-10 rounded-full bg-bg-elevated text-brand font-bold flex items-center justify-center">1</span>
        <div>
          <h3 class="font-semibold">Testing Manual de Software</h3>
          <p class="text-sm text-content-muted">Fundamentos, casos de prueba, gestión de defectos.</p>
        </div>
      </div>
      <div class="flex gap-4 items-start">
        <span class="flex-shrink-0 w-10 h-10 rounded-full bg-bg-elevated text-brand font-bold flex items-center justify-center">2</span>
        <div>
          <h3 class="font-semibold">Automatización de Pruebas</h3>
          <p class="text-sm text-content-muted">Selenium, Cypress, Playwright, CI/CD.</p>
        </div>
      </div>
      <div class="flex gap-4 items-start">
        <span class="flex-shrink-0 w-10 h-10 rounded-full bg-bg-elevated text-brand font-bold flex items-center justify-center">3</span>
        <div>
          <h3 class="font-semibold">Testing con IA</h3>
          <p class="text-sm text-content-muted">IA aplicada, generación automática de pruebas, análisis predictivo.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="relative py-16 md:py-24 px-6 text-center">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Empezá tu ruta hoy</h2>
    <a href="/admision/solicitar-informacion" class="btn-primary inline-block rounded-full bg-brand text-white px-8 py-3 text-sm font-semibold hover:bg-brand-hover hover:shadow-glow-soft transition-all duration-300">
      Solicitar información
    </a>
  </section>
</Base>
