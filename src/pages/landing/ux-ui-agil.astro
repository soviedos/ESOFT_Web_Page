---
import Base from '../../layouts/Base.astro';
---

<Base title="UX/UI Ágil" description="Técnico ágil en diseño UX/UI: diseño de experiencias digitales en ESOFT.">
  <section class="relative py-16 md:py-28 px-6 overflow-hidden">
    <div class="relative max-w-4xl mx-auto text-center">
      <span class="text-content-secondary text-sm font-medium mb-4 block">Técnico ágil</span>
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Diseñá experiencias digitales</h1>
      <p class="text-lg text-content-secondary max-w-2xl mx-auto mb-8">
        Aprendé diseño de interfaces, UX research, prototipado con Figma y design systems en un programa ágil y práctico.
      </p>
      <a href="/admision/solicitar-informacion" class="btn-primary inline-block rounded-full bg-accent2 text-white px-8 py-4 text-sm font-semibold hover:bg-[#a01855] transition-all duration-300">
        Solicitar información ahora
      </a>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-10 md:py-16 text-center">
    <h2 class="text-xl md:text-2xl font-bold mb-6">¿Qué vas a aprender?</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-semibold mb-2">Diseño UI</h3>
        <p class="text-sm text-content-muted">Interfaces visuales, tipografía, color y componentes.</p>
      </div>
      <div>
        <h3 class="font-semibold mb-2">UX Research</h3>
        <p class="text-sm text-content-muted">Investigación de usuarios, tests de usabilidad y métricas.</p>
      </div>
      <div>
        <h3 class="font-semibold mb-2">Figma & Prototyping</h3>
        <p class="text-sm text-content-muted">Prototipado interactivo y design systems profesionales.</p>
      </div>
    </div>
  </section>

  <section class="relative py-16 md:py-24 px-6 text-center">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Empezá a diseñar tu futuro</h2>
    <a href="/admision/solicitar-informacion" class="btn-primary inline-block rounded-full bg-accent2 text-white px-8 py-3 text-sm font-semibold hover:bg-[#a01855] transition-all duration-300">
      Solicitar información
    </a>
  </section>
</Base>
