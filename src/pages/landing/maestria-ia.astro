---
import Base from '../../layouts/Base.astro';
import CTAButton from '../../components/ui/CTAButton.astro';
---

<Base title="Maestría en IA" description="Maestría en Ingeniería de Software e Inteligencia Artificial en ESOFT.">
  <section class="relative py-16 md:py-28 px-6 overflow-hidden">
    <div class="relative max-w-4xl mx-auto text-center">
      <span class="text-content-secondary text-sm font-medium mb-4 block">Maestría</span>
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Maestría en Software e IA</h1>
      <p class="text-lg text-content-secondary max-w-2xl mx-auto mb-8">
        Liderá la innovación combinando ingeniería de software avanzada con inteligencia artificial y machine learning.
      </p>
      <CTAButton href="/admision/solicitar-informacion" texto="Solicitar información ahora" />
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-10 md:py-16 text-center">
    <h2 class="text-xl md:text-2xl font-bold mb-6">¿Qué vas a dominar?</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-semibold mb-2">Machine Learning</h3>
        <p class="text-sm text-content-muted">Modelos supervisados, no supervisados y deep learning.</p>
      </div>
      <div>
        <h3 class="font-semibold mb-2">MLOps</h3>
        <p class="text-sm text-content-muted">Despliegue, monitoreo y gobernanza de modelos en producción.</p>
      </div>
      <div>
        <h3 class="font-semibold mb-2">Investigación</h3>
        <p class="text-sm text-content-muted">Tesis aplicada con impacto real en la industria.</p>
      </div>
    </div>
  </section>

  <section class="relative py-16 md:py-24 px-6 text-center">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Llevá tu carrera al siguiente nivel</h2>
    <CTAButton href="/admision/solicitar-informacion" texto="Matricular ahora" />
  </section>
</Base>
