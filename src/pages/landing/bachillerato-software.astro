---
import Base from '../../layouts/Base.astro';
---

<Base title="Bachillerato en Software" description="Formá tu carrera como ingeniero de software con el bachillerato de ESOFT.">
  <section class="relative py-16 md:py-28 px-6 overflow-hidden">
    <div class="relative max-w-4xl mx-auto text-center">
      <span class="text-content-secondary text-sm font-medium mb-4 block">Bachillerato universitario</span>
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Convertite en Ingeniero de Software</h1>
      <p class="text-lg text-content-secondary max-w-2xl mx-auto mb-8">
        4 años de formación integral: desarrollo, arquitectura, testing, IA y gestión de proyectos. Acreditado por SINAES.
      </p>
      <a href="/admision/solicitar-informacion" class="btn-primary inline-block rounded-full bg-brand text-white px-8 py-4 text-sm font-semibold hover:bg-brand-hover transition-all duration-300">
        Solicitar información ahora
      </a>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-10 md:py-16 text-center">
    <h2 class="text-xl md:text-2xl font-bold mb-6">¿Por qué elegir ESOFT?</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-semibold mb-2">100% Software</h3>
        <p class="text-sm text-content-muted">Enfoque exclusivo en ingeniería de software y disciplinas afines.</p>
      </div>
      <div>
        <h3 class="font-semibold mb-2">Acreditado</h3>
        <p class="text-sm text-content-muted">Calidad certificada por SINAES.</p>
      </div>
      <div>
        <h3 class="font-semibold mb-2">Industria</h3>
        <p class="text-sm text-content-muted">Alianzas, proyectos reales y empleabilidad desde el primer día.</p>
      </div>
    </div>
  </section>

  <section class="relative py-16 md:py-24 px-6 text-center">
    <h2 class="text-xl md:text-2xl font-bold mb-4">¿Listo para empezar?</h2>
    <a href="/admision/solicitar-informacion" class="btn-primary inline-block rounded-full bg-brand text-white px-8 py-3 text-sm font-semibold hover:bg-brand-hover transition-all duration-300">
      Aplicar ahora
    </a>
  </section>
</Base>
